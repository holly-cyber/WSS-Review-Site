    ?'<div class="al inf">Apparel — 5 WSS™ pillars (1,2,3,5,7).</div>'
    :'<div class="al inf">Nutrition — 4 criteria: Taste 25%, Nutrition 30%, Performance 30%, Value 15%.</div>';
  let reviewContext='';
  if(state.customerReviews.length){
    if(state.customerReviews[0].rating!==undefined)reviewContext='\n\nCUSTOMER REVIEWS:\n'+state.customerReviews.slice(0,5).map(r=>`${r.rating}★: ${r.text}`).join('\n');
    else reviewContext='\n\nCUSTOMER SENTIMENT:\n'+state.customerReviews[0].text;
  }
  const testerSection=testerNotes?`\n\nTESTER DATA:\n${testerNotes}`:'\n\nTESTER DATA: Not supplied. Flag findings requiring tester evidence as "Not independently verified."';
  const note=fb?`\n\nHolly's feedback: ${fb}\nAddress this directly.`:'';
  const prompt=`Write a WSS™ product review for Women's Sports Store.\n\nProduct: ${name} by ${brand}\nPrice: £${price}\nType: ${pType}\nAffiliate: ${affLink}\n\nResearch:\n${state.researchText||'See product URL.'}${testerSection}${reviewContext}${note}\n\nApply framework exactly. Include all headings, all scores, overall rating, 50-80 word verdict. Replace [AFFILIATE_LINK] with: ${affLink}\nBritish English.`;
  const text=await aiStream([{role:'user',content:prompt}],`Senior WSS reviewer. Never fabricate. Specific failure modes. British English.\n\n${pType==='apparel'?WSS_APPAREL:WSS_NUTRITION}`,document.getElementById('writeOut'),document.getElementById('writeBtn'),'Regenerate');
