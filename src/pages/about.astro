---
import BaseLayout from '../layouts/BaseLayout.astro';
import { team, igIcon } from '../data/team.js';
import { withBase } from '../data/taxonomy.js';

const stats = [
  { num: '80%', label: 'of women have experienced poor product fit' },
  { num: '86%', label: 'more likely to buy a WSS™-certified product' },
  { num: '98%', label: 'want clearer independent standards' },
];

const pillars = [
  { n: '1', name: 'Inclusive Fit & Proportional Sizing' },
  { n: '2', name: 'Functional Performance in Use' },
  { n: '3', name: 'Adequate Support Standards' },
  { n: '4', name: 'Thermal Regulation & Material Performance' },
  { n: '5', name: 'Genuine Female Design' },
  { n: '6', name: 'Diversity & Inclusion in Testing' },
  { n: '7', name: 'Transparency & Independent Verification' },
];

---
<BaseLayout
  title="About Us — Women's Sports Store"
  description="Meet the team behind Women's Sports Store — the UK's first certified women's sports retail destination. Independent reviews tested against the Women's Sports Standard™."
>
  <section class="about-hero">
    <div class="container">
      <span class="wss-badge">WSS™ Independent Reviews</span>
      <h1>About Women's Sports Store</h1>
      <p class="hero-sub">Sports products were never designed for women. We're changing that.</p>
      <p class="hero-body">Women's Sports Store is the UK's first certified women's sports retail destination. Every product we review is independently tested against the Women's Sports Standard™ — seven rigorous pillars that measure what actually matters to active women. No brand bias. No vague praise. Just honest, evidence-based assessments.</p>
    </div>
  </section>

  <section class="about-why">
    <div class="container">
      <h2>Why we exist</h2>
      <div class="stat-grid">
        {stats.map((s) => (
          <div class="stat-card">
            <div class="stat-num">{s.num}</div>
            <p>{s.label}</p>
          </div>
        ))}
      </div>
      <p class="why-body">We built the Women's Sports Standard™ because the sports industry has spent decades designing products for men and shrinking them down for women. Our independent review framework holds brands accountable to real standards — tested by active women, scored transparently, published regardless of commercial relationships.</p>
      <p class="stat-source">Source: WSS consumer survey, n=331.</p>
    </div>
  </section>

  <section class="about-standard">
    <div class="container">
      <h2>The Women's Sports Standard™</h2>
      <p class="standard-intro">Every product is held to the seven pillars of the Women's Sports Standard™. <a href="https://womenssportsstandard.com" target="_blank" rel="noopener noreferrer">Read the full standard →</a></p>
      <ol class="pillar-list">
        {pillars.map((p) => (
          <li class="pillar-item">
            <span class="pillar-dot">{p.n}</span>
            <span class="pillar-name">{p.name}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="about-team" id="team">
    <div class="container">
      <h2>Our review team</h2>
      <p class="team-intro">Every review is written by an active woman who has tested the product in real conditions. Our team combines editorial expertise, specialist clinical knowledge, and first-hand experience of the fit and performance issues women face every day.</p>
      <div class="team-grid">
        {team.map((m) => (
          <article class="reviewer-card">
            <div class="reviewer-avatar">
              <span class="reviewer-initials">{m.initials}</span>
              {m.image && <img class="reviewer-photo" src={withBase(m.image)} alt={m.name} loading="lazy" onerror="this.style.display='none'" />}
            </div>
            <div class="reviewer-role">{m.role}</div>
            <h3 class="reviewer-name"><a href={`/reviewers/${m.slug}/`}>{m.name}</a></h3>
            <p class="reviewer-bio">{m.bio}</p>
            <a class="reviewer-more" href={`/reviewers/${m.slug}/`}>View {m.name.split(' ')[0]}'s reviews →</a>
            <div class="reviewer-tags">
              {m.specialisms.map((s) => <span class="tag">{s}</span>)}
            </div>
            <div class="reviewer-contact">
              <a class="reviewer-ig" href={m.instagram.url} target="_blank" rel="noopener noreferrer"><span class="ig-icon" set:html={igIcon} />{m.instagram.handle}</a>
              {m.email && <a class="reviewer-email" href={`mailto:${m.email}`}>{m.email}</a>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="about-contact">
    <div class="container">
      <h2>Get in touch</h2>
      <p>For review submissions, brand partnerships, or press enquiries, contact us at:</p>
      <p><a class="btn btn-pink contact-btn" href="mailto:mel@womenssportsstore.com">Email us →</a></p>
      <p class="contact-standard"><a href="https://womenssportsstandard.com" target="_blank" rel="noopener noreferrer">womenssportsstandard.com →</a></p>
    </div>
  </section>
</BaseLayout>

<style>
.about-hero { background: #000036; color: #fff; padding: 4rem 0 3.5rem; }
.about-hero .wss-badge { margin-bottom: 1.25rem; }
.about-hero h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1rem; }
.hero-sub { font-size: clamp(1.1rem, 2vw, 1.4rem); color: var(--pink); font-weight: 600; margin-bottom: 1.25rem; max-width: 640px; }
.hero-body { font-size: 1.05rem; line-height: 1.7; color: rgba(255,255,255,.8); max-width: 680px; }

.about-why { background: #f8f8f6; padding: 3.5rem 0; }
.about-why h2 { font-size: 1.75rem; margin-bottom: 1.75rem; }
.stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 2rem; }
.stat-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; }
.stat-num { font-size: 2.75rem; font-weight: 700; color: var(--pink); line-height: 1; margin-bottom: .5rem; }
.stat-card p { font-size: .9rem; color: var(--text-secondary); line-height: 1.5; }
.why-body { font-size: 1rem; line-height: 1.75; color: var(--text-secondary); max-width: 760px; }
.stat-source { font-size: .75rem; color: var(--text-muted); margin-top: .75rem; }

.about-standard { padding: 3.5rem 0; }
.about-standard h2 { font-size: 1.75rem; margin-bottom: .5rem; }
.standard-intro { color: var(--text-secondary); margin-bottom: 1.75rem; }
.standard-intro a { color: var(--pink); font-weight: 600; }
.pillar-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .875rem; max-width: 640px; }
.pillar-item { display: flex; align-items: center; gap: 1rem; }
.pillar-dot { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; background: var(--pink); color: #fff; font-weight: 700; display: flex; align-items: center; justify-content: center; font-size: .95rem; }
.pillar-name { font-size: 1.05rem; font-weight: 600; color: var(--navy); }

.about-team { background: #f8f8f6; padding: 3.5rem 0; }
.about-team h2 { font-size: 1.75rem; margin-bottom: .75rem; }
.team-intro { color: var(--text-secondary); line-height: 1.7; max-width: 760px; margin-bottom: 2rem; }
.team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr)); gap: 1.5rem; }
.reviewer-card { background: #fff; border: 1px solid #eee; border-radius: 10px; padding: 1.5rem; }
.reviewer-avatar { position: relative; width: 80px; height: 80px; border-radius: 50%; overflow: hidden; background: #FF5E84; color: #fff; font-weight: 700; font-size: 1.4rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
.reviewer-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.reviewer-role { color: #FF5E84; font-size: 12px; text-transform: uppercase; letter-spacing: .08em; font-weight: 600; margin-bottom: .35rem; }
.reviewer-name { font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 20px; color: #000036; margin-bottom: .75rem; }
.reviewer-name a { color: inherit; text-decoration: none; }
.reviewer-name a:hover { color: #FF5E84; }
.reviewer-bio { color: #555; font-size: 14px; line-height: 1.7; margin-bottom: 1rem; }
.reviewer-more { display: inline-block; color: #FF5E84; font-size: 13px; font-weight: 600; margin-bottom: 1rem; }
.reviewer-more:hover { text-decoration: underline; }
.reviewer-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1rem; }
.tag { background: #fff0f4; color: #FF5E84; font-size: 12px; border-radius: 20px; padding: 3px 10px; }
.reviewer-contact { display: flex; flex-direction: column; gap: .35rem; }
.reviewer-ig { display: inline-flex; align-items: center; gap: .4rem; color: #FF5E84; font-size: 13px; font-weight: 600; }
.reviewer-ig .ig-icon { display: inline-flex; line-height: 0; }
.reviewer-email { color: #888; font-size: 13px; }

.about-contact { padding: 3.5rem 0; }
.about-contact h2 { font-size: 1.75rem; margin-bottom: .75rem; }
.about-contact p { color: var(--text-secondary); margin-bottom: .5rem; }
.contact-btn { display: inline-block; margin: .25rem 0 .5rem; }
.contact-standard a { color: var(--pink); font-weight: 600; }

@media (max-width: 700px) {
  .stat-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .about-hero { padding: 2.75rem 0 2.5rem; }
  .about-why, .about-standard, .about-team, .about-contact { padding: 2.5rem 0; }
}
</style>
