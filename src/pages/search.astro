---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCard from '../components/ReviewCard.astro';

const reviews = import.meta.glob('./reviews/*/*.md', { eager: true });
const index = Object.entries(reviews)
  .map(([path, mod]: [string, any]) => {
    const parts = path.split('/');
    const slug = parts.pop()!.replace('.md', '');
    const category = parts.pop()!;
    const fm = mod.frontmatter;
    const text = [fm.title, fm.brand, category.replace('-', ' '), fm.product_type, fm.excerpt, fm.tested_by]
      .filter(Boolean).join(' ').toLowerCase();
    return { title: fm.title, brand: fm.brand, category, slug, score: fm.overall_score, excerpt: fm.excerpt, image: fm.hero_image || '', date: fm.date, text };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---
<BaseLayout title="Search Reviews" description="Search every Women's Sports Store review tested against the Women's Sports Standard™.">
  <section class="search-hero">
    <div class="container">
      <h1>Search reviews</h1>
      <p>Find a product, brand or category — every review tested against the WSS™ framework.</p>
      <div class="search-box">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 4.99L20.49 19l-4.99-5Zm-6 0A4.5 4.5 0 1 1 14 9.5 4.49 4.49 0 0 1 9.5 14Z"/></svg>
        <input id="searchInput" type="search" placeholder="Search by product, brand or category…" autocomplete="off" aria-label="Search reviews" />
      </div>
      <p id="searchCount" class="search-count"></p>
    </div>
  </section>

  <section class="container search-results-wrap">
    <div class="reviews-grid" id="searchResults">
      {index.map((r) => (
        <div class="search-item" data-search={r.text}>
          <ReviewCard title={r.title} brand={r.brand} slug={r.slug} category={r.category} score={r.score} excerpt={r.excerpt} image={r.image} date={r.date} />
        </div>
      ))}
    </div>
    <div id="noResults" class="no-results" style="display:none">
      <p>No reviews match your search.</p>
      <p class="no-results-sub">Try a brand, product type, or a category like “run” or “sports bras”.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('searchInput') as HTMLInputElement;
  const items = Array.from(document.querySelectorAll<HTMLElement>('.search-item'));
  const count = document.getElementById('searchCount')!;
  const noRes = document.getElementById('noResults')!;

  function apply(q: string) {
    const terms = (q || '').trim().toLowerCase().split(/\s+/).filter(Boolean);
    let n = 0;
    for (const it of items) {
      const hay = it.dataset.search || '';
      const match = terms.length === 0 || terms.every((t) => hay.includes(t));
      it.style.display = match ? '' : 'none';
      if (match) n++;
    }
    count.textContent = terms.length ? `${n} result${n !== 1 ? 's' : ''} for “${q.trim()}”` : `${items.length} review${items.length !== 1 ? 's' : ''}`;
    noRes.style.display = n ? 'none' : 'block';
  }

  const q0 = new URLSearchParams(location.search).get('q') || '';
  input.value = q0;
  apply(q0);
  input.focus();

  input.addEventListener('input', () => {
    apply(input.value);
    const u = new URL(location.href);
    if (input.value) u.searchParams.set('q', input.value);
    else u.searchParams.delete('q');
    history.replaceState({}, '', u);
  });
</script>

<style>
.search-hero { background: var(--navy); color: white; padding: 3rem 0 2.5rem; }
.search-hero h1 { color: white; font-size: clamp(1.75rem, 3vw, 2.5rem); margin-bottom: .5rem; }
.search-hero p { opacity: .75; margin-bottom: 1.5rem; max-width: 560px; }
.search-box { display: flex; align-items: center; gap: .6rem; background: white; border-radius: 999px; padding: .25rem .25rem .25rem 1rem; max-width: 560px; box-shadow: var(--shadow-md); }
.search-box svg { color: var(--text-muted); flex-shrink: 0; }
.search-box input { flex: 1; border: none; outline: none; font-size: 1rem; padding: .75rem .5rem; color: var(--text-primary); background: transparent; }
.search-count { margin: 1rem 0 0; font-size: .8rem; opacity: .7; }
.search-results-wrap { padding-top: 2rem; padding-bottom: 3rem; }
.reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr)); gap: 1.5rem; }
.search-item { display: contents; }
.no-results { text-align: center; padding: 3rem 1rem; color: var(--text-secondary); }
.no-results-sub { font-size: .875rem; color: var(--text-muted); margin-top: .375rem; }
</style>
