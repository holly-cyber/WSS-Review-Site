async function scrapeProduct(url,type){
  // 1) Try Shopify product JSON (CORS-friendly, real data)
  try{
    const base=url.split('?')[0].split('#')[0].replace(/\/$/,'');
    const r=await fetch(base+'.json',{headers:{Accept:'application/json'}});
    if(r.ok){
      const d=await r.json();
      if(d.product){
        const p=d.product;
        const sizeOpt=(p.options||[]).find(o=>/size|uk|us|eu/i.test(o.name));
        return {
          name:p.title||'',
          brand:p.vendor||'',
          price:(p.variants&&p.variants[0]&&p.variants[0].price)?String(p.variants[0].price):'',
          sizes:sizeOpt?sizeOpt.values.join(', '):'',
          specs:stripHtml(p.body_html).slice(0,600),
          images:(p.images||[]).slice(0,12).map(im=>({url:im.src,type:'product',alt:p.title||'Product image'}))
        };
      }
    }
  }catch{}
  // 2) Fall back to ai-proxy extraction from the URL/slug
  const specHint={apparel:'size range, fabric, support level, fit',nutrition:'flavour, macros per serving, ingredients, serving size',footwear:'last/fit, heel-to-toe drop, weight, terrain, size range',technology:'sensors, battery life, connectivity, compatible apps, metrics tracked',equipment:'dimensions/sizing, materials, safety certifications, weight, adjustability'}[type]||'key specifications';
  const raw=await aiCall([{role:'user',content:`Extract product details for a women's ${type} review from this URL.\nURL: ${url}\nInfer brand and product name from the domain and slug, and your knowledge of the product if you recognise it. For "specs", focus on: ${specHint}.\nReturn ONLY this JSON (no prose): {"name":"","brand":"","price":"","sizes":"","specs":""}\nUse "" for anything you cannot determine. Never invent a price.`}],'Product data extractor for WSS. Return only valid JSON. Never fabricate prices or specs.',800);
  const obj=JSON.parse(cleanJson(raw));
  obj.images=[];
  return obj;
}

