  return `<div class="nw-lib-row" data-path="${esc(f.path)}"><div><div class="nw-lib-title">${esc(f.title||f.slug)}</div><div class="nw-lib-meta">${esc(f.author||'—')}${d?' · '+d:''} · ${esc(f.slug)}</div></div><div class="nw-lib-acts"><button class="bg" data-act="edit">Edit</button><button class="bg" data-act="preview">Preview</button><button class="bg" data-act="toggle">${f.draft?'Publish':'Unpublish'}</button><button class="bg bdanger" data-act="delete">Delete</button></div></div>`;
}
