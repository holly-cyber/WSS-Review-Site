---
import BaseLayout from './BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import ReviewCard from '../components/ReviewCard.astro';
import { findReviewer } from '../data/team.js';
import { slugify } from '../data/taxonomy.js';

const { frontmatter: fm } = Astro.props;
const category = fm.category || 'run';

// Other reviews in the same category (excluding the one being viewed).
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).pop();
const reviewMods = import.meta.glob('../pages/reviews/*/*.md', { eager: true });
const relatedReviews = Object.entries(reviewMods)
  .map(([p, m]: [string, any]) => {
    const parts = p.split('/');
    const slug = parts[parts.length - 1].replace('.md', '');
    const _cat = parts[parts.length - 2];
    return { ...(m.frontmatter || {}), slug, _cat };
  })
  .filter((r) => (r.category || r._cat) === category && r.slug !== currentSlug)
  .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime())
  .slice(0, 3);

// Clickable category trail (category › subcategory › sub-subcategory).
const subSlug = fm.subcategory ? slugify(fm.subcategory) : '';
const subsubSlug = fm.subsubcategory ? slugify(fm.subsubcategory) : '';

// Link the byline / reviewer box to the reviewer's own page when we can match.
const reviewer = findReviewer(fm.tested_by);
const bylineAvatar = fm.reviewer_avatar || reviewer?.image;

// Buy CTA buttons. Shopify = primary (nofollow); affiliate = secondary (nofollow sponsored).
const shopLink = fm.shopify_link || '';
const affLink = fm.affiliate_link || '';
const prodLink = fm.product_url || '';
const brandName = fm.brand || 'the brand';
const priceLabel = fm.price ? ` — £${fm.price}` : '';
const buyButtons: any[] = [];
if (shopLink) buyButtons.push({ href: shopLink, rel: 'nofollow', text: `Buy from WSS store${priceLabel} →`, primary: true });
if (affLink) buyButtons.push({ href: affLink, rel: 'nofollow sponsored', text: shopLink ? `Buy direct from ${brandName} →` : `Buy direct from ${brandName}${priceLabel} →`, primary: !shopLink });
if (!buyButtons.length && prodLink) buyButtons.push({ href: prodLink, rel: 'nofollow', text: `Buy now${priceLabel} →`, primary: true });

function starHtml(score: number) {
  const pct = Math.max(0, Math.min(100, (Number(score) / 5) * 100));
  return `<span class="stars-wrap"><span class="stars-bg">★★★★★</span><span class="stars-fg" style="width:${pct}%">★★★★★</span></span>`;
}

const pillars = fm.pillar_scores || {};
const criteriaLabels: Record<string, string> = {
  p1: 'Inclusive Fit & Sizing',
  p2: 'Functional Performance',
  p3: 'Support Standards',
  p4: 'Thermal Regulation & Materials',
  p5: 'Female Design',
  p7: 'Transparency',
  taste: 'Taste & Texture (25%)',
  nutrition: 'Nutrition Profile (30%)',
  performance: 'Performance (30%)',
  value: 'Value (15%)',
  f1: 'Female-Specific Last',
  f2: 'Functional Performance',
  f3: 'Fit Accuracy & Size',
  f4: 'Female Biomechanics',
  f5: 'Transparency',
  t1: 'Female Data & Metrics',
  t2: 'Hardware Fit',
  t3: 'Functional Accuracy',
  t4: 'Software & App',
  t5: 'Transparency',
  e1: 'Female-Specific Design',
  e2: 'Functional Performance',
  e3: 'Fit & Adjustability',
  e4: 'Safety & Standards',
  e5: 'Transparency',
};

const authorNode = fm.tested_by
  ? { "@type": "Person", "name": String(fm.tested_by).split(',')[0].trim() }
  : { "@type": "Organization", "name": "Women's Sports Store" };

const reviewNode = {
  "@type": "Review",
  "name": `${fm.brand} ${fm.title} Review`.trim(),
  "reviewBody": fm.excerpt,
  "reviewRating": { "@type": "Rating", "ratingValue": fm.overall_score, "bestRating": "5", "worstRating": "1" },
  "author": authorNode,
  "publisher": { "@type": "Organization", "name": "Women's Sports Store" },
  "datePublished": fm.date,
};

const schemaReview = JSON.stringify({
  "@context": "https://schema.org",
  ...reviewNode,
  "itemReviewed": { "@type": "Product", "name": fm.title, "brand": { "@type": "Brand", "name": fm.brand } },
});

const schemaProduct = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": fm.title,
  "brand": { "@type": "Brand", "name": fm.brand },
  ...(fm.hero_image ? { "image": fm.hero_image } : {}),
  "review": reviewNode,
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": fm.overall_score, "bestRating": "5", "worstRating": "1", "reviewCount": 1 },
  ...(fm.price ? { "offers": { "@type": "Offer", "price": String(fm.price).replace(/[^\d.]/g, ''), "priceCurrency": "GBP", "availability": "https://schema.org/InStock", ...(fm.affiliate_link ? { "url": fm.affiliate_link } : {}) } } : {}),
});

const faqItems = Array.isArray(fm.faq) ? fm.faq.filter((f: any) => f && f.q && f.a) : [];
const schemaFaq = faqItems.length ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((f: any) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
}) : null;
---
<BaseLayout title={`${fm.title} Review`} description={fm.meta_description || fm.excerpt} ogImage={fm.hero_image}>
  <script type="application/ld+json" set:html={schemaReview} />
  <script type="application/ld+json" set:html={schemaProduct} />
  {schemaFaq && <script type="application/ld+json" set:html={schemaFaq} />}

  <div class="review-hero" style={fm.hero_image ? `background-image:url(${fm.hero_image})` : ''}>
    <div class="container">
      <div class="breadcrumb">
        <a href="/reviews/">Reviews</a> / <a href={`/reviews/${category}/`}>{category.replace('-',' ')}</a> / <span>{fm.brand}</span>
      </div>
      <div class="rv-cats">
        <a class="rv-cat" href={`/reviews/${category}/`}>{category.replace('-',' ')}</a>
        {subSlug && <span class="rv-cat-sep">›</span>}
        {subSlug && <a class="rv-cat" href={`/reviews/${category}/${subSlug}/`}>{fm.subcategory}</a>}
        {subsubSlug && <span class="rv-cat-sep">›</span>}
        {subsubSlug && <a class="rv-cat" href={`/reviews/${category}/${subSlug}/${subsubSlug}/`}>{fm.subsubcategory}</a>}
      </div>
      <h1>{fm.title}</h1>
      <p class="review-brand">by <strong>{fm.brand}</strong>{fm.price ? ` · £${fm.price}` : ''}</p>
      <div class="hero-score">
        <span class="stars big-stars" aria-label={`${fm.overall_score} out of 5`} set:html={starHtml(fm.overall_score)} />
        <span class="overall-num">{fm.overall_score}/5</span>
        <span class="wss-badge">WSS™ Reviewed</span>
      </div>
      {fm.tested_by && (
        <div class="hero-byline">
          {bylineAvatar && (reviewer
            ? <a href={`/reviewers/${reviewer.slug}/`}><img class="hero-byline-img" src={bylineAvatar} alt={reviewer.name} loading="lazy" /></a>
            : <img class="hero-byline-img" src={bylineAvatar} alt={fm.tested_by} loading="lazy" />)}
          <span class="hero-byline-text">Reviewed by {reviewer
            ? <a class="hero-byline-link" href={`/reviewers/${reviewer.slug}/`}><strong>{fm.tested_by}</strong></a>
            : <strong>{fm.tested_by}</strong>}</span>
        </div>
      )}
    </div>
  </div>

  <div class="review-layout container">
    <aside class="review-sidebar">
      <div class="score-card">
        <div class="score-overall">
          <div class="score-big">{fm.overall_score}</div>
          <div class="score-label">Overall WSS™ Score</div>
          <div class="stars" aria-label={`${fm.overall_score} out of 5`} set:html={starHtml(fm.overall_score)} />
        </div>
        <div class="score-breakdown">
          {Object.entries(pillars).map(([key, val]) => (
            <div class="score-row">
              <div class="score-row-label">{criteriaLabels[key] || key}</div>
              <div class="score-row-right">
                <div class="score-bar-wrap"><div class="score-bar" style={`width:${(Number(val)/5)*100}%`}></div></div>
                <span class="score-row-val">{val}/5</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      {buyButtons.map((b) => <a href={b.href} class={`btn ${b.primary ? 'btn-pink' : 'btn-navy'} buy-btn`} target="_blank" rel={b.rel}>{b.text}</a>)}
      <div class="quick-facts">
        <h4>Quick facts</h4>
        {fm.product_type && <div class="fact"><span>Type</span><span>{fm.product_type}</span></div>}
        {fm.price && <div class="fact"><span>Price</span><span>£{fm.price}</span></div>}
        {fm.sizes && <div class="fact"><span>Sizes</span><span>{fm.sizes}</span></div>}
        {fm.tested_by && <div class="fact"><span>Tested by</span><span>{reviewer
          ? <a class="fact-link" href={`/reviewers/${reviewer.slug}/`}>{reviewer.name}</a>
          : fm.tested_by}</span></div>}
        {fm.date && <div class="fact"><span>Reviewed</span><span>{new Date(fm.date).toLocaleDateString('en-GB',{month:'long',year:'numeric'})}</span></div>}
      </div>
    </aside>
    <article class="review-content">
      <slot />
      {buyButtons.length > 0 && (
        <div class="rv-cta">
          {buyButtons.map((b) => <a class={`rv-buy${b.primary ? '' : ' alt'}`} href={b.href} target="_blank" rel={b.rel}>{b.text}</a>)}
        </div>
      )}
      {(fm.tested_by || fm.reviewer_bio || reviewer) && (
        <div class="rv-reviewer">
          {bylineAvatar && (reviewer
            ? <a href={`/reviewers/${reviewer.slug}/`}><img class="rv-reviewer-img" src={bylineAvatar} alt={reviewer.name} loading="lazy" /></a>
            : <img class="rv-reviewer-img" src={bylineAvatar} alt={fm.tested_by || 'Reviewer'} loading="lazy" />)}
          <div class="rv-reviewer-body">
            <div class="rv-reviewer-label">About the reviewer</div>
            {fm.tested_by && <div class="rv-reviewer-name">{reviewer
              ? <a href={`/reviewers/${reviewer.slug}/`}>{fm.tested_by}</a>
              : fm.tested_by}</div>}
            {(fm.reviewer_bio || reviewer?.bio) && <p class="rv-reviewer-bio">{fm.reviewer_bio || reviewer.bio}</p>}
            {reviewer && <a class="rv-reviewer-link" href={`/reviewers/${reviewer.slug}/`}>View all reviews by {reviewer.name.split(' ')[0]} →</a>}
          </div>
        </div>
      )}
    </article>
  </div>

  {relatedReviews.length > 0 && (
    <section class="more-reviews container">
      <div class="more-reviews-head">
        <h2>More {category.replace('-', ' ')} reviews</h2>
        <div class="more-reviews-tools">
          <a class="more-reviews-all" href={`/reviews/${category}/`}>View all →</a>
          {relatedReviews.length > 1 && (
            <div class="carousel-nav">
              <button class="carousel-btn" type="button" data-dir="-1" aria-label="Scroll reviews left">‹</button>
              <button class="carousel-btn" type="button" data-dir="1" aria-label="Scroll reviews right">›</button>
            </div>
          )}
        </div>
      </div>
      <div class="more-reviews-track" id="moreReviewsTrack">
        {relatedReviews.map((r: any) => (
          <ReviewCard title={r.title} brand={r.brand} slug={r.slug} category={r.category || r._cat} score={r.overall_score} excerpt={r.excerpt} image={r.hero_image} date={r.date} />
        ))}
      </div>
    </section>
  )}

  <EmailSignup />
</BaseLayout>

<script>
  // Label each comparison-table cell with its column header so the mobile
  // stacked-card layout can show "Header: value". Works for every review.
  document.querySelectorAll('.review-content table').forEach((table) => {
    const heads = Array.from(table.querySelectorAll('thead th')).map((th) => (th.textContent || '').trim());
    if (!heads.length) return;
    table.querySelectorAll('tbody tr').forEach((tr) => {
      Array.from(tr.children).forEach((td, i) => {
        if (heads[i]) td.setAttribute('data-label', heads[i]);
      });
    });
  });

  // "More reviews" carousel: scroll one card-width per arrow click.
  const moreTrack = document.getElementById('moreReviewsTrack');
  if (moreTrack) {
    document.querySelectorAll('.more-reviews .carousel-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = Number(btn.getAttribute('data-dir')) || 1;
        moreTrack.scrollBy({ left: dir * Math.min(moreTrack.clientWidth * 0.85, 360), behavior: 'smooth' });
      });
    });
  }
</script>

<style>
.review-hero{background:var(--navy);color:white;padding:2.5rem 0;background-size:cover;background-position:center;position:relative}
.review-hero::before{content:'';position:absolute;inset:0;background:rgba(0,0,30,.75)}
.review-hero .container{position:relative}
.breadcrumb{font-size:.75rem;opacity:.6;margin-bottom:1rem}
.breadcrumb a{opacity:.8}
.rv-cats{display:flex;align-items:center;flex-wrap:wrap;gap:.4rem;margin-bottom:1rem}
.rv-cat{display:inline-block;padding:.25rem .8rem;border-radius:20px;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;background:rgba(255,255,255,.14);color:#fff;text-decoration:none;transition:background .15s}
.rv-cat:hover{background:var(--pink)}
.rv-cat-sep{color:rgba(255,255,255,.5);font-size:.95rem;line-height:1}
.review-hero h1{font-size:clamp(1.5rem,3vw,2.5rem);color:white;margin-bottom:.4rem}
.review-brand{font-size:.9rem;opacity:.7;margin-bottom:1rem}
.hero-score{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
.big-stars{font-size:1.5rem}
:global(.stars-wrap){position:relative;display:inline-block;white-space:nowrap;line-height:1;letter-spacing:.05em}
:global(.stars-bg){color:#e6e6e6}
:global(.stars-fg){position:absolute;top:0;left:0;overflow:hidden;color:var(--pink);width:0}
.review-hero :global(.stars-bg){color:rgba(255,255,255,.4)}
.overall-num{font-size:1.25rem;font-weight:700;color:white}
.hero-byline{display:flex;align-items:center;gap:.6rem;margin-top:1rem}
.hero-byline-img{width:40px;height:40px;border-radius:50%;object-fit:cover;border:2px solid var(--pink);flex-shrink:0}
.hero-byline>a{flex-shrink:0;display:block;line-height:0;width:40px;height:40px}
.hero-byline-text{font-size:.85rem;color:rgba(255,255,255,.85)}
.hero-byline-text strong{color:#fff}
.hero-byline-link{color:#fff}
.hero-byline-link:hover strong{color:var(--pink)}
.hero-byline-img{display:block}
.review-layout{display:grid;grid-template-columns:300px 1fr;gap:2.5rem;padding-top:2.5rem;padding-bottom:3rem;align-items:start}
.review-sidebar{position:sticky;top:80px;min-width:0}
.score-card{background:white;border:1px solid var(--border);border-radius:var(--radius-md);padding:1.5rem;margin-bottom:1rem;box-shadow:var(--shadow-sm)}
.score-overall{text-align:center;padding-bottom:1.25rem;border-bottom:1px solid var(--border);margin-bottom:1.25rem}
.score-big{font-size:3.5rem;font-weight:700;color:var(--pink);line-height:1}
.score-label{font-size:.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.5rem}
.score-overall .stars{color:var(--pink);font-size:1.25rem}
.score-breakdown{display:flex;flex-direction:column;gap:.75rem}
.score-row{display:flex;flex-direction:column;gap:.25rem}
.score-row-label{font-size:.7rem;color:var(--text-secondary);font-weight:600}
.score-row-right{display:flex;align-items:center;gap:.5rem}
.score-bar-wrap{flex:1;height:9px;background:var(--border);border-radius:5px;overflow:hidden}
.score-bar{height:100%;background:var(--pink);border-radius:5px}
.score-row-val{font-size:1rem;font-weight:700;color:var(--pink);min-width:38px;text-align:right;font-variant-numeric:tabular-nums}
.buy-btn{width:100%;justify-content:center;margin-bottom:.625rem}
.quick-facts{background:var(--off-white);border-radius:var(--radius-md);padding:1.25rem;margin-top:1rem}
.quick-facts h4{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:.875rem}
.fact{display:flex;justify-content:space-between;font-size:.8rem;padding:.375rem 0;border-bottom:1px solid var(--border)}
.fact:last-child{border-bottom:none}
.fact span:first-child{color:var(--text-muted)}
.fact span:last-child{font-weight:600;color:var(--navy);text-align:right;max-width:55%}
.fact-link{color:var(--pink);text-decoration:none}
.fact-link:hover{text-decoration:underline}
.review-content{font-size:1rem;line-height:1.75;min-width:0}
.review-content :global(h2){font-size:1.4rem;color:var(--navy);margin:1.7rem 0 .55rem}
.review-content :global(h3){font-size:1.1rem;color:var(--navy);margin:1.1rem 0 .4rem}
.review-content :global(p){margin:0 0 .85rem;color:var(--text-secondary)}
.review-content :global(h2+p),.review-content :global(h3+p){margin-top:0}
.review-content :global(strong){color:var(--text-primary)}
/* In-content links (incl. affiliate links Avelon converts) — make them clearly clickable. */
.review-content :global(p a),.review-content :global(li a),.review-content :global(td a){color:var(--pink);text-decoration:underline;text-underline-offset:2px;font-weight:600}
.review-content :global(p a:hover),.review-content :global(li a:hover),.review-content :global(td a:hover){color:#e04470}
.review-content :global(p a strong),.review-content :global(li a strong),.review-content :global(td a strong){color:inherit}
.review-content :global(ul),.review-content :global(ol){margin:0 0 1rem 1.25rem;color:var(--text-secondary)}
.review-content :global(li){margin-bottom:.375rem}
.review-content :global(img){border-radius:var(--radius-md);margin:1.5rem 0;width:100%}
.review-content :global(blockquote){border-left:3px solid var(--pink);padding:.75rem 1.25rem;background:var(--light-pink);border-radius:0 var(--radius-sm) var(--radius-sm) 0;margin:1.25rem 0;font-style:italic;color:var(--text-secondary)}
.review-content :global(.wss-score){display:inline-flex;align-items:center;gap:.6rem;margin:.1rem 0 .9rem;vertical-align:middle}
.review-content :global(.wss-score-num){display:inline-flex;align-items:center;justify-content:center;width:2.4rem;height:2.4rem;border-radius:50%;background:var(--pink);color:#fff;font-weight:700;font-size:1.15rem;line-height:1;flex-shrink:0}
.review-content :global(.wss-score-stars){color:var(--pink);font-size:1.2rem;letter-spacing:.08em;line-height:1}
.review-content :global(.wss-score-stars .off){color:#dcdcdc}
.review-content :global(.table-wrap){overflow-x:auto;margin:1.5rem 0}
.review-content :global(table){width:100%;border-collapse:collapse;font-size:.9rem;background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);overflow:hidden}
.review-content :global(thead){background:var(--navy)}
.review-content :global(th){color:#fff;text-align:left;padding:.75rem .875rem;font-weight:600;font-size:.8rem;text-transform:uppercase;letter-spacing:.02em;white-space:normal;overflow-wrap:break-word}
.review-content :global(td){padding:.75rem .875rem;border-top:1px solid var(--border);color:var(--text-secondary);vertical-align:top;overflow-wrap:anywhere}
.review-content :global(tbody tr:nth-child(odd)){background:var(--off-white)}
.review-content :global(tbody tr:first-child){background:var(--light-pink)}
.review-content :global(tbody tr:first-child td){font-weight:600;color:var(--text-primary)}
.rv-cta{display:flex;gap:.75rem;flex-wrap:wrap;margin:2rem 0 1.5rem}
.rv-buy{display:inline-flex;align-items:center;justify-content:center;background:var(--pink);color:#fff;font-weight:700;padding:.85rem 1.6rem;border-radius:8px;font-size:1rem;text-decoration:none;transition:background .15s}
.review-content :global(.rv-buy),.review-content :global(.rv-buy):hover{color:#fff}
.rv-buy:hover{background:#e04470}
.rv-buy.alt{background:var(--navy)}
.rv-buy.alt:hover{background:#000060}
.rv-reviewer{display:flex;gap:1rem;align-items:flex-start;background:var(--off-white);border:1px solid var(--border);border-radius:var(--radius-md);padding:1.25rem;margin:1.5rem 0 .5rem}
.rv-reviewer>a{flex-shrink:0;display:block;line-height:0;width:64px;height:64px}
.rv-reviewer img.rv-reviewer-img{width:64px;height:64px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--pink);margin:0;display:block}
.rv-reviewer-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:.2rem}
.rv-reviewer-name{font-weight:700;color:var(--navy)}
.rv-reviewer-name a{color:var(--navy);text-decoration:none}
.rv-reviewer-name a:hover{color:var(--pink)}
.rv-reviewer-bio{font-size:.9rem;color:var(--text-secondary);margin:.35rem 0 0;line-height:1.55}
.rv-reviewer-link{display:inline-block;margin-top:.6rem;font-size:.85rem;font-weight:600;color:var(--pink)}
.rv-reviewer-link:hover{text-decoration:underline}
.review-content :global(.pros-cons){display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.25rem 0}
.review-content :global(.pc-col){border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem 1.1rem;background:var(--off-white)}
.review-content :global(.pc-pros){border-top:4px solid #bde1c9}
.review-content :global(.pc-cons){border-top:4px solid var(--pink)}
.review-content :global(.pc-h){font-weight:700;color:var(--navy);margin-bottom:.6rem;font-size:.95rem}
.review-content :global(.pros-cons ul){list-style:none;margin:0;padding:0}
.review-content :global(.pros-cons li){position:relative;padding-left:1.7rem;margin-bottom:.5rem;font-size:.9rem;line-height:1.5;color:var(--text-secondary)}
.review-content :global(.pc-pros li::before){content:'✓';position:absolute;left:0;top:-1px;color:#2e9e5b;font-weight:800}
.review-content :global(.pc-cons li::before){content:'✗';position:absolute;left:0;top:-1px;color:var(--pink);font-weight:800}
.review-content :global(.pc-buy){margin:1rem 0 .25rem;font-weight:600;font-size:.95rem}
.review-content :global(.pc-buy a){color:var(--pink);text-decoration:underline}
.more-reviews{padding-bottom:3.5rem}
.more-reviews-head{display:flex;align-items:center;justify-content:space-between;gap:1rem;border-bottom:2px solid var(--pink);padding-bottom:.5rem;margin-bottom:1.5rem}
.more-reviews-head h2{font-size:1.4rem;color:var(--navy);text-transform:capitalize}
.more-reviews-tools{display:flex;align-items:center;gap:1rem;flex-shrink:0}
.more-reviews-all{font-size:.8rem;font-weight:600;color:var(--pink);white-space:nowrap}
.more-reviews-all:hover{text-decoration:underline}
.carousel-nav{display:flex;gap:.5rem;flex-shrink:0}
.carousel-btn{width:38px;height:38px;border-radius:50%;border:1px solid var(--border);background:#fff;color:var(--navy);font-size:1.4rem;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.carousel-btn:hover{background:var(--pink);color:#fff;border-color:var(--pink)}
.more-reviews-track{display:flex;gap:1.5rem;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:.75rem;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.more-reviews-track::-webkit-scrollbar{height:6px}
.more-reviews-track::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.more-reviews-track>:global(.review-card){flex:0 0 320px;max-width:320px;scroll-snap-align:start}
@media(max-width:480px){.more-reviews-track>:global(.review-card){flex-basis:85%;max-width:85%}}
@media(max-width:900px){.review-layout{grid-template-columns:1fr}.review-sidebar{position:static}}
@media(max-width:600px){
  .review-content :global(.pros-cons){grid-template-columns:1fr}
  .review-layout{gap:1.5rem;padding-top:1.75rem}
  .rv-cta{flex-direction:column;gap:.6rem}
  .rv-buy{width:100%}
  /* Comparison table -> stacked cards (each product a card, cells labelled). */
  .review-content :global(table){display:block;border:none;border-radius:0;background:transparent;font-size:.92rem}
  .review-content :global(thead){display:none}
  .review-content :global(tbody){display:block}
  .review-content :global(tbody tr){display:block;border:1px solid var(--border);border-radius:var(--radius-md);background:var(--white);padding:.85rem 1rem;margin-bottom:1rem}
  .review-content :global(tbody tr:nth-child(odd)){background:var(--white)}
  .review-content :global(tbody tr:first-child){background:var(--light-pink);border-color:#ffd5e1}
  .review-content :global(td){display:flex;justify-content:space-between;gap:1rem;padding:.5rem 0;border-top:1px solid var(--border);text-align:right;overflow-wrap:anywhere}
  .review-content :global(td::before){content:attr(data-label);flex:0 0 40%;text-align:left;font-weight:700;color:var(--navy);text-transform:uppercase;font-size:.66rem;letter-spacing:.03em;line-height:1.5}
  .review-content :global(tr td:first-child){display:block;text-align:left;border-top:none;font-weight:700;font-size:1.02rem;color:var(--navy);padding:0 0 .55rem;margin-bottom:.45rem;border-bottom:2px solid var(--pink)}
  .review-content :global(tr td:first-child::before){display:none}
  .review-content :global(tbody tr:first-child td){font-weight:600}
}
</style>
