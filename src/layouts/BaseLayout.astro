---
import { taxonomy, slugify, withBase } from '../data/taxonomy.js';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}
const { title, description = "Women's Sports Store — Independent product reviews tested against the Women's Sports Standard™.", ogImage, noindex } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;

// Umami — privacy-first, cookieless analytics. Activates only when both env
// vars are set, so the site stays clean until configured:
//   PUBLIC_UMAMI_SRC         = https://cloud.umami.is/script.js  (bare URL)
//                              OR the full <script ...></script> snippet Umami
//                              gives you — either is accepted.
//   PUBLIC_UMAMI_WEBSITE_ID  = <website uuid from the Umami dashboard>
const rawUmamiSrc = (import.meta.env.PUBLIC_UMAMI_SRC || '').trim();
const rawUmamiId = (import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || '').trim();
// Tolerate pasting the whole embed snippet: pull the src URL / id out of it.
const umamiSrc = (rawUmamiSrc.match(/src=["']([^"']+)["']/)?.[1] || rawUmamiSrc);
const umamiId = rawUmamiId || (rawUmamiSrc.match(/data-website-id=["']([^"']+)["']/)?.[1] || '');

// Latest review per category (for the mega-menu featured card) + which sub /
// sub-sub categories actually have reviews (only those are shown in nav).
// Reviews now live at src/pages/<category>/<slug>.md (flattened for the /reviews
// base path). Glob every top-level folder and keep only real taxonomy categories
// so sibling content like news/ is never treated as a review.
const reviewMods = import.meta.glob('../pages/*/*.md', { eager: true });
const CAT_SLUGS = new Set(taxonomy.map((t: any) => t.slug));
const latestByCat: Record<string, any> = {};
const subWithReviews = new Set<string>();
const subsubWithReviews = new Set<string>();
for (const [path, mod] of Object.entries(reviewMods)) {
  const fm = (mod as any).frontmatter || {};
  const parts = path.split('/');
  if (!CAT_SLUGS.has(parts[parts.length - 2])) continue;
  // Hide draft reviews in production; show them in dev.
  if (import.meta.env.PROD && fm.draft === true) continue;
  const cat = fm.category || parts[parts.length - 2];
  const slug = parts[parts.length - 1].replace('.md', '');
  const entry = { title: fm.title, brand: fm.brand, slug, cat, score: fm.overall_score, image: fm.hero_image, date: fm.date };
  if (!latestByCat[cat] || new Date(entry.date).getTime() > new Date(latestByCat[cat].date).getTime()) latestByCat[cat] = entry;
  if (fm.subcategory) subWithReviews.add(`${cat}/${slugify(fm.subcategory)}`);
  if (fm.subcategory && fm.subsubcategory) subsubWithReviews.add(`${cat}/${slugify(fm.subcategory)}/${slugify(fm.subsubcategory)}`);
}
const isActive = (slug: string) => currentPath === `/${slug}/` || currentPath.startsWith(`/${slug}/`);
const visibleSubs = (cat: any) => cat.subs.filter((s: any) => subWithReviews.has(`${cat.slug}/${slugify(s.name)}`));
const visibleItems = (catSlug: string, sub: any) => sub.items.filter((it: string) => subsubWithReviews.has(`${catSlug}/${slugify(sub.name)}/${slugify(it)}`));
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Women's Sports Store</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex" />}
  <meta property="og:title" content={`${title} | Women's Sports Store`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={new URL(withBase(ogImage), Astro.site)} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=4" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=4" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=4" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <!-- Netlify Identity: loaded site-wide so invite / recovery links (which land
       on the public site root) are handled. Public pages stay fully public. -->
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/pipeline/";
          });
        }
      });
    }
  </script>
  {umamiSrc && umamiId && (
    <script is:inline defer src={umamiSrc} data-website-id={umamiId}></script>
  )}
  {umamiSrc && umamiId && (
    <script is:inline>
      // Reliable "review-open" tracking. Same-tab navigations unload the page
      // before Umami's auto data-umami-event request is sent, so the event is
      // lost (buy buttons work only because they open a new tab). Here we send
      // the event first, then navigate — with a short fallback so the click
      // always proceeds even if tracking is slow or blocked.
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[data-open-review]');
        if (!a) return;
        // Let modified clicks / new-tab / non-primary buttons behave normally.
        if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (a.target === '_blank' || !a.href) return;
        var data = {
          review: a.getAttribute('data-open-review'),
          category: a.getAttribute('data-open-category'),
          brand: a.getAttribute('data-open-brand'),
          from: a.getAttribute('data-open-from')
        };
        if (!window.umami || typeof window.umami.track !== 'function') return; // navigate normally
        e.preventDefault();
        var href = a.href, done = false;
        function go() { if (!done) { done = true; window.location.href = href; } }
        try {
          var r = window.umami.track('review-open', data);
          if (r && typeof r.then === 'function') r.then(go, go);
        } catch (err) {}
        setTimeout(go, 300);
      });
    </script>
  )}
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="drawer">
        <span></span><span></span><span></span>
      </button>
      <a href="/" class="logo" aria-label="Women's Sports Store — reviews home">
        <img src="/logo.svg" alt="Women's Sports Store" class="logo-img" width="48" height="48" />
        <span class="logo-wordmark">WomensSportsStore.com</span>
      </a>
      <a href="https://womenssportsstore.com" class="back-to-shop" aria-label="Back to the Women's Sports Store shop">← Back to shop</a>

      <nav class="mega-nav" aria-label="Primary">
        {taxonomy.map((cat) => (
          <div class="mega-item">
            <a class:list={["mega-trigger", isActive(cat.slug) && "active"]} href={`/${cat.slug}/`} aria-haspopup="true" aria-expanded="false">{cat.name}</a>
            <div class="mega-panel" role="region" aria-label={`${cat.name} categories`}>
              <div class="container mega-panel-inner">
                <div class="mega-left">
                  <div class="mega-head">{cat.name}</div>
                  {visibleSubs(cat).length > 0 ? (
                    <div class="mega-subs">
                      {visibleSubs(cat).map((sub: any) => (
                        <a class="mega-sub" href={`/${cat.slug}/${slugify(sub.name)}/`}>
                          <span class="mega-sub-name">{sub.name}</span>
                          {visibleItems(cat.slug, sub).length > 0 && <span class="mega-sub-desc">{visibleItems(cat.slug, sub).slice(0, 4).join(' · ')}</span>}
                        </a>
                      ))}
                    </div>
                  ) : (
                    <p class="mega-soon">Reviews coming soon — browse everything in {cat.name}.</p>
                  )}
                  <a class="mega-all" href={`/${cat.slug}/`}>View all {cat.name} reviews →</a>
                </div>
                <div class="mega-feature">
                  {latestByCat[cat.slug] ? (
                    <a class="feature-card" href={`/${latestByCat[cat.slug].cat}/${latestByCat[cat.slug].slug}/`}>
                      <span class="feature-label">Latest {cat.name} review</span>
                      {latestByCat[cat.slug].image && <img class="feature-img" src={withBase(latestByCat[cat.slug].image)} alt="" loading="lazy" />}
                      <span class="feature-title">{latestByCat[cat.slug].title}</span>
                      <span class="feature-meta">by {latestByCat[cat.slug].brand}{latestByCat[cat.slug].score ? ` · ${latestByCat[cat.slug].score}/5 ★` : ''}</span>
                    </a>
                  ) : (
                    <a class="feature-card feature-empty" href={`/${cat.slug}/`}>
                      <span class="feature-label">{cat.name}</span>
                      <span class="feature-title">Explore {cat.name} reviews</span>
                      <span class="feature-meta">Tested against the Women's Sports Standard™ →</span>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
        <div class="mega-item">
          <a class:list={["mega-trigger", Astro.url.pathname.startsWith('/news') && "active"]} href="/news/">News</a>
        </div>
      </nav>

      <form class="site-search" action="/search" method="get" role="search">
        <input type="search" name="q" placeholder="Search reviews…" aria-label="Search reviews" />
      </form>
      <a href="https://shop.womenssportsstore.com" class="btn btn-pink shop-btn" target="_blank" rel="noopener">Shop →</a>
    </div>
  </header>

  <!-- Mobile drawer -->
  <div class="drawer-overlay" id="drawerOverlay" hidden></div>
  <aside class="drawer" id="drawer" aria-label="Menu" aria-hidden="true">
    <div class="drawer-head">
      <a href="/" class="logo" aria-label="Women's Sports Store — home"><img src="/logo.svg" alt="Women's Sports Store" class="logo-img" width="44" height="44" /></a>
      <button class="drawer-close" aria-label="Close menu">✕</button>
    </div>
    <form class="drawer-search" action="/search" method="get" role="search">
      <input type="search" name="q" placeholder="Search reviews…" aria-label="Search reviews" />
    </form>
    <nav class="drawer-nav" aria-label="Mobile">
      {taxonomy.map((cat) => (
        <div class="drawer-cat">
          <button class="drawer-cat-btn" aria-expanded="false" aria-controls={`d-${cat.slug}`}>
            <span>{cat.name}</span><span class="chev" aria-hidden="true">›</span>
          </button>
          <div class="drawer-sub" id={`d-${cat.slug}`}>
            <a class="drawer-sub-all" href={`/${cat.slug}/`}>All {cat.name} →</a>
            {visibleSubs(cat).map((sub: any) => (
              <a href={`/${cat.slug}/${slugify(sub.name)}/`}>{sub.name}</a>
            ))}
          </div>
        </div>
      ))}
      <div class="drawer-cat"><a class="drawer-cat-btn" href="/news/" style="display:flex;text-decoration:none"><span>News</span></a></div>
    </nav>
    <a href="https://shop.womenssportsstore.com" class="btn btn-pink drawer-shop" target="_blank" rel="noopener">Shop →</a>
  </aside>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-col footer-brand">
        <div class="footer-logo">WSS™</div>
        <p class="footer-tag">The UK's first dedicated Women's Sports Store. Independent reviews tested against the Women's Sports Standard™.</p>
        <p class="footer-copy">© 2025 Active AI Ltd. All rights reserved.</p>
      </div>
      <div class="footer-col">
        <h4>Reviews</h4>
        <a href="/run/">Run</a>
        <a href="/swim/">Swim</a>
        <a href="/cycle/">Cycle</a>
        <a href="/tri/">Tri</a>
        <a href="/sports-bras/">Sports Bras</a>
        <a href="/nutrition/">Nutrition</a>
        <a href="/technology/">Technology</a>
        <a href="/equipment/">Equipment</a>
        <a href="/news/">News</a>
      </div>
      <div class="footer-col">
        <h4>WSS™</h4>
        <a href="https://womenssportsstandard.com" target="_blank" rel="noopener noreferrer">The Women's Sports Standard</a>
        <a href="https://shop.womenssportsstore.com" target="_blank" rel="noopener noreferrer">Shop</a>
        <a href="/about/">About Us</a>
        <a href="/about/#team">Our Team</a>
        <a href="/coaching-plans/">Coaching Plans</a>
      </div>
      <div class="footer-col">
        <h4>Legal &amp; Social</h4>
        <a href="/privacy-and-cookies/#privacy-policy">Privacy Policy</a>
        <a href="/privacy-and-cookies/#cookie-policy">Cookie Policy</a>
        <div class="footer-social">
          <a href="https://www.facebook.com/womenssportsstore" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6 4.39 10.97 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.96H15.83c-1.49 0-1.95.93-1.95 1.87v2.26h3.32l-.53 3.47h-2.79v8.38C19.61 23.04 24 18.07 24 12.07z"/></svg>
          </a>
          <a href="https://www.instagram.com/womenssportsstore_com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 01-1.38-.9 3.72 3.72 0 01-.9-1.38c-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 1.94c-3.14 0-3.51.01-4.75.07-1.15.05-1.77.24-2.18.4-.55.21-.94.47-1.35.88-.41.41-.67.8-.88 1.35-.16.41-.35 1.03-.4 2.18-.06 1.24-.07 1.61-.07 4.75s.01 3.51.07 4.75c.05 1.15.24 1.77.4 2.18.21.55.47.94.88 1.35.41.41.8.67 1.35.88.41.16 1.03.35 2.18.4 1.24.06 1.61.07 4.75.07s3.51-.01 4.75-.07c1.15-.05 1.77-.24 2.18-.4.55-.21.94-.47 1.35-.88.41-.41.67-.8.88-1.35.16-.41.35-1.03.4-2.18.06-1.24.07-1.61.07-4.75s-.01-3.51-.07-4.75c-.05-1.15-.24-1.77-.4-2.18a3.66 3.66 0 00-.88-1.35 3.66 3.66 0 00-1.35-.88c-.41-.16-1.03-.35-2.18-.4-1.24-.06-1.61-.07-4.75-.07zm0 3.3a4.6 4.6 0 110 9.2 4.6 4.6 0 010-9.2zm0 7.59a2.99 2.99 0 100-5.98 2.99 2.99 0 000 5.98zm5.85-7.81a1.08 1.08 0 11-2.15 0 1.08 1.08 0 012.15 0z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@womenssportsstore" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M16.6 5.82a4.28 4.28 0 01-1.04-2.82h-3.1v12.4a2.59 2.59 0 01-2.59 2.5 2.59 2.59 0 01-2.59-2.59 2.59 2.59 0 012.59-2.59c.27 0 .53.04.77.12v-3.16a5.7 5.7 0 00-.77-.05A5.73 5.73 0 004.2 15.36a5.73 5.73 0 0010.27 3.5 5.7 5.7 0 001.12-3.4V9.01a7.35 7.35 0 004.3 1.38V7.28a4.28 4.28 0 01-3.29-1.46z"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <p>Independent reviews · Tested against the WSS™ framework · <a href="https://womenssportsstandard.com" target="_blank" rel="noopener noreferrer">womenssportsstandard.com</a></p>
      </div>
    </div>
  </footer>

  <script>
    const DELAY = 200;
    const nav = document.querySelector('.mega-nav');
    const items = Array.from(document.querySelectorAll('.mega-item'));
    let openT, closeT, current = null;
    const setOpen = (item, v) => { item.classList.toggle('open', v); const t = item.querySelector('.mega-trigger'); if (t) t.setAttribute('aria-expanded', v ? 'true' : 'false'); };
    const openItem = (item) => { clearTimeout(closeT); if (current && current !== item) setOpen(current, false); setOpen(item, true); current = item; };
    const closeAll = () => { if (current) { setOpen(current, false); current = null; } };
    items.forEach((item) => {
      item.addEventListener('mouseenter', () => { clearTimeout(closeT); clearTimeout(openT); openT = setTimeout(() => openItem(item), DELAY); });
      item.addEventListener('mouseleave', () => { clearTimeout(openT); closeT = setTimeout(closeAll, DELAY); });
      const t = item.querySelector('.mega-trigger');
      t.addEventListener('focus', () => openItem(item));
      t.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') { e.preventDefault(); openItem(item); const link = item.querySelector('.mega-panel a'); if (link) link.focus(); }
        else if (e.key === 'Escape') { closeAll(); t.blur(); }
        else if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') { e.preventDefault(); const i = items.indexOf(item); const n = items[(i + (e.key === 'ArrowRight' ? 1 : items.length - 1)) % items.length]; n.querySelector('.mega-trigger').focus(); }
      });
    });
    if (nav) {
      nav.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeAll(); const t = current && current.querySelector('.mega-trigger'); if (t) t.focus(); } });
      nav.addEventListener('focusout', (e) => { if (!nav.contains(e.relatedTarget)) closeAll(); });
    }
    document.addEventListener('click', (e) => { if (nav && !nav.contains(e.target)) closeAll(); });

    // Mobile drawer
    const ham = document.getElementById('hamburger');
    const drawer = document.getElementById('drawer');
    const overlay = document.getElementById('drawerOverlay');
    const setDrawer = (v) => {
      document.body.classList.toggle('drawer-open', v);
      if (drawer) drawer.setAttribute('aria-hidden', v ? 'false' : 'true');
      if (overlay) overlay.hidden = !v;
      if (ham) ham.setAttribute('aria-expanded', v ? 'true' : 'false');
      if (v) { const c = drawer && drawer.querySelector('.drawer-close'); if (c) c.focus(); } else if (ham) ham.focus();
    };
    if (ham) ham.addEventListener('click', () => setDrawer(!document.body.classList.contains('drawer-open')));
    if (overlay) overlay.addEventListener('click', () => setDrawer(false));
    const dc = drawer && drawer.querySelector('.drawer-close'); if (dc) dc.addEventListener('click', () => setDrawer(false));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && document.body.classList.contains('drawer-open')) setDrawer(false); });
    if (drawer) drawer.querySelectorAll('.drawer-cat-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const exp = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', exp ? 'false' : 'true');
        const panel = document.getElementById(btn.getAttribute('aria-controls'));
        if (panel) panel.style.maxHeight = exp ? '' : panel.scrollHeight + 'px';
      });
    });
  </script>

  <!-- Cookie consent banner — sets wss_cookie_consent so the Avelon loader
       below knows whether marketing (affiliate tracking) cookies are allowed. -->
  <div id="cookieConsent" class="cookie-consent" role="dialog" aria-live="polite" aria-label="Cookie consent" hidden>
    <div class="cookie-consent-inner">
      <p class="cookie-consent-text">We use cookies to understand how the site is used and to track affiliate referrals that help fund our independent reviews. Accept marketing cookies, or reject them and only essential cookies are used. See our <a href="/privacy-and-cookies/#cookie-policy">Cookie Policy</a>.</p>
      <div class="cookie-consent-actions">
        <button type="button" class="cookie-btn cookie-reject" id="cookieReject">Reject</button>
        <button type="button" class="cookie-btn cookie-accept" id="cookieAccept">Accept all</button>
      </div>
    </div>
  </div>
  <script>
    (function () {
      var KEY = 'wss_cookie_consent';
      var banner = document.getElementById('cookieConsent');
      function save(marketing) {
        try { localStorage.setItem(KEY, JSON.stringify({ marketing: marketing, ts: Date.now() })); } catch (e) {}
        if (banner) banner.hidden = true;
        // Fire only when marketing is granted, so the Avelon loader can react
        // without a page reload.
        if (marketing) window.dispatchEvent(new CustomEvent('wss:consent-updated'));
      }
      var stored = null;
      try { stored = JSON.parse(localStorage.getItem(KEY) || 'null'); } catch (e) {}
      if (!stored || typeof stored.marketing !== 'boolean') { if (banner) banner.hidden = false; }
      var a = document.getElementById('cookieAccept'), r = document.getElementById('cookieReject');
      if (a) a.addEventListener('click', function () { save(true); });
      if (r) r.addEventListener('click', function () { save(false); });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- AVELON AUTO URL CONVERTER                           -->
  <!-- Converts outbound product URLs to affiliate links   -->
  <!-- Only loads after marketing cookie consent given     -->
  <!--                                                     -->
  <!-- TO DISABLE the Avelon URL Converter:                -->
  <!--  - Open src/layouts/BaseLayout.astro in GitHub      -->
  <!--  - Delete this marked block (from this line...)     -->
  <!--  - Commit changes                                   -->
  <!--  - Netlify auto-deploys in ~60 seconds              -->
  <!--  - All links revert to standard product URLs        -->
  <!--    instantly                                        -->
  <!--  - No other files need changing                     -->
  <!--  - No review content is affected                    -->
  <!-- ═══════════════════════════════════════════════════ -->
  <script>
  (function() {
    const AVELON_SRC = 'https://avln.me/affiliate/script/JufojTjFAbux/urlrw.js';

    function loadAvelon(forceRescan) {
      if (document.querySelector('script[src="' + AVELON_SRC + '"]')) return;
      const script = document.createElement('script');
      script.src = AVELON_SRC;
      script.async = true;
      // Safeguard: when consent is granted mid-session the page has already
      // finished loading, so a converter that only binds to DOMContentLoaded
      // would never fire. Re-dispatch a synthetic DOMContentLoaded once the
      // script loads so it scans (and rewrites) the links already on the page.
      if (forceRescan) {
        script.onload = function () {
          document.dispatchEvent(new Event('DOMContentLoaded'));
        };
      }
      document.head.appendChild(script);
    }

    function checkConsent(forceRescan) {
      try {
        const consent = JSON.parse(
          localStorage.getItem('wss_cookie_consent') || '{}'
        );
        if (consent.marketing === true) loadAvelon(forceRescan);
      } catch(e) {}
    }

    // Check on page load — rely on the natural DOMContentLoaded, no rescan.
    checkConsent(false);

    // Check when consent updated (fires when user accepts banner) — the page is
    // already loaded, so force a rescan after the script loads.
    window.addEventListener('wss:consent-updated', function () { checkConsent(true); });
  })();
  </script>
  <!-- ...to here. All links revert to standard URLs instantly -->
