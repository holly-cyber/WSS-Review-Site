function parseNwSources(fm){
  // sources: is the last frontmatter key in generated files, so capture to the
  // end and pull title/url pairs (non-pair trailing lines are simply ignored).
  const m=fm.match(/(?:^|\n)sources:[ \t]*\n([\s\S]*)$/);
  if(!m) return [];
  const out=[]; const re=/-[ \t]*title:[ \t]*"((?:[^"\\]|\\.)*)"[ \t]*\n[ \t]*url:[ \t]*"((?:[^"\\]|\\.)*)"/g; let x;
  while((x=re.exec(m[1]))) out.push({title:x[1].replace(/\\"/g,'"'),link:x[2].replace(/\\"/g,'"')});
  return out;
}
