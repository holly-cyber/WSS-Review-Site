let nwResults=[], nwActiveTag='', nwSearchT=null;

async function refreshFeeds(){
  if(!nwFeeds.length){ alert('newsAlert','wr','No RSS feeds configured — add one in the RSS feeds panel above.'); return; }
  const sources=selectedFeeds();
  if(!sources.length){ alert('newsAlert','wr','No feeds selected — tick at least one feed in the RSS feeds panel.'); return; }
  const btn=$('nwRefresh'); btn.disabled=true; btn.textContent='Fetching…';
  alert('newsAlert','inf','Fetching '+sources.length+' feed(s)…');
  try{
    const r=await fetch('/api/rss-proxy',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sources})});
    const data=await r.json().catch(()=>({}));
    if(!r.ok) throw new Error(data.message||('HTTP '+r.status));
    nwResults=data.results||[]; nwAllItems=[]; nwSel=[];
    let nwHidden=0;
    for(const rr of nwResults){ for(const it of (rr.items||[])){
      if(it.link && nwUsedLinks.has(normLink(it.link))){ nwHidden++; continue; }   // skip articles we've used before
      nwAllItems.push({title:it.title,link:it.link,summary:it.summary,date:it.date,ts:it.ts,source:rr.name,tag:rr.tag||''});
    }}
    renderNwTags();
    $('nwFilterBar').style.display=nwAllItems.length?'flex':'none';
    applyNwFilter();
    const ok=nwResults.filter(x=>x.ok).length;
    alert('newsAlert','ok',`Loaded ${nwAllItems.length} new stor${nwAllItems.length===1?'y':'ies'} from ${ok}/${sources.length} feed(s)${nwHidden?` · ${nwHidden} already-used hidden`:''}. Filter by tag or keyword, then select one (rewrite) or several (roundup).`);
  }catch(e){ alert('newsAlert','er','Could not fetch feeds: '+e.message+' (the rss-proxy function needs to be deployed on Netlify).'); }
  btn.disabled=false; btn.textContent='↻ Refresh feeds'; updateFeedPickCount();
}

// --- Tag + keyword filtering over the pulled stories ---
function nwTagList(){ const s=new Set(); nwFeeds.forEach(f=>f.tag&&s.add(f.tag)); nwResults.forEach(r=>r.tag&&s.add(r.tag)); return [...s].sort(); }
function renderNwTags(){
  $('nwTags').innerHTML=[`<span class="nw-tag${nwActiveTag===''?' active':''}" data-tag="">All</span>`]
    .concat(nwTagList().map(t=>`<span class="nw-tag${nwActiveTag===t?' active':''}" data-tag="${esc(t)}">${esc(t)}</span>`)).join('');
}
$('nwTags').addEventListener('click',e=>{ const c=e.target.closest('[data-tag]'); if(!c) return; nwActiveTag=c.dataset.tag; renderNwTags(); applyNwFilter(); });
$('nwSearch').addEventListener('input',()=>{ clearTimeout(nwSearchT); nwSearchT=setTimeout(applyNwFilter,180); });

function applyNwFilter(){
  const terms=($('nwSearch').value||'').trim().toLowerCase().split(/\s+/).filter(Boolean);
  const bySource=new Map();
  nwAllItems.forEach((it,i)=>{
    if(nwActiveTag && it.tag!==nwActiveTag) return;
    const hay=(it.title+' '+(it.summary||'')).toLowerCase();
    if(terms.length && !terms.every(t=>hay.includes(t))) return;
    (bySource.get(it.source)||bySource.set(it.source,[]).get(it.source)).push({it,i});
  });
  let html='';
  for(const r of nwResults){
    if(!r.ok){ html+=`<div class="nw-feed"><div class="nw-feed-h">${esc(r.name)} <span style="color:#c00;font-weight:400">· ${esc(r.error||'failed')}</span></div></div>`; continue; }
    const rows=bySource.get(r.name)||[]; if(!rows.length) continue;
    let body='';
    for(const {it,i} of rows){
      const d=it.ts?new Date(it.ts).toLocaleDateString('en-GB',{day:'numeric',month:'short'}):'';
      const checked=nwSel.includes(i)?' checked':'';
      body+=`<div class="nw-item" data-i="${i}"><input type="checkbox" data-i="${i}"${checked}/><span class="nw-it-title">${esc(it.title)}</span>${it.link?`<a class="nw-it-link" href="${esc(it.link)}" target="_blank" rel="noopener">source ↗</a>`:''}<span class="nw-it-meta">${esc(r.name)}${it.tag?' · '+esc(it.tag):''}${d?' · '+d:''}</span>${it.summary?`<span class="nw-it-sum">${esc(it.summary)}</span>`:''}</div>`;
    }
    html+=`<div class="nw-feed"><div class="nw-feed-h">${esc(r.name)} <span style="color:#aaa;font-weight:400">· ${rows.length} shown</span></div>${body}</div>`;
  }
  $('nwItems').innerHTML=html||`<p style="color:#999;padding:8px">No stories match this filter.</p>`;
  updateNwSel();
}

