  const text=await aiStream([{role:'user',content:prompt}],`Senior WSS reviewer. Never fabricate tester data. Specific failure modes, never vague praise. British English.\n\n${pType==='apparel'?WSS_APPAREL:WSS_NUTRITION}`,document.getElementById('writeOut'),document.getElementById('writeBtn'),'Regenerate',4000);
