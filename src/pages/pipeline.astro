    const d=await ghApi('put',{path:editingPath,content:b64(document.getElementById('meContent').value),message:`Edit review: ${editingPath}`,sha:editingSha});editingSha=d.content.sha;
    setAlert('manageAlert','ok','Saved ✓ Netlify will redeploy within ~60s.');
  }catch(e){setAlert('manageAlert','er','Save failed: '+e.message);}
  btn.disabled=false;btn.textContent='Save changes';
});
document.getElementById('meDeleteBtn').addEventListener('click',()=>deleteArticle({path:editingPath,sha:editingSha},true));
async function deleteArticle(f,fromEditor){
  if(!confirm('Delete this article permanently?\n\n'+f.path+'\n\nIt will be removed from the site on the next deploy.'))return;
  setAlert('manageAlert','inf','Deleting…');
  try{
    // Re-fetch the file's current sha on this branch (robust against stale tree shas).
    const g=await ghApi('get',{path:f.path});const sha=g.sha;
    await ghApi('delete',{path:f.path,message:`Delete review: ${f.path}`,sha});
    setAlert('manageAlert','ok','Deleted ✓ It will disappear from the site on the next deploy.');
    manageFiles=manageFiles.filter(x=>x.path!==f.path);
    renderManageList();
    if(fromEditor)showManageList();
  }catch(e){setAlert('manageAlert','er','Delete failed: '+e.message);}
}

// Review preview (renders the final markdown the way the live page will)
function mdToHtml(md){
  const escTxt=s=>s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  function inline(t){
    // Preserve raw <a>…</a> anchors (placement links already have rel); format the rest.
    return String(t).split(/(<a\b[^>]*>[\s\S]*?<\/a>)/g).map((part,idx)=>{
      if(idx%2===1)return part;
      part=escTxt(part);
      part=part.replace(/!\[([^\]]*)\]\(([^)\s]+)[^)]*\)/g,(m,a,u)=>`<img src="${u}" alt="${a}">`);
      part=part.replace(/\[([^\]]+)\]\(([^)\s]+)[^)]*\)/g,(m,a,u)=>`<a href="${u}" target="_blank" rel="noopener">${a}</a>`);
      part=part.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
      part=part.replace(/(^|[^*])\*([^*\n]+)\*(?!\*)/g,'$1<em>$2</em>');
      part=part.replace(/`([^`]+)`/g,'<code>$1</code>');
      return part;
    }).join('');
  }
  const lines=(md||'').replace(/\r/g,'').split('\n');let html='',i=0;
  while(i<lines.length){
    const line=lines[i];
    if(!line.trim()){i++;continue;}
    if(/^\s*<(?!a\b)/.test(line)){html+=line;i++;continue;}
    const hm=line.match(/^(#{2,6})\s+(.*)$/);
    if(hm){const lvl=Math.min(hm[1].length,6);html+=`<h${lvl}>${inline(hm[2])}</h${lvl}>`;i++;continue;}
    if(/^\s*\|/.test(line)&&i+1<lines.length&&/-/.test(lines[i+1])&&/^\s*\|?[\s:|-]+$/.test(lines[i+1])){
      const splitRow=l=>l.trim().replace(/^\|/,'').replace(/\|$/,'').split('|').map(x=>x.trim());
      const head=splitRow(line);i+=2;const rows=[];
      while(i<lines.length&&/^\s*\|/.test(lines[i])){rows.push(splitRow(lines[i]));i++;}
      html+='<table><thead><tr>'+head.map(c=>`<th>${inline(c)}</th>`).join('')+'</tr></thead><tbody>'+rows.map(r=>'<tr>'+r.map(c=>`<td>${inline(c)}</td>`).join('')+'</tr>').join('')+'</tbody></table>';continue;
    }
    if(/^\s*([-*]|\d+\.)\s+/.test(line)){const ordered=/^\s*\d+\./.test(line);const items=[];while(i<lines.length&&/^\s*([-*]|\d+\.)\s+/.test(lines[i])){items.push(lines[i].replace(/^\s*([-*]|\d+\.)\s+/,''));i++;}html+=`<${ordered?'ol':'ul'}>`+items.map(it=>`<li>${inline(it)}</li>`).join('')+`</${ordered?'ol':'ul'}>`;continue;}
    if(/^\s*>/.test(line)){const q=[];while(i<lines.length&&/^\s*>/.test(lines[i])){q.push(lines[i].replace(/^\s*>\s?/,''));i++;}html+=`<blockquote>${inline(q.join(' '))}</blockquote>`;continue;}
    const para=[line];i++;
    while(i<lines.length&&lines[i].trim()&&!/^\s*(#{2,6}\s|[-*]\s|\d+\.\s|>|\||<(?!a\b))/.test(lines[i])){para.push(lines[i]);i++;}
    html+=`<p>${inline(para.join(' '))}</p>`;
  }
  return html;
}
function openPreview(){
  const review=getReview();
  if(!review){setAlert('pushAlert','er','Write the review first.');return}
  harvestReview();
  const name=val('pName')||'Product',brand=val('pBrand')||'',price=val('pPrice'),pType=val('pType');
  const category=val('pCategory')||(pType==='nutrition'?'nutrition':guessCategory());
  const selImgs=state.selectedImages.map(i=>state.allImages[i]).filter(Boolean);
  let body=tidyMd(buildReviewBody(stripBuy(review),val('reviewerName'),selImgs,`${brand} ${name}`));
  body=body.replace(/^##[ \t]*Overview\b[^\n]*$/im,'## '+reviewHeading(brand,name));
  const productPage=val('destUrl')||val('pUrl')||'',affLink=state.affLink||'',shopifyLink=val('pShopify');
  body=tidyMd(polishBody(body));
  body=replaceLinkTokens(body,affLink,shopifyLink);
  const om=review.match(/Overall:\s*([\d.]+)\s*\/\s*5/i),overall=om?om[1]:'4.0';
  const reviewer=val('reviewerName'),bio=val('reviewerBio'),avatar=val('reviewerAvatar');
  const title=reviewHeading(brand,name);
  const buyBtns=[];
  if(shopifyLink)buyBtns.push(`<a class="pv-buy" href="${esc(shopifyLink)}" target="_blank" rel="nofollow">Buy from WSS store${price?' — £'+esc(price):''} →</a>`);
  if(affLink)buyBtns.push(`<a class="pv-buy${shopifyLink?' alt':''}" href="${esc(affLink)}" target="_blank" rel="nofollow sponsored">${shopifyLink?'Buy direct from '+esc(brand||'brand')+' →':'Buy direct from '+esc(brand||'brand')+(price?' — £'+esc(price):'')+' →'}</a>`);
  if(!buyBtns.length&&productPage)buyBtns.push(`<a class="pv-buy" href="${esc(productPage)}" target="_blank" rel="nofollow">Buy now${price?' — £'+esc(price):''} →</a>`);
  const pct=Math.max(0,Math.min(100,(parseFloat(overall)/5)*100));
  const stars=`<span class="pv-stars-wrap"><span class="pv-stars-bg">★★★★★</span><span class="pv-stars-fg" style="width:${pct}%">★★★★★</span></span>`;
  let h=`<div class="pv-hero"><div class="pv-pill">${esc(category.replace('-',' '))}</div><div class="pv-title">${esc(title)}</div><div class="pv-brand">by <strong>${esc(brand)}</strong>${price?' · £'+esc(price):''}</div><div class="pv-score">${stars}<span class="overall-num">${esc(overall)}/5</span><span class="pv-badge">WSS™ Reviewed</span></div>`;
  if(reviewer)h+=`<div class="pv-byline">${avatar?`<img src="${esc(avatar)}" alt=""/>`:''}<span>Reviewed by <strong>${esc(reviewer)}</strong></span></div>`;
  h+=`</div>`;
  let c=`<div class="pv-content">${mdToHtml(body)}`;
  if(buyBtns.length)c+=`<div class="pv-cta">${buyBtns.join('')}</div>`;
  if(reviewer||bio)c+=`<div class="pv-reviewer">${avatar?`<img src="${esc(avatar)}" alt=""/>`:''}<div><div class="lbl">About the reviewer</div>${reviewer?`<div class="nm">${esc(reviewer)}</div>`:''}${bio?`<p class="bio">${esc(bio)}</p>`:''}</div></div>`;
  c+=`</div>`;
  document.getElementById('previewBody').innerHTML=h+c;
  document.getElementById('previewBody').scrollTop=0;
  document.getElementById('previewOv').classList.add('show');
}
document.getElementById('previewBtn').addEventListener('click',openPreview);
document.getElementById('previewCloseBtn').addEventListener('click',()=>document.getElementById('previewOv').classList.remove('show'));
document.getElementById('previewOv').addEventListener('click',e=>{if(e.target===document.getElementById('previewOv'))document.getElementById('previewOv').classList.remove('show')});

// Taxonomy-driven subcategory / sub-subcategory selectors
const TAXONOMY=(()=>{try{return JSON.parse(document.getElementById('wss-taxonomy').textContent||'[]');}catch{return[];}})();
function taxoSlug(s){return String(s||'').toLowerCase().replace(/&/g,'and').replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');}
function populateSubcategory(){
  const c=TAXONOMY.find(t=>t.slug===val('pCategory'));
  const sel=document.getElementById('pSubcategory');if(!sel)return;
  sel.innerHTML='<option value="">— optional —</option>'+(c?c.subs.map(s=>`<option value="${taxoSlug(s.name)}">${esc(s.name)}</option>`).join(''):'');
  populateSubsub();
}
function populateSubsub(){
  const c=TAXONOMY.find(t=>t.slug===val('pCategory'));
  const s=c&&c.subs.find(x=>taxoSlug(x.name)===val('pSubcategory'));
  const sel=document.getElementById('pSubsubcategory');if(!sel)return;
  sel.innerHTML='<option value="">— optional —</option>'+(s?s.items.map(it=>`<option value="${taxoSlug(it)}">${esc(it)}</option>`).join(''):'');
}
document.getElementById('pCategory').addEventListener('change',populateSubcategory);
document.getElementById('pSubcategory').addEventListener('change',populateSubsub);
populateSubcategory();

