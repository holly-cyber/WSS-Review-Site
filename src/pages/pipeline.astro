  const critList=areas.map(([k,l])=>l).join('; ');
  const typeLabel=(TYPE_LABELS[type]||'product').toLowerCase();
  const prompt=`Pre-assess this women's ${typeLabel} product for a WSS™ review.\nURL: ${url}\nProduct: ${name}\nBrand: ${brand}\nPrice: £${price}\nSpecs found: ${specs}\n\nProvide:\n1. WSS PRE-ASSESSMENT across these criteria (likely score 1-5 + the evidence/gaps for each): ${critList}\n2. RED FLAGS specific to this ${typeLabel} (unsubstantiated female-specific claims, sizing/fit gaps, missing certifications or testing data, "pink it and shrink it")\n3. CUSTOMER SENTIMENT SUMMARY (what buyers commonly say; be clear about data limitations)\n4. PRICE-TO-VALUE vs comparable women's products\nBe precise and sceptical. Where evidence is missing, say so. British English.`;
  const text=await aiStream([{role:'user',content:prompt}],'Senior WSS research analyst. British English. Never fabricate. Be sceptical and specific.',resOut,null,'',2000);
  state.researchText=text||'';
