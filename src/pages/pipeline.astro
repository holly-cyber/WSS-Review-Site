// Parse the 3-email sequence from the delimiter format ([EMAIL] ... [/EMAIL]).
// Avoids JSON entirely so HTML quotes/newlines can't break it. Falls back to
// legacy JSON output if the model returns that instead.
function parseEmails(raw){
  const txt=cleanJson(raw);
  const parts=txt.split(/\[EMAIL\]/i).slice(1);
  const out=parts.map(p=>{
    p=p.replace(/\[\/EMAIL\][\s\S]*$/i,'').trim();
    const subject=((p.match(/^\s*SUBJECT:\s*(.*)$/im)||[])[1]||'').trim();
    const preview_text=((p.match(/^\s*PREVIEW(?:_TEXT)?:\s*(.*)$/im)||[])[1]||'').trim();
    const bm=p.match(/^\s*BODY(?:_HTML)?:\s*([\s\S]*)$/im);
    const body_html=(bm?bm[1]:'').trim();
    return {subject,preview_text,body_html};
  }).filter(e=>e.subject||e.body_html);
  if(out.length)return out;
  // The model returned JSON instead. Try a strict parse; if it fails (unescaped
  // quotes/newlines inside body_html), extract the fields tolerantly.
  let s=txt;const a=s.indexOf('['),b=s.lastIndexOf(']');if(a>=0&&b>a)s=s.slice(a,b+1);
  try{const j=JSON.parse(s);if(Array.isArray(j)&&j.length)return j;}catch(e){}
  const unesc=v=>(v||'').split('\\n').join('\n').split('\\t').join(' ').split('\\"').join('"').split('\\\\').join('\\').trim();
  const objs=s.replace(/^\s*\[/,'').replace(/\]\s*$/,'').split(/\}\s*,\s*\{/);
  const out2=objs.map(o=>({
    subject:unesc((o.match(/"subject"\s*:\s*"([\s\S]*?)"\s*,\s*"preview/i)||o.match(/"subject"\s*:\s*"([^"]*)"/i)||[])[1]),
    preview_text:unesc((o.match(/"preview_text"\s*:\s*"([\s\S]*?)"\s*,\s*"body/i)||o.match(/"preview_text"\s*:\s*"([^"]*)"/i)||[])[1]),
    body_html:unesc((o.match(/"body_html"\s*:\s*"([\s\S]*?)"\s*\}?\s*$/i)||[])[1])
  })).filter(e=>e.subject||e.body_html);
  if(out2.length)return out2;
  return JSON.parse(s);
}
function stripHtml(h){const d=document.createElement('div');d.innerHTML=h||'';return(d.textContent||'').replace(/\s+/g,' ').trim()}

