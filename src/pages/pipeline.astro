    state.reviewText=text;
    document.getElementById('writeEdit').value=text;
    document.getElementById('writeEditWrap').style.display='block';
    document.getElementById('writeFB').style.display='block';
  }
}

// GitHub push
document.getElementById('pushBtn').addEventListener('click',async()=>{
  if(!cfg.ghToken){setAlert('pushAlert','er','Add your GitHub Personal Access Token in Settings first.');return}
  const review=getReview();
  if(!review){setAlert('pushAlert','er','Write and approve the review first.');return}
  const name=document.getElementById('pName').value||'Product Review';
  const brand=document.getElementById('pBrand').value||'';
  const price=document.getElementById('pPrice').value||'';
  const pType=document.getElementById('pType').value;
  const affLink=state.affLink||'';
  const slug=slugify(`${brand}-${name}`);
  const category=pType==='nutrition'?'nutrition':guessCategory();
  setAlert('pushAlert','inf','Pushing to GitHub…');
  document.getElementById('pushBtn').disabled=true;document.getElementById('pushBtn').textContent='Pushing…';
  try{
    const overallMatch=review.match(/Overall:\s*([\d.]+)\s*\/\s*5/i);
    const overall=overallMatch?overallMatch[1]:'4.0';
    const pillarScores=extractPillarScores(review,pType);
    const today=new Date().toISOString().split('T')[0];
    const heroImg=state.selectedImages.length?state.allImages[state.selectedImages[0]]?.url||'':'';
    const excerpt=extractExcerpt(review);
    const frontmatter=`---\ntitle: "${name}"\nbrand: "${brand}"\ncategory: "${category}"\ndate: "${today}"\nprice: "${price}"\nproduct_type: "${pType}"\nexcerpt: "${excerpt}"\nhero_image: "${heroImg}"\noverall_score: ${overall}\naffiliate_link: "${affLink}"\nshopify_link: ""\npillar_scores:\n${Object.entries(pillarScores).map(([k,v])=>`  ${k}: ${v}`).join('\n')}\n---\n\n${review}`;
    const path=`src/pages/reviews/${category}/${slug}.md`;
    const content=btoa(unescape(encodeURIComponent(frontmatter)));
    let sha='';
    try{const check=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${path}`,{headers:{Authorization:`token ${cfg.ghToken}`,Accept:'application/vnd.github.v3+json'}});if(check.ok){const d=await check.json();sha=d.sha;}}catch{}
    const body={message:`Add review: ${brand} ${name}`,content,branch:cfg.ghBranch};
    if(sha)body.sha=sha;
    const res=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${path}`,{method:'PUT',headers:{Authorization:`token ${cfg.ghToken}`,Accept:'application/vnd.github.v3+json','Content-Type':'application/json'},body:JSON.stringify(body)});
    if(!res.ok){const err=await res.json().catch(()=>({}));throw new Error(err.message||'HTTP '+res.status);}
    setAlert('pushAlert','','');
    document.getElementById('pushResult').style.display='block';
    document.getElementById('pushBadge').textContent=`✓ Pushed — ${path}`;
    document.getElementById('pushBadge').className='gh-status ok';
    document.getElementById('pushLinks').innerHTML=`<a class="deploy-link" href="https://github.com/${cfg.ghUser}/${cfg.ghRepo}/blob/${cfg.ghBranch}/${path}" target="_blank">View on GitHub →</a><a class="deploy-link pink" href="https://app.netlify.com/sites/wss-reviews/deploys" target="_blank">Watch Netlify deploy →</a>`;
    markDone('push');
  }catch(e){
    setAlert('pushAlert','er','GitHub push failed: '+e.message);
    document.getElementById('pushBadge').textContent='✗ Push failed: '+e.message;
    document.getElementById('pushBadge').className='gh-status er';
    document.getElementById('pushResult').style.display='block';
  }
  document.getElementById('pushBtn').disabled=false;document.getElementById('pushBtn').textContent='Re-push to GitHub';
});

function guessCategory(){
  const n=(document.getElementById('pName').value||'').toLowerCase();
  if(/bra|bras/.test(n))return'sports-bras';
  if(/swim|goggle|wetsuit/.test(n))return'swim';
  if(/cycle|cycling|bike|jersey/.test(n))return'cycle';
  if(/tri|trisuit|triathlon/.test(n))return'tri';
  return'run';
}
function extractExcerpt(review){
  const lines=review.split('\n').filter(l=>l.trim()&&!l.startsWith('#'));
  return(lines[0]||'').slice(0,155).replace(/"/g,"'")+'\u2026';
}
function extractPillarScores(review,pType){
  const scores={};
  if(pType==='apparel'){
    [['p1','Pillar 1'],['p2','Pillar 2'],['p3','Pillar 3'],['p5','Pillar 5'],['p7','Pillar 7']].forEach(([key,label])=>{const m=review.match(new RegExp(label+'[^:]*:\\s*(\\d)'));scores[key]=m?parseInt(m[1]):3;});
  }else{
    [['taste','Taste'],['nutrition','Nutrition Profile'],['performance','Performance'],['value','Value']].forEach(([key,label])=>{const m=review.match(new RegExp(label+'[^:]*:\\s*(\\d)'));scores[key]=m?parseInt(m[1]):3;});
  }
  return scores;
}

