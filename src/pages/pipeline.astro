function renderEmails(){
  const labels=['Email 1 — Review Drop','Email 2 — Buy Nudge (day 4)','Email 3 — Social Proof (day 7)'];
  document.getElementById('emailsOut').innerHTML=state.emails.map((e,i)=>`<div class="ec"><div class="eh" data-toggle="${i}"><div class="eht">${labels[i]||'Email '+(i+1)}</div><div id="ech${i}">▼</div></div><div id="ecb${i}" class="eb" style="${i>0?'display:none':''}"><div class="ef"><div class="efl">Subject</div><input id="es${i}" value="${esc(e.subject||'')}"/></div><div class="ef"><div class="efl">Preview text</div><input id="ep${i}" value="${esc(e.preview_text||'')}"/></div><div class="ef"><div class="efl">Body HTML</div><textarea id="eb${i}" rows="6" style="font-family:monospace;font-size:12px">${esc(e.body_html||'')}</textarea></div></div></div>`).join('');
  if(!emailsBound){document.getElementById('emailsOut').addEventListener('click',e=>{const h=e.target.closest('[data-toggle]');if(h){const i=h.dataset.toggle;const b=document.getElementById('ecb'+i);const c=document.getElementById('ech'+i);b.style.display=b.style.display==='none'?'block':'none';c.textContent=b.style.display==='none'?'▼':'▲';}});emailsBound=true;}
  document.getElementById('emailsPush').style.display='block';
}
// Commit the (edited) emails to the repo so Claude can read + push them to MailerLite via MCP.
async function putRepoFile(path,str,message){
  let sha='';
  try{const c=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${path}?ref=${cfg.ghBranch}`,{headers:{Authorization:`token ${cfg.ghToken}`,Accept:'application/vnd.github.v3+json'}});if(c.ok){sha=(await c.json()).sha;}}catch{}
  const body={message,content:b64(str),branch:cfg.ghBranch};if(sha)body.sha=sha;
  const res=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${path}`,{method:'PUT',headers:{Authorization:`token ${cfg.ghToken}`,Accept:'application/vnd.github.v3+json','Content-Type':'application/json'},body:JSON.stringify(body)});
  if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||'HTTP '+res.status);}
  return res.json();
}
document.getElementById('emailsToClaudeBtn').addEventListener('click',async()=>{
  if(!cfg.ghToken){setAlert('emailsPushAlert','er','Add your GitHub token in Settings first (same one used to publish reviews).');return}
  if(!state.emails.length){setAlert('emailsPushAlert','er','Generate the emails first.');return}
  const emails=state.emails.map((e,i)=>({label:['Review Drop','Buy Nudge (day 4)','Social Proof (day 7)'][i]||('Email '+(i+1)),subject:document.getElementById('es'+i)?.value??e.subject,preview_text:document.getElementById('ep'+i)?.value??e.preview_text,body_html:document.getElementById('eb'+i)?.value??e.body_html}));
  const name=val('pName')||'product';const brand=val('pBrand')||'';
  const slug=slugify(brand+'-'+name)||'review';
  const payload={product:name,brand,slug,review_url:`https://wss-review-site-tool.netlify.app/reviews/${(val('pType')==='nutrition'?'nutrition':guessCategory())}/${slug}/`,affiliate_link:state.affLink||'',generated_at:new Date().toISOString(),emails};
  const json=JSON.stringify(payload,null,2);
  const btn=document.getElementById('emailsToClaudeBtn');btn.disabled=true;btn.textContent='Sending…';
  setAlert('emailsPushAlert','inf','Saving emails to the repo…');
  try{
    await putRepoFile('pipeline-output/emails-latest.json',json,`Pipeline emails: ${brand} ${name}`);
    await putRepoFile(`pipeline-output/emails-${slug}.json`,json,`Pipeline emails: ${brand} ${name}`);
    setAlert('emailsPushAlert','ok','Sent ✓ Now tell Claude in chat: “Push the latest pipeline emails to MailerLite as drafts.”');
  }catch(e){setAlert('emailsPushAlert','er','Could not send: '+e.message);}
  btn.disabled=false;btn.textContent='⬆ Send emails to Claude (for MailerLite)';
});

// STAGE 9 — Social
document.getElementById('socialBtn').addEventListener('click',()=>runSocial());
document.getElementById('socialRegenBtn').addEventListener('click',()=>runSocial(document.getElementById('socialFBText').value));
document.getElementById('socialApproveBtn').addEventListener('click',()=>approve('social'));
async function runSocial(fb){
  const name=val('pName')||'product';
  const brand=val('pBrand')||'';
  const note=fb?`\n\nHolly's feedback: ${fb}`:'';
  const reel=document.getElementById('reelOut').innerText||'';
  const text=await aiStream([{role:'user',content:`Instagram social copy for ${name} by ${brand}.\nReview:\n${getReview()}\nReel:\n${reel}${note}\n\nProduce, clearly labelled:\n1. REEL CAPTION (150 words max, hook first, 3 WSS findings, "link in bio", exactly 5 hashtags)\n2. STORIES SEQUENCE (3 slides: teaser / key stat / CTA)\n3. CAROUSEL (5 slide titles, each with a one-line caption)`}],'WSS social writer. Expert, direct, a little sassy. British English. No "pink it and shrink it".',document.getElementById('socialOut'),document.getElementById('socialBtn'),'Regenerate',2000);
  if(text)document.getElementById('socialFB').style.display='block';
}

// Stage control
const STAGES=['write','push','reel','emails','social','approve'];
function goStage(s){
  STAGES.forEach(id=>{document.getElementById('s-'+id).style.display=id===s?'block':'none'});
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('act',t.dataset.s===s));
  if(s==='write')renderScoreInputs(val('pType'));
  if(s==='approve')buildChecklist();
}
function markDone(s){done.add(s);document.querySelectorAll('.tab').forEach(t=>{if(t.dataset.s===s){t.classList.add('dn');t.classList.remove('act')}});}
function approve(s){markDone(s);const next=STAGES[STAGES.indexOf(s)+1];if(next)goStage(next);}
document.getElementById('tabs').addEventListener('click',e=>{const t=e.target.closest('.tab');if(t&&t.dataset.s)goStage(t.dataset.s)});

// STAGE 10 — Holly approves
function buildChecklist(){
  const items=[['write','Full WSS™ review (pillars, scores, FAQ, meta)'],['push','Pushed to GitHub (Netlify auto-deploys)'],['reel','60s Reel script'],['emails','3-email series'],['social','Instagram caption + Stories + carousel']];
  document.getElementById('checklist').innerHTML=items.map(([id,label])=>{const ok=done.has(id);return`<div class="ci"><div class="ck ${ok?'yes':''}">${ok?'✓':''}</div><span class="cl ${ok?'yes':''}">${label}</span>${!ok?`<button class="cr" data-goto="${id}">Review</button>`:''}</div>`;}).join('');
  if(!checklistBound){document.getElementById('checklist').addEventListener('click',e=>{const b=e.target.closest('[data-goto]');if(b)goStage(b.dataset.goto)});checklistBound=true;}
  if(state.emails.length){
    const name=val('pName')||'product';
    document.getElementById('mlCode').textContent=`Push these 3 approved emails to MailerLite as draft campaigns for "${name}":\nEmail 1: ${document.getElementById('es0')?.value||state.emails[0]?.subject||''}\nEmail 2: ${document.getElementById('es1')?.value||state.emails[1]?.subject||''}\nEmail 3: ${document.getElementById('es2')?.value||state.emails[2]?.subject||''}\nSender: holly@womenssportsstore.com / WomensSportsStore.com`;
    document.getElementById('mlPrompt').style.display='block';
  }
}
let checklistBound=false;

document.getElementById('addImgBtn').addEventListener('click',addManualImage);
document.getElementById('manualImgUrl').addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();addManualImage();}});

// Manage articles (edit / delete) via the GitHub API
function ghHeaders(){return{Authorization:`token ${cfg.ghToken}`,Accept:'application/vnd.github.v3+json'};}
function b64decode(b){const clean=(b||'').replace(/\n/g,'');try{return decodeURIComponent(escape(atob(clean)));}catch{return atob(clean);}}
let manageFiles=[],editingPath='',editingSha='';
document.getElementById('manageBtn').addEventListener('click',openManage);
document.getElementById('manageCloseBtn').addEventListener('click',()=>document.getElementById('manageOv').classList.remove('show'));
document.getElementById('manageOv').addEventListener('click',e=>{if(e.target===document.getElementById('manageOv'))document.getElementById('manageOv').classList.remove('show')});
document.getElementById('meBackBtn').addEventListener('click',showManageList);
async function openManage(){
  if(!cfg.ghToken){setAlert('manageAlert','er','Add your GitHub token in Settings first.');document.getElementById('manageOv').classList.add('show');return}
  document.getElementById('manageOv').classList.add('show');
  showManageList();
  loadArticles();
}
function showManageList(){document.getElementById('manageEditor').style.display='none';document.getElementById('manageList').style.display='block';}
async function loadArticles(){
  const list=document.getElementById('manageList');
  list.innerHTML='<div style="padding:10px;color:#aaa;font-size:13px">Loading articles…</div>';
  setAlert('manageAlert','','');
  try{
    const r=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/git/trees/${cfg.ghBranch}?recursive=1`,{headers:ghHeaders()});
    if(!r.ok)throw new Error('HTTP '+r.status+(r.status===404?' — check repo/branch in Settings':''));
    const d=await r.json();
    manageFiles=(d.tree||[]).filter(t=>t.type==='blob'&&/^src\/pages\/reviews\/.+\.md$/.test(t.path)).sort((a,b)=>a.path.localeCompare(b.path));
    if(!manageFiles.length){list.innerHTML='<div style="padding:10px;color:#aaa;font-size:13px">No review articles found.</div>';return}
    list.innerHTML=manageFiles.map((f,i)=>{const parts=f.path.split('/');const slug=parts.pop().replace('.md','');const cat=parts.pop();return `<div class="retitem" style="cursor:default"><div><div class="retn">${esc(slug)}</div><div class="retd">${esc(cat)}</div></div><div style="display:flex;gap:6px;margin-left:auto"><button class="bg" data-edit="${i}" style="padding:5px 11px">Edit</button><button class="bg" data-del="${i}" style="padding:5px 11px;color:#c00;border-color:#fcc">Delete</button></div></div>`;}).join('');
  }catch(e){list.innerHTML=`<div style="padding:10px;color:#c00;font-size:13px">Could not load: ${esc(e.message)}</div>`;}
}
document.getElementById('manageList').addEventListener('click',e=>{
  const ed=e.target.closest('[data-edit]'),dl=e.target.closest('[data-del]');
  if(ed)editArticle(manageFiles[parseInt(ed.dataset.edit)]);
  else if(dl)deleteArticle(manageFiles[parseInt(dl.dataset.del)],false);
});
async function editArticle(f){
  setAlert('manageAlert','inf','Loading '+f.path+'…');
  try{
    const r=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${f.path}?ref=${cfg.ghBranch}`,{headers:ghHeaders()});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const d=await r.json();
    editingPath=f.path;editingSha=d.sha;
    document.getElementById('meContent').value=b64decode(d.content);
    document.getElementById('meName').textContent=f.path;
    document.getElementById('manageList').style.display='none';
    document.getElementById('manageEditor').style.display='block';
    setAlert('manageAlert','','');
  }catch(e){setAlert('manageAlert','er','Could not load: '+e.message);}
}
document.getElementById('meSaveBtn').addEventListener('click',async()=>{
  const btn=document.getElementById('meSaveBtn');btn.disabled=true;btn.textContent='Saving…';
  setAlert('manageAlert','inf','Saving…');
  try{
    const body={message:`Edit review: ${editingPath}`,content:b64(document.getElementById('meContent').value),branch:cfg.ghBranch,sha:editingSha};
    const r=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${editingPath}`,{method:'PUT',headers:{...ghHeaders(),'Content-Type':'application/json'},body:JSON.stringify(body)});
    if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error(e.message||'HTTP '+r.status);}
    const d=await r.json();editingSha=d.content.sha;
    setAlert('manageAlert','ok','Saved ✓ Netlify will redeploy within ~60s.');
  }catch(e){setAlert('manageAlert','er','Save failed: '+e.message);}
  btn.disabled=false;btn.textContent='Save changes';
});
document.getElementById('meDeleteBtn').addEventListener('click',()=>deleteArticle({path:editingPath,sha:editingSha},true));
async function deleteArticle(f,fromEditor){
  if(!confirm('Delete this article permanently?\n\n'+f.path+'\n\nIt will be removed from the site on the next deploy.'))return;
  setAlert('manageAlert','inf','Deleting…');
  try{
    // Re-fetch the file's current sha on this branch (robust against stale tree shas).
    const g=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${f.path}?ref=${encodeURIComponent(cfg.ghBranch)}`,{headers:ghHeaders()});
    if(!g.ok){const ge=await g.json().catch(()=>({}));throw new Error(`couldn't locate the file on branch "${cfg.ghBranch}" (HTTP ${g.status}${ge.message?': '+ge.message:''})`);}
    const sha=(await g.json()).sha;
    const body={message:`Delete review: ${f.path}`,sha,branch:cfg.ghBranch};
    const r=await fetch(`https://api.github.com/repos/${cfg.ghUser}/${cfg.ghRepo}/contents/${f.path}`,{method:'DELETE',headers:{...ghHeaders(),'Content-Type':'application/json'},body:JSON.stringify(body)});
    if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error((e.message||'HTTP '+r.status)+(r.status===403?' — the token needs write access to this repo':''));}
    setAlert('manageAlert','ok','Deleted ✓ It will disappear from the site on the next deploy.');
    if(fromEditor)showManageList();
    loadArticles();
  }catch(e){setAlert('manageAlert','er','Delete failed: '+e.message);}
}

// Restore saved login so credentials persist across refreshes.
loadCfg();
reflectConnected();
{const rn=document.getElementById('reviewerName');if(rn)rn.value=cfg.reviewer||'';}
if(cfg.avEmail&&cfg.avPass)loadRetailers();
</script>
