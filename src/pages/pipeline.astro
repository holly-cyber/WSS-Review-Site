  }catch(e){el.innerHTML=`<div style="padding:10px;font-size:12px;color:#c00">Could not load retailers: ${esc(e.message)}</div>`;}
}
function autoMatchRetailer(){
  const sel=document.getElementById('retSelect');if(!sel||!state.retailers.length)return;
  let host='';try{host=new URL(val('destUrl')).hostname.replace(/^www\./,'').split('.')[0].toLowerCase();}catch{return;}
  if(!host)return;
  const norm=s=>(s==null?'':String(s)).toLowerCase().replace(/[^a-z0-9]/g,'');
  const idx=state.retailers.findIndex(r=>{const id=norm(r.pk||r.id||r.slug);const nm=norm(r.name||r.retailerName);return id===host||(id&&(id.includes(host)||host.includes(id)))||(nm&&(nm.includes(host)||host.includes(nm)));});
  if(idx>=0){sel.value=String(idx);state.selectedRetailer=state.retailers[idx];setAlert('affAlert','ok','Auto-matched retailer: '+(state.retailers[idx].name||state.retailers[idx].pk||'')+'. Change it above if wrong.');}
}
