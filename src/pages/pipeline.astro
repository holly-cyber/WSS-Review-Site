// Customer reviews (folded into research context)
async function fetchCustomerReviews(url,name,brand){
  try{
    const u=new URL(url);
    const handle=u.pathname.split('/').filter(Boolean).pop();
    try{
      const r=await fetch(`https://judge.me/api/v1/reviews?shop_domain=${u.hostname}&handle=${handle}&per_page=20`);
      if(r.ok){const d=await r.json();if(d.reviews&&d.reviews.length){state.customerReviews=d.reviews.slice(0,8).map(rv=>({rating:rv.rating,text:(rv.body||'').slice(0,250),author:rv.reviewer?.name||'Verified buyer',source:'Judge.me'}));return;}}
    }catch{}
    const text=await aiCall([{role:'user',content:`Summarise customer sentiment for ${brand} ${name}. URL: ${url}\nOverall sentiment, common complaints, common praise, and any fit/performance issues relevant to WSS pillars. Be honest about limitations. British English.`}],'WSS research analyst. Summarise customer sentiment accurately. Never fabricate. British English.',900);
    state.customerReviews=[{text}];
  }catch(e){state.customerReviews=[];}
}

