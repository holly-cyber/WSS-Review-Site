async function fetchImages(url){
  const el=document.getElementById('imageGrid');
  el.innerHTML='<p style="font-size:12px;color:#aaa">Fetching images…</p>';
  try{
    const r=await fetch(url);const html=await r.text();
    const set=new Set();
    [...html.matchAll(/og:image["']?\s*content=["']([^"']+)["']/gi)].forEach(m=>set.add(m[1]));
    [...html.matchAll(/<img[^>]+src=["']([^"']+\.(?:jpg|jpeg|png|webp)[^"']*)["']/gi)].forEach(m=>set.add(m[1]));
    const found=[...set].filter(u=>!/icon|logo|sprite|favicon/i.test(u)).slice(0,12).map((u,i)=>({url:u.startsWith('//')?'https:'+u:u,type:i===0?'hero':'product',alt:'Product image'}));
    if(found.length){state.allImages=found;renderImages(found,true);}
    else{el.innerHTML='<p style="font-size:12px;color:#aaa">No images found automatically. Paste an image URL below to add one.</p>';updateImgStatus();}
  }catch{
    el.innerHTML='<p style="font-size:12px;color:#aaa">Could not fetch images automatically (the site may block cross-origin requests). Paste an image URL below to add one.</p>';updateImgStatus();
  }
}
let imgGridBound=false;
function renderImages(imgs,autoselect){
  const el=document.getElementById('imageGrid');
  if(!imgs.length){el.innerHTML='<p style="font-size:12px;color:#aaa">No images yet. Paste an image URL below to add one.</p>';updateImgStatus();return}
  el.innerHTML=imgs.map((img,i)=>`<div class="icard" id="icard${i}" data-img="${i}"><img src="${esc(img.url)}" loading="lazy" alt="${esc(img.alt||'')}"/><div class="ifeat">★ Featured</div><div class="itick">✓</div><div class="itype">${esc(img.type||'product')}</div></div>`).join('');
  el.querySelectorAll('.icard img').forEach(im=>{im.addEventListener('error',()=>{const card=im.closest('.icard');if(card){const i=parseInt(card.dataset.img);card.style.display='none';const idx=state.selectedImages.indexOf(i);if(idx>=0)state.selectedImages.splice(idx,1);updateFeat();updateImgStatus();}});});
  if(!imgGridBound){el.addEventListener('click',e=>{const c=e.target.closest('.icard');if(c)toggleImg(parseInt(c.dataset.img))});imgGridBound=true;}
  state.selectedImages=state.selectedImages.filter(i=>i<imgs.length);
  if(autoselect&&!state.selectedImages.length)state.selectedImages=[0];
  state.selectedImages.forEach(i=>document.getElementById('icard'+i)?.classList.add('sel'));
  updateFeat();updateImgStatus();
}
function toggleImg(i){
  const c=document.getElementById('icard'+i);if(!c)return;
  const idx=state.selectedImages.indexOf(i);
  if(idx>=0){state.selectedImages.splice(idx,1);c.classList.remove('sel');setAlert('imageAlert','','');}
  else{
    if(state.selectedImages.length>=4){setAlert('imageAlert','inf','Maximum of 4 images per review — deselect one first.');return;}
    state.selectedImages.push(i);c.classList.add('sel');setAlert('imageAlert','','');
  }
  updateFeat();updateImgStatus();
}
function updateFeat(){
  document.querySelectorAll('.icard').forEach(el=>el.classList.remove('feat'));
  if(state.selectedImages.length){document.getElementById('icard'+state.selectedImages[0])?.classList.add('feat');}
}
function updateImgStatus(){
  const n=state.selectedImages.length;
  const el=document.getElementById('imgStatus');if(!el)return;
  el.textContent=n?`${n}/4 image${n>1?'s':''} selected · first is the featured/hero, the rest are spread through the article`:'No images selected — click up to 4 thumbnails above (or add one below).';
  el.style.color=n?'#060':'#888';
}
function addManualImage(){
  const inp=document.getElementById('manualImgUrl');const u=(inp.value||'').trim();
  if(!u){return}
  if(!/^https?:\/\//i.test(u)){setAlert('imageAlert','er','Enter a full image URL starting with http(s)://');return}
  setAlert('imageAlert','','');
  state.allImages.push({url:u,type:'manual',alt:'Added image'});
  const newIdx=state.allImages.length-1;
  renderImages(state.allImages,false);
  toggleImg(newIdx);
  inp.value='';
}

