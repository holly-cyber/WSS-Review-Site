---
import BaseLayout from './BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { findReviewer } from '../data/team.js';
import { withBase } from '../data/taxonomy.js';

const { frontmatter: fm } = Astro.props;
const author = fm.author || fm.tested_by || '';
const writer = findReviewer(author);
const avatar = fm.author_avatar || writer?.image;
const dateLabel = fm.date
  ? new Date(fm.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

// Other recent blog posts (newest first), excluding this one.
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).pop();
const blogMods = import.meta.glob('../pages/blog/*.md', { eager: true });
const moreBlog = Object.entries(blogMods)
  .map(([p, m]: [string, any]) => ({ ...(m.frontmatter || {}), slug: p.split('/').pop().replace('.md', '') }))
  .filter((n) => n.slug !== currentSlug && (import.meta.env.PROD ? n.draft !== true : true))
  .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime())
  .slice(0, 3);
---
<BaseLayout title={fm.title} description={fm.meta_description || fm.excerpt} ogImage={fm.hero_image} noindex={import.meta.env.PROD && fm.draft === true}>
  <article class="blog">
    <div class="container blog-head">
      <div class="breadcrumb"><a href="/blog/">Blog</a>{fm.topic ? <> / <span>{fm.topic}</span></> : null}</div>
      <h1>{fm.title}</h1>
      {fm.excerpt && <p class="blog-standfirst">{fm.excerpt}</p>}
      <div class="blog-meta">
        {avatar && <img class="blog-avatar" src={withBase(avatar)} alt={author} loading="lazy" />}
        <span>
          {author && (<>By {writer ? <a href={`/reviewers/${writer.slug}/`}><strong>{author}</strong></a> : <strong>{author}</strong>}</>)}
          {author && dateLabel ? ' · ' : ''}{dateLabel}
        </span>
      </div>
    </div>

    {fm.hero_image && <div class="container"><img class="blog-hero" src={withBase(fm.hero_image)} alt={fm.title} />{fm.hero_credit && <p class="blog-hero-credit">{fm.hero_credit}</p>}</div>}

    <div class="container blog-body">
      <div class="blog-prose"><slot /></div>
    </div>

    {moreBlog.length > 0 && (
      <div class="container blog-more">
        <h2>More from the blog</h2>
        <div class="blog-more-grid">
          {moreBlog.map((n) => (
            <a class="blog-more-card" href={`/blog/${n.slug}/`}>
              {n.hero_image && <img src={withBase(n.hero_image)} alt={n.title} loading="lazy" />}
              <div class="blog-more-body">
                {n.topic && <span class="blog-more-topic">{n.topic}</span>}
                <span class="blog-more-title">{n.title}</span>
                {n.date && <span class="blog-more-date">{new Date(n.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="container"><EmailSignup /></div>
  </article>

  <script define:vars={{ blogSlug: currentSlug, blogTitle: fm.title || '', blogTopic: fm.topic || '' }}>
    (function () {
      function track() {
        if (window.umami && typeof window.umami.track === 'function') {
          try { window.umami.track('blog-view', { slug: blogSlug, title: blogTitle, topic: blogTopic }); } catch (e) {}
          return true;
        }
        return false;
      }
      if (!track()) { var n = 0, id = setInterval(function () { if (track() || ++n > 25) clearInterval(id); }, 150); }
    })();
  </script>
</BaseLayout>

<style>
.blog { padding-bottom: 3rem; }
.blog-head { max-width: 760px; margin: 0 auto; padding-top: 2.5rem; }
.blog .breadcrumb { font-size: .85rem; color: #888; margin-bottom: 1rem; text-transform: capitalize; }
.blog .breadcrumb a { color: #FF5E84; text-decoration: none; }
.blog-head h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.15; color: #000036; margin: 0 0 .8rem; }
.blog-standfirst { font-size: 1.15rem; color: #444; line-height: 1.5; margin: 0 0 1.2rem; }
.blog-meta { display: flex; align-items: center; gap: .6rem; font-size: .9rem; color: #666; }
.blog-meta a { color: #000036; text-decoration: none; }
.blog-avatar { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 2px solid #FF5E84; }
.blog-hero { display: block; width: 100%; max-width: 920px; margin: 1.6rem auto 0; border-radius: 14px; object-fit: cover; }
.blog-hero-credit { max-width: 920px; margin: .4rem auto 0; font-size: .75rem; color: #9ca3af; text-align: right; }
.blog-body { max-width: 760px; margin: 0 auto; }
.blog-prose { font-size: 1.06rem; line-height: 1.75; color: #1f2430; margin-top: 1.8rem; }
.blog-prose :global(h2) { font-size: 1.5rem; color: #000036; margin: 2rem 0 .8rem; }
.blog-prose :global(h3) { font-size: 1.2rem; color: #000036; margin: 1.6rem 0 .6rem; }
.blog-prose :global(p) { margin: 0 0 1.1rem; }
.blog-prose :global(ul), .blog-prose :global(ol) { margin: 0 0 1.1rem 1.2rem; }
.blog-prose :global(li) { margin: .3rem 0; }
.blog-prose :global(a) { color: #FF5E84; }
.blog-prose :global(img) { width: 100%; border-radius: 12px; margin: 1.4rem 0; }
.blog-prose :global(blockquote) { border-left: 3px solid #FF5E84; margin: 1.4rem 0; padding: .2rem 0 .2rem 1.1rem; color: #555; font-style: italic; }
.blog-more { max-width: 920px; margin: 2.5rem auto 0; }
.blog-more h2 { font-size: 1.3rem; color: #000036; margin: 0 0 1rem; }
.blog-more-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
.blog-more-card { display: flex; flex-direction: column; border: 1px solid #ececf3; border-radius: 12px; overflow: hidden; text-decoration: none; background: #fff; transition: box-shadow .15s; }
.blog-more-card:hover { box-shadow: 0 6px 20px rgba(0,0,54,.08); }
.blog-more-card img { width: 100%; height: 130px; object-fit: cover; }
.blog-more-body { padding: .8rem .9rem; display: flex; flex-direction: column; gap: .3rem; }
.blog-more-topic { font-size: .7rem; text-transform: uppercase; letter-spacing: .05em; color: #FF5E84; font-weight: 600; }
.blog-more-title { font-size: .98rem; color: #000036; font-weight: 600; line-height: 1.3; }
.blog-more-date { font-size: .8rem; color: #999; }
</style>
