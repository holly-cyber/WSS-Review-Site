function yaml(s){return '"'+String(s==null?'':s).replace(/\\/g,'\\\\').replace(/"/g,'\\"').replace(/\n/g,' ').trim()+'"';}
function b64(str){return btoa(unescape(encodeURIComponent(str)));}
function catLabel(c){return({run:'Run',swim:'Swim',cycle:'Cycle',tri:'Tri','sports-bras':'Sports Bras',nutrition:'Nutrition'})[c]||'Apparel';}
function guessCategory(){
  const n=(val('pName')+' '+val('pSpecs')).toLowerCase();
  if(/bra|bras/.test(n))return'sports-bras';
  if(/swim|goggle|wetsuit|costume/.test(n))return'swim';
  if(/cycle|cycling|bike|jersey|bib/.test(n))return'cycle';
  if(/tri|trisuit|triathlon/.test(n))return'tri';
  return'run';
}
function extractPillarScores(review,pType){
  const areas=SCORE_AREAS[pType]||SCORE_AREAS.apparel;
  const scores={};
  areas.forEach(([key,label])=>{
    const frag=label.replace(/\s*\(\d+%\)\s*/,'').trim();
    const esc=s=>s.replace(/[-/\\^$*+?.()|[\]{}&]/g,'\\$&');
    let m=review.match(new RegExp(esc(frag)+'[^:\\n]*:\\s*(\\d)','i'));
    if(!m){const two=frag.split(/\s+/).slice(0,2).map(esc).join('\\s+');m=review.match(new RegExp(two+'[^:\\n]*:\\s*(\\d)','i'));}
    scores[key]=m?parseInt(m[1]):3;
  });
  return scores;
}

