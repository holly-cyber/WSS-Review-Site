    const list=Array.isArray(data)?data:(data.retailers||data.data||[]);
    state.retailers=list;
    if(!list.length){el.innerHTML='<div style="padding:10px;font-size:12px;color:#aaa">No approved retailers found.</div>';return}
    const opts=list.map((r,i)=>`<option value="${i}">${esc(r.name||r.retailerName||'Retailer '+i)} — ${esc(String(r.pk||r.id||r.slug||''))}</option>`).join('');
