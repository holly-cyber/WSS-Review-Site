---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReviewCard from '../../../components/ReviewCard.astro';
const category = 'nutrition';
const label = 'nutrition'.replace(/-/g,' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const mods = import.meta.glob('./*.md', { eager: true });
const sorted = Object.entries(mods)
  .map(([path, mod]: [string, any]) => ({
    ...mod.frontmatter,
    slug: path.split('/').pop()?.replace('.md','')
  }))
  .filter((r: any) => import.meta.env.PROD ? r.draft !== true : true)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
---
<BaseLayout title={`${label} Reviews — Women's Sports Standard™`} description={`Independent ${label.toLowerCase()} product reviews tested against the WSS™ framework.`}>
  <section class="cat-hero">
    <div class="container">
      <span class={`pill pill-nutrition`}>{label}</span>
      <h1>{label} Reviews</h1>
      <p>Every {label.toLowerCase()} product reviewed against the Women's Sports Standard™. Independent, honest, scored.</p>
    </div>
  </section>
  <section class="cat-reviews container">
    {sorted.length > 0 ? (
      <div class="reviews-grid">
        {sorted.map((r: any) => (
          <ReviewCard title={r.title} brand={r.brand} slug={r.slug} category={category} score={r.overall_score} excerpt={r.excerpt} image={r.hero_image} date={r.date} />
        ))}
      </div>
    ) : (
      <div class="empty"><p>Reviews coming soon. Check back shortly.</p></div>
    )}
  </section>
</BaseLayout>
<style>
.cat-hero{background:var(--navy);color:white;padding:3rem 0}
.cat-hero .pill{margin-bottom:1rem}
.cat-hero h1{font-size:2.25rem;color:white;margin-bottom:.75rem}
.cat-hero p{opacity:.7;max-width:520px}
.cat-reviews{padding:2.5rem 0 3rem}
.reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,300px),1fr));gap:1.5rem}
.empty{text-align:center;padding:3rem;color:var(--text-muted)}
</style>
