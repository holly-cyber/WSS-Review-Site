---
export const prerender = true;
import { taxonomy } from '../data/taxonomy.js';
import AuthGate from '../components/AuthGate.astro';
const categories = taxonomy.map((t) => t.slug);
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WSS™ Review Console</title>
<meta name="robots" content="noindex,nofollow"/>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style is:global>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Poppins',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f4f5f8;color:#111}
button{cursor:pointer;border:none;font-family:inherit;font-size:13px}
button:disabled{opacity:.45;cursor:not-allowed}
input,textarea,select{font-family:inherit;font-size:13px;border:1px solid #ddd;border-radius:7px;padding:8px 10px;width:100%;background:#fff;color:#111;outline:none}
input:focus,textarea:focus,select:focus{border-color:#FF5E84;box-shadow:0 0 0 3px rgba(255,94,132,.12)}
textarea{resize:vertical;line-height:1.6}
.bp{background:#FF5E84;color:#fff;padding:8px 16px;border-radius:7px;font-weight:600}
.bp:hover:not(:disabled){background:#e04470}
.bg{background:#fff;color:#555;border:1px solid #ddd;padding:7px 14px;border-radius:7px}
.bg:hover:not(:disabled){background:#f5f5f5}
.bdanger{color:#c00;border-color:#fcc}
.al{padding:9px 12px;border-radius:7px;font-size:12.5px;margin:8px 0}
.al.ok{background:#f0fff4;color:#0a7a33;border:1px solid #b6e8c4}
.al.er{background:#fff5f5;color:#c00;border:1px solid #fcc}
.al.inf{background:#f0f7ff;color:#1666c4;border:1px solid #bcd9f7}
.al.wr{background:#fffaf0;color:#8a5a00;border:1px solid #f3d9a3}

/* Shell */
.shell{display:flex;min-height:100vh}
.side{width:210px;flex-shrink:0;background:#000036;color:#fff;display:flex;flex-direction:column;padding:18px 12px;position:sticky;top:0;height:100vh}
.side .brand{font-weight:700;font-size:16px;padding:6px 10px 16px}
.side .brand small{display:block;font-weight:400;font-size:11px;opacity:.6;margin-top:2px}
.navbtn{display:flex;align-items:center;gap:9px;width:100%;text-align:left;background:transparent;color:#cfcfe6;padding:10px 12px;border-radius:8px;font-size:13.5px;font-weight:500}
.navbtn:hover{background:rgba(255,255,255,.08);color:#fff}
.navbtn.active{background:#FF5E84;color:#fff}
.side .spacer{flex:1}
.side .ext{color:#cfcfe6;font-size:12px;text-decoration:none;padding:8px 12px;border-radius:8px;display:block}
.side .ext:hover{background:rgba(255,255,255,.08);color:#fff}
.main{flex:1;min-width:0;padding:26px 30px}
.h1{font-size:22px;font-weight:700;color:#000036;margin-bottom:3px}
.sub{color:#777;font-size:13px;margin-bottom:18px}
.view{display:none}.view.active{display:block}

/* Dashboard */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:22px}
.card{background:#fff;border:1px solid #ececf1;border-radius:12px;padding:16px 18px}
.card .n{font-size:28px;font-weight:700;color:#000036}
.card .l{font-size:12px;color:#888;text-transform:uppercase;letter-spacing:.04em;margin-top:2px}
.catbars{background:#fff;border:1px solid #ececf1;border-radius:12px;padding:16px 18px}
.catrow{display:flex;align-items:center;gap:10px;margin:7px 0;font-size:13px}
.catrow .nm{width:120px;text-transform:capitalize;color:#444}
.catrow .bar{flex:1;height:9px;background:#f0f0f4;border-radius:5px;overflow:hidden}
.catrow .bar>span{display:block;height:100%;background:#FF5E84}
.catrow .ct{width:54px;text-align:right;color:#888}

/* Reviews table */
.filters{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
.filters input{max-width:280px}.filters select{max-width:190px}
table.rev{width:100%;border-collapse:collapse;background:#fff;border:1px solid #ececf1;border-radius:12px;overflow:hidden;font-size:13px}
table.rev th{text-align:left;background:#fafafb;color:#888;font-size:11px;text-transform:uppercase;letter-spacing:.04em;padding:10px 14px;border-bottom:1px solid #eee}
table.rev td{padding:10px 14px;border-bottom:1px solid #f1f1f4;vertical-align:middle}
table.rev tr:last-child td{border-bottom:0}
table.rev tr:hover td{background:#fcfcfd}
.tt{font-weight:600;color:#000036}
.ts{font-size:11.5px;color:#999}
.badge{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-radius:10px;padding:2px 8px}
.badge.draft{color:#8a5a00;background:#fffaf0;border:1px solid #f3d9a3}
.badge.live{color:#0a7a33;background:#f0fff4;border:1px solid #b6e8c4}
.rowacts{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap}
.rowacts button{padding:5px 10px;border-radius:6px;background:#fff;border:1px solid #e0e0e6;color:#555;font-size:12px}
.rowacts button:hover{background:#f5f5f8}
.rowacts button.danger{color:#c00;border-color:#fcc}

/* Editor */
.edbar{display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap}
.edbar .path{font-size:12px;color:#777}
.toggle{display:inline-flex;border:1px solid #ddd;border-radius:8px;overflow:hidden}
.toggle button{background:#f4f4f7;border-left:1px solid #ddd;padding:6px 13px;font-size:12px;font-weight:600;color:#555}
.toggle button:first-child{border-left:0}.toggle button.active{background:#000036;color:#fff}
#edSplit{display:flex;gap:14px;align-items:stretch}
#edSplit>textarea{flex:1 1 50%;min-width:0;font-family:ui-monospace,Menlo,monospace;font-size:12px;min-height:62vh}
#edPreview{flex:1 1 50%;min-width:0;max-height:74vh;overflow:auto;border:1px solid #e6e6ec;border-radius:12px;background:#fff}
#editor.view-md #edPreview{display:none}#editor.view-md #edBody{flex-basis:100%}
#editor.view-pv #edBody{display:none}#editor.view-pv #edPreview{flex-basis:100%}
@media(max-width:820px){#edSplit{flex-direction:column}}
.panel{background:#fff;border:1px solid #ececf1;border-radius:12px;padding:16px 18px;margin-top:16px}
.panel h3{font-size:14px;color:#000036;margin-bottom:4px}
.panel .hint{font-size:12px;color:#777;margin-bottom:10px;line-height:1.5}
.actbar{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.actbar .grouplbl{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#aaa;width:100%;margin-top:4px}
.chip{display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid #e0e0e6;color:#444;padding:7px 13px;border-radius:8px;font-size:12.5px;font-weight:600}
.chip:hover{background:#f6f6f9}.chip.danger{color:#c00;border-color:#fcc}
.chip.soon{opacity:.85}
.chip .tag{font-size:9px;font-weight:700;background:#eef;color:#3636a8;padding:1px 5px;border-radius:6px;text-transform:uppercase}
.igrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(96px,1fr));gap:8px;margin-top:10px}
.icard{position:relative;border:2px solid #eee;border-radius:8px;overflow:hidden;cursor:pointer;aspect-ratio:1}
.icard img{width:100%;height:100%;object-fit:cover}
.icard.sel{border-color:#FF5E84}
.icard.feat::after{content:'★ hero';position:absolute;top:4px;left:4px;background:#FF5E84;color:#fff;font-size:9px;font-weight:700;padding:1px 5px;border-radius:5px}
.icard .tick{position:absolute;top:4px;right:4px;width:18px;height:18px;border-radius:50%;background:#FF5E84;color:#fff;font-size:11px;display:none;align-items:center;justify-content:center}
.icard.sel .tick{display:flex}

/* Modal */
.ov{position:fixed;inset:0;background:rgba(0,0,20,.55);display:none;align-items:center;justify-content:center;padding:20px;z-index:80}
.ov.show{display:flex}
.mo{background:#fff;border-radius:14px;max-width:560px;width:100%;max-height:88vh;overflow:auto;padding:0}
.moh{display:flex;justify-content:space-between;align-items:center;background:#000036;color:#fff;padding:13px 18px;border-radius:14px 14px 0 0}
.moh .x{background:transparent;color:#fff;font-size:20px}
.mob{padding:18px}

/* Preview (matches the live review page) */
.pv-hero{background:#000036;color:#fff;padding:22px}
.pv-pill{display:inline-block;background:rgba(255,255,255,.15);color:#fff;font-size:11px;font-weight:600;text-transform:capitalize;padding:3px 10px;border-radius:999px;margin-bottom:8px}
.pv-title{font-size:23px;font-weight:700;margin:0 0 6px}
.pv-brand{font-size:13px;opacity:.75;margin-bottom:10px}
.pv-score{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.pv-score .overall-num{font-size:18px;font-weight:700}
.pv-badge{background:#FF5E84;color:#fff;font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px}
.pv-byline{display:flex;align-items:center;gap:9px;margin-top:12px;font-size:13px;opacity:.9}
.pv-byline img{width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid #FF5E84}
.pv-stars-wrap{position:relative;display:inline-block;white-space:nowrap;line-height:1;letter-spacing:.05em;font-size:18px}
.pv-stars-bg{color:rgba(255,255,255,.35)}
.pv-stars-fg{position:absolute;top:0;left:0;overflow:hidden;color:#FF5E84;width:0}
.pv-content{padding:22px;font-size:15px;line-height:1.7;color:#374151}
.pv-content h2{font-size:20px;color:#000036;margin:1.5rem 0 .5rem}
.pv-content h3{font-size:16px;color:#000036;margin:1.1rem 0 .35rem}
.pv-content h2:first-child,.pv-content h3:first-child{margin-top:0}
.pv-content p{margin:0 0 .8rem}.pv-content strong{color:#111827}
.pv-content a{color:#FF5E84;text-decoration:underline}
.pv-content ul,.pv-content ol{margin:0 0 1rem 1.25rem}.pv-content li{margin-bottom:.35rem}
.pv-content img{width:100%;border-radius:10px;margin:1.2rem 0}
.pv-content blockquote{border-left:3px solid #FF5E84;background:#fff0f4;border-radius:0 6px 6px 0;padding:.7rem 1.1rem;margin:1.1rem 0;font-style:italic}
.pv-content table{width:100%;border-collapse:collapse;font-size:13.5px;border:1px solid #eee;border-radius:8px;overflow:hidden;margin:1.2rem 0}
.pv-content thead{background:#000036}.pv-content th{color:#fff;text-align:left;padding:.6rem .8rem;font-size:12px;text-transform:uppercase}
.pv-content td{padding:.6rem .8rem;border-top:1px solid #eee}.pv-content tbody tr:nth-child(odd){background:#fafafa}
.pv-content tbody tr:first-child{background:#fff0f4}.pv-content tbody tr:first-child td{font-weight:600;color:#111827}
.pv-cta{display:flex;gap:.6rem;flex-wrap:wrap;margin:1.6rem 0 1rem}
.pv-content .pv-buy{display:inline-flex;align-items:center;background:#FF5E84;color:#fff;font-weight:700;padding:.7rem 1.3rem;border-radius:8px}
.pv-content .pv-buy.alt{background:#000036}
.pv-reviewer{display:flex;gap:1rem;align-items:center;background:#f7f7f7;border:1px solid #eee;border-radius:10px;padding:1.1rem;margin:1.3rem 0 .3rem}
.pv-reviewer img{width:54px;height:54px;border-radius:50%;object-fit:cover;border:2px solid #FF5E84;flex-shrink:0}
.pv-reviewer .lbl{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:#9ca3af}
.pv-reviewer .nm{font-weight:700;color:#000036}.pv-reviewer .bio{font-size:.85rem;color:#555;margin:.3rem 0 0;line-height:1.5}
</style>
<script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
<AuthGate>
  <div class="shell">
    <nav class="side">
      <div class="brand">WSS™ Console<small>Review management</small></div>
      <button class="navbtn active" data-nav="dashboard">▥ Dashboard</button>
      <button class="navbtn" data-nav="reviews">▤ Reviews</button>
      <button class="navbtn" data-nav="news">📰 News</button>
      <button class="navbtn" data-nav="social">✦ Social &amp; outbound</button>
      <div class="spacer"></div>
      <a class="ext" href="/reviews/" target="_blank">🌐 View review site ↗</a>
      <a class="ext" href="/pipeline" target="_blank">＋ New review (pipeline) ↗</a>
      <div style="font-size:11px;color:#5b5b7a;margin-top:10px;letter-spacing:.04em">build r5 · 2026-06-24</div>
    </nav>
    <main class="main">
      <!-- Dashboard -->
      <section id="view-dashboard" class="view active">
        <div class="h1">Dashboard</div>
        <div class="sub">Overview of every review in the site.</div>
        <div id="dashAlert"></div>
        <div class="cards" id="dashCards"></div>
        <div class="catbars" id="dashCats"><p style="color:#999;font-size:13px">Loading…</p></div>
      </section>

      <!-- Reviews -->
      <section id="view-reviews" class="view">
        <div class="h1">Reviews</div>
        <div class="sub">Edit, publish, preview and act on any review.</div>
        <div id="revAlert"></div>
        <div class="filters">
          <input id="fSearch" placeholder="Search title or slug…"/>
          <select id="fCat"><option value="">All categories</option>{categories.map((c) => <option value={c}>{c}</option>)}</select>
          <select id="fStatus"><option value="">All statuses</option><option value="draft">Draft</option><option value="live">Live</option></select>
          <button class="bg" id="fReload">↻ Reload</button>
        </div>
        <table class="rev"><thead><tr><th>Review</th><th>Category</th><th>Reviewer</th><th>Score</th><th>Status</th><th></th></tr></thead><tbody id="revBody"><tr><td colspan="6" style="color:#999;padding:16px">Loading…</td></tr></tbody></table>
      </section>

      <!-- Editor -->
      <section id="view-editor" class="view">
        <div id="editor" class="view-split">
          <div class="edbar">
            <button class="bg" id="edBack">← Reviews</button>
            <span class="path" id="edPath"></span>
            <span class="toggle" id="edToggle" style="margin-left:auto">
              <button data-view="md">Markdown</button>
              <button data-view="split" class="active">Split</button>
              <button data-view="pv">Preview</button>
            </span>
          </div>
          <div id="edAlert"></div>
          <div id="edSplit">
            <textarea id="edBody" spellcheck="false"></textarea>
            <div id="edPreview"></div>
          </div>
          <div class="edbar" style="margin-top:10px">
            <button class="bp" id="edSave">Save changes</button>
            <button class="bg" id="edDraft">Set draft</button>
            <a class="bg" id="edView" target="_blank">View live ↗</a>
            <button class="bg bdanger" id="edDelete" style="margin-left:auto">Delete</button>
          </div>

          <!-- Reviewer -->
          <div class="panel" id="edReviewerPanel">
            <h3>Reviewer</h3>
            <div class="hint">Change who this review is attributed to. Updates the byline name, photo and bio from the team profile and clears any per-article overrides. Save to commit.</div>
            <select id="edReviewer" style="max-width:340px"></select>
          </div>

          <!-- Images -->
          <div class="panel" id="edImages">
            <h3>Images</h3>
            <div class="hint">Pull product images from a page URL (pre-filled from the review's buy link) or paste a direct image URL. First selected is the hero; the rest spread through the article. Insert writes them into the markdown above, then Save.</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
              <input id="edImgUrl" style="flex:1;min-width:240px" placeholder="https://retailer.com/products/…"/>
              <button class="bg" id="edFind">Find images</button>
              <button class="bp" id="edInsert" disabled>Insert selected →</button>
            </div>
            <div id="edImgAlert"></div>
            <div class="igrid" id="edImgGrid"></div>
            <div id="edImgStatus" style="font-size:12px;color:#888;margin-top:8px;font-weight:600"></div>
            <div style="margin-top:8px"><input id="edImgPaste" placeholder="…or paste a direct image URL (.jpg/.png) and press Enter"/></div>
          </div>

          <!-- Actions -->
          <div class="panel">
            <h3>Actions</h3>
            <div class="hint">Run an action on this review. Social &amp; outbound actions are wired into the console and activate as each integration is configured.</div>
            <div class="actbar" id="edActions"></div>
          </div>
        </div>
      </section>

      <!-- News -->
      <section id="view-news" class="view">
        <div class="h1">News</div>
        <div class="sub">Manage your news articles, and generate new ones from your RSS feeds.</div>
        <div class="nw-tabbar">
          <button class="nw-tab active" data-nwtab="drafts" type="button">📝 Drafts <span class="nw-tabcount" id="nwCountDrafts"></span></button>
          <button class="nw-tab" data-nwtab="published" type="button">✅ Published <span class="nw-tabcount" id="nwCountPublished"></span></button>
          <button class="nw-tab" data-nwtab="generate" type="button">✦ Generate</button>
        </div>
        <div id="newsAlert"></div>
        <div id="nwLibAlert"></div>

        <div id="nwtab-drafts" class="nwtab">
        <div class="panel">
          <h3>Draft articles <button class="bg" id="nwLibReload" style="font-weight:400;font-size:12px;padding:3px 9px;margin-left:6px">↻ Reload</button></h3>
          <div class="hint">Hidden from the live site until you publish them.</div>
          <div id="nwLibDrafts"><p style="color:#999;font-size:13px;padding:4px">Loading…</p></div>
        </div>
        </div><!-- /nwtab-drafts -->

        <div id="nwtab-published" class="nwtab" hidden>
        <div class="panel">
          <h3>Published articles <button class="bg" id="nwLibReload2" style="font-weight:400;font-size:12px;padding:3px 9px;margin-left:6px">↻ Reload</button></h3>
          <div class="hint">Live on the site at <code>/news/</code>.</div>
          <div id="nwLibPublished"><p style="color:#999;font-size:13px;padding:4px">Loading…</p></div>
        </div>
        </div><!-- /nwtab-published -->

        <div id="nwtab-generate" class="nwtab" hidden>
        <h3 class="nw-gen-h">Generate a new article</h3>

        <details class="nw-feeds" id="nwFeedsBox">
          <summary>RSS feeds <span class="nw-tabcount" id="nwFeedsCount"></span></summary>
          <div class="hint">Sources pulled when you refresh. Add or remove feeds — changes are saved to <code>src/data/feeds.json</code> in the repo.</div>
          <div id="nwFeedsAlert"></div>
          <div id="nwFeedsList"><p class="nw-lib-empty">Loading…</p></div>
          <div class="nw-feed-add">
            <input id="nwFeedName" placeholder="Name (e.g. Women's Running)"/>
            <input id="nwFeedUrl" placeholder="Feed URL — https://…/feed/ (RSS or Atom)"/>
            <input id="nwFeedTag" placeholder="Tag (optional)"/>
            <button class="bp" id="nwFeedAdd">Add feed</button>
          </div>
        </details>

        <div class="filters">
          <button class="bp" id="nwRefresh">↻ Refresh feeds</button>
          <button class="bg" id="nwSelClear">Clear selection</button>
          <span id="nwFeedStatus" style="font-size:12px;color:#888;align-self:center"></span>
        </div>
        <div id="nwFilterBar" class="nw-filterbar" style="display:none">
          <input id="nwSearch" placeholder="🔎 Find stories by keyword…"/>
          <div id="nwTags" class="nw-tags"></div>
        </div>
        <div id="nwItems" class="nw-items"><p style="color:#999;font-size:13px;padding:8px">Click <strong>Refresh feeds</strong> to pull the latest stories from your RSS feeds.</p></div>

        <div class="panel" id="nwComposePanel" style="display:none">
          <h3>Draft article <span style="font-weight:400;color:#999">— <span id="nwSelCount">0</span> selected · <span id="nwMode">—</span></span></h3>
          <div class="hint">Every article is written fully in original wording under strict legal/originality rules (no copied phrasing, no fabricated facts, sources attributed &amp; linked) and auto-checked for verbatim overlap. Add an optional angle, pick an author, then generate.</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:8px">
            <input id="nwAngle" style="flex:1;min-width:240px" placeholder="Optional angle (e.g. UK perspective; tie to training; keep it upbeat)"/>
            <select id="nwAuthor" style="max-width:220px"></select>
          </div>
          <button class="bp" id="nwGenerate" disabled>✦ Generate draft</button>
        </div>

        <div class="panel" id="nwOutPanel" style="display:none">
          <h3>Generated article</h3>
          <div class="nw-meta">
            <label>Headline<input id="nwTitle"/></label>
            <label>URL slug<input id="nwSlug"/></label>
            <label>Topic<input id="nwTopic"/></label>
            <label>Hero image<span class="nw-hero-row"><input id="nwHero" placeholder="https://… paste, Find from source, or search free photos"/><button type="button" class="bg" id="nwHeroFind">Find</button></span></label>
          </div>
          <div class="nw-hero-row" style="margin-bottom:6px">
            <input id="nwStockQuery" placeholder="🔍 Search rights-free photos (e.g. women running, swimming)"/>
            <button type="button" class="bp" id="nwStockSearch">Free photos</button>
          </div>
          <div id="nwHeroGrid" class="nw-hero-grid"></div>
          <div id="nwHeroNote" class="hint" style="display:none"></div>
          <div id="nwSplit" class="nw-split">
            <textarea id="nwBody" spellcheck="false"></textarea>
            <div id="nwPreview" class="nw-preview"></div>
          </div>
          <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
            <button class="bp" id="nwPush">Push as draft →</button>
            <button class="bg" id="nwRegen">↻ Regenerate</button>
            <button class="bg" id="nwRecheck">✓ Check originality</button>
            <a class="bg" id="nwView" target="_blank" rel="noopener" style="display:none">View ↗</a>
          </div>
          <div id="nwPushAlert"></div>
        </div>
        </div><!-- /nwtab-generate -->
      </section>

      <!-- Social -->
      <section id="view-social" class="view">
        <div class="h1">Social &amp; outbound</div>
        <div class="sub">Distribution channels for published reviews. Each becomes available from a review's Actions panel once configured.</div>
        <div class="cards" id="socialCards"></div>
      </section>
    </main>
  </div>

  <!-- Integration modal -->
  <div class="ov" id="intgOv"><div class="mo"><div class="moh"><div id="intgTitle">Integration</div><button class="x" id="intgClose">×</button></div><div class="mob" id="intgBody"></div></div></div>
