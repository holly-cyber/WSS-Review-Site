// Customer reviews
async function fetchCustomerReviews(url,name,brand){
  const el=document.getElementById('reviewsOut');
  el.innerHTML='<div class="out empty">Searching for customer reviews…</div>';
  try{
    const u=new URL(url);
    const handle=u.pathname.split('/').filter(Boolean).pop();
    try{
      const r=await fetch(`https://judge.me/api/v1/reviews?shop_domain=${u.hostname}&handle=${handle}&per_page=20`);
      if(r.ok){const d=await r.json();if(d.reviews&&d.reviews.length){state.customerReviews=d.reviews.slice(0,8).map(rv=>({rating:rv.rating,text:(rv.body||'').slice(0,250),author:rv.reviewer?.name||'Verified buyer',source:'Judge.me'}));renderReviews();return;}}
    }catch{}
    const text=await aiCall([{role:'user',content:`Find and summarise customer reviews of ${brand} ${name}. URL: ${url}\n1. Overall sentiment\n2. 5 most useful reviews with rating and key finding\n3. Common complaints\n4. Common praise\n5. Fit or performance issues relevant to WSS pillars\nBe honest about limitations. British English.`}],'WSS research analyst. Summarise customer sentiment accurately. British English.');
    state.customerReviews=[{text}];
    el.innerHTML=`<div class="out">${esc(text)}</div>`;
  }catch(e){el.innerHTML=`<div class="out empty">Could not retrieve reviews: ${esc(e.message)}</div>`;}
}
function renderReviews(){
  const el=document.getElementById('reviewsOut');
  if(!state.customerReviews.length){el.innerHTML='<div class="out empty">No reviews found.</div>';return}
  if(!state.customerReviews[0].rating){el.innerHTML=`<div class="out">${esc(state.customerReviews[0].text)}</div>`;return}
  el.innerHTML=state.customerReviews.map(r=>`<div class="rv"><div class="rstar">${'★'.repeat(r.rating||5)}${'☆'.repeat(5-(r.rating||5))}</div><div>${esc(r.text)}</div><div class="rauth">${esc(r.author)}${r.source?' · '+r.source:''}</div></div>`).join('');
}

// Images
async function fetchImages(url){
  const el=document.getElementById('imageGrid');
  el.innerHTML='<p style="font-size:12px;color:#aaa">Fetching images…</p>';
  try{
    const result=await aiCall([{role:'user',content:`List significant product images from: ${url}\nReturn JSON array: [{url,type,alt}]. Include og:image and main product images. Exclude icons/logos/tiny UI.\nRaw JSON only.`}],'Image extraction. Return only valid JSON array.');
    const imgs=JSON.parse(result.trim().replace(/^```json\n?/,'').replace(/^```\n?/,'').replace(/\n?```$/,'').trim());
    state.allImages=imgs;renderImages(imgs);
  }catch{
    try{
      const r=await fetch(url);const html=await r.text();
      const matches=[...html.matchAll(/og:image.*?content=["']([^"']+)["']/gi)];
      const found=matches.map(m=>({url:m[1],type:'hero',alt:'Product image'}));
      state.allImages=found.slice(0,8);
      if(found.length)renderImages(state.allImages);
      else el.innerHTML='<p style="font-size:12px;color:#aaa">No images found. You can proceed without images.</p>';
    }catch{el.innerHTML='<p style="font-size:12px;color:#aaa">Could not fetch images. Proceed without them.</p>';}
  }
}
function renderImages(imgs){
  const el=document.getElementById('imageGrid');
  if(!imgs.length){el.innerHTML='<p style="font-size:12px;color:#aaa">No images found.</p>';return}
  el.innerHTML=imgs.map((img,i)=>`<div class="icard" id="icard${i}" data-img="${i}"><img src="${esc(img.url)}" alt="${esc(img.alt||'')}" onerror="this.parentElement.style.display='none'"/><div class="itype">${esc(img.type||'product')}</div><div class="itick">✓</div></div>`).join('');
  el.addEventListener('click',e=>{const c=e.target.closest('.icard');if(c)toggleImg(parseInt(c.dataset.img))});
  const heroIdx=imgs.findIndex(i=>i.type==='hero');
  if(imgs.length)toggleImg(heroIdx>=0?heroIdx:0);
}
function toggleImg(i){
  const c=document.getElementById('icard'+i);if(!c)return;
  const idx=state.selectedImages.indexOf(i);
  if(idx>=0){state.selectedImages.splice(idx,1);c.classList.remove('sel')}
  else{state.selectedImages.push(i);c.classList.add('sel')}
}

