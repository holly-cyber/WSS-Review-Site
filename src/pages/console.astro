// --- News article library: existing drafts + published, with manage actions ---
let nwLib=[];
let nwUsedLinks=new Set();  // source URLs already used by an existing article
const normLink=(u)=>String(u||'').trim().toLowerCase().replace(/^https?:\/\//,'').replace(/^www\./,'').replace(/\/+$/,'');
$('nwLibReload').addEventListener('click',loadNwLib);
async function loadNwLib(){
  $('nwLibDrafts').innerHTML=$('nwLibPublished').innerHTML='<p style="color:#999;font-size:13px;padding:4px">Loading…</p>';
  setNwLibAlert('','');
  try{
    const d=await ghApi('tree',{});
    const files=(d.tree||[]).filter(t=>t.type==='blob'&&/^src\/pages\/news\/.+\.md$/.test(t.path));
    nwLib=files.map(t=>({path:t.path,slug:t.path.split('/').pop().replace('.md',''),sha:'',content:'',draft:false}));
    await Promise.all(nwLib.map(async f=>{
      try{ const g=await ghApi('get',{path:f.path}); f.sha=g.sha; f.content=b64decode(g.content);
        const {fm}=splitFrontmatter(f.content);
        f.title=fmField(fm,'title')||f.slug; f.date=fmField(fm,'date'); f.author=fmField(fm,'author'); f.draft=isDraft(f.content);
      }catch(_){ }
    }));
    // Collect every source URL we've already used, so feeds can skip them.
    nwUsedLinks=new Set();
    for(const f of nwLib){ try{ for(const s of parseNwSources(splitFrontmatter(f.content).fm)) if(s.link) nwUsedLinks.add(normLink(s.link)); }catch(_){ } }
    renderNwLib(); renderDashboard();
  }catch(e){ $('nwLibDrafts').innerHTML=$('nwLibPublished').innerHTML=`<p style="color:#c00;font-size:13px;padding:4px">Could not load: ${esc(e.message)}</p>`; }
}
function setNwLibAlert(type,msg){ $('nwLibAlert').innerHTML=msg?`<div class="al ${type}">${msg}</div>`:''; }
