    const g=await ghApi('get',{path:f.path}); await ghApi('delete',{path:f.path,message:`Delete news: ${f.path}`,sha:g.sha});
    nwLib=nwLib.filter(x=>x.path!==f.path); renderNwLib(); setNwLibAlert('ok','Deleted ✓ Disappears on the next deploy.');
