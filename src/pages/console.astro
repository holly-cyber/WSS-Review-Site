// Originality guard: warn if the draft shares any verbatim 6+ word run with a source.
function nwCheckOriginality(text,items){
  if(!items||!items.length){ alert('nwPushAlert','inf','No linked sources to compare against — originality check skipped.'); return; }
  const hits=sourceOverlap(text,items,6);
  if(hits.length){
    const shown=hits.slice(0,3).map(h=>`“${esc(h)}”`).join(', ');
    alert('nwPushAlert','wr',`⚠ Originality check: reuses wording from the source — ${shown}${hits.length>3?` and ${hits.length-3} more`:''}. Edit those phrases or click <strong>Regenerate</strong> before publishing.`);
  } else {
    alert('nwPushAlert','ok','✓ Originality check passed — no verbatim phrasing (6+ words) shared with the source.');
  }
}

async function generateNews(){
  if(!nwSel.length) return;
  nwEditPath=''; nwEditDate=''; nwEditSources=null; $('nwSlug').readOnly=false; $('nwPush').textContent='Push as draft →';
  const items=nwSel.map(i=>nwAllItems[i]).filter(Boolean);
  nwLastItems=items;
  const btn=$('nwGenerate'), rbtn=$('nwRegen');
  btn.disabled=true; rbtn.disabled=true; btn.textContent='Generating…';
  $('nwOutPanel').style.display='block';
  $('nwBody').value=''; $('nwPreview').innerHTML='<p style="padding:12px;color:#999">Writing…</p>';
  $('nwView').style.display='none'; alert('nwPushAlert','','');
  nwHeroImgs=[]; nwHeroCredit=''; $('nwHeroGrid').innerHTML=''; $('nwHero').value=''; $('nwStockQuery').value=''; $('nwHeroNote').style.display='none';
  try{
    alert('nwPushAlert','inf','Fetching source articles for context & the originality check…');
    await nwAttachFullText(items);
    const text=await aiStream({
      system:NEWS_SYSTEM,
      messages:[{role:'user',content:buildNewsPrompt(items,$('nwAngle').value.trim())}],
      max_tokens:1800,
      onText:(t)=>{ $('nwBody').value=t; },
    });
    const {title,body}=splitHeadline(text);
    $('nwTitle').value=title||'Untitled article';
    $('nwSlug').value=slugify(title||'news-article');
    $('nwBody').value=body;
    if(!$('nwTopic').value) $('nwTopic').value=(items[0]&&items[0].tag)||"Women's Sport";
    renderNwPreview();
    await nwEnforceOriginality(items);
    nwAutoHero(items);
  }catch(e){ $('nwPreview').innerHTML=''; alert('newsAlert','er','Generation failed: '+e.message); }
  btn.disabled=nwSel.length===0; rbtn.disabled=false; btn.textContent='✦ Generate draft';
}

// Fetch the full text of each source (best-effort) so the model has the real
// article as reference and the originality check compares against it, not the
// short RSS summary. Attaches it.fulltext; silently falls back on failure.
async function nwAttachFullText(items){
  const urls=(items||[]).map(it=>it.link).filter(Boolean);
  if(!urls.length) return;
  try{
    const r=await fetch('/api/article-text',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({urls})});
    const d=await r.json().catch(()=>({}));
    const map={}; (d.results||[]).forEach(x=>{ if(x&&x.ok&&x.text) map[x.url]=x.text; });
    items.forEach(it=>{ if(map[it.link]) it.fulltext=map[it.link]; });
  }catch(_){ /* best-effort */ }
}

// Editor pass: re-check the draft against the source full text and, while
// verbatim overlaps remain, ask the model to rewrite the flagged passages.
// Up to 2 rewrites, then report the final status by the buttons.
async function nwEnforceOriginality(items){
  for(let pass=0;;){
    const hits=sourceOverlap($('nwTitle').value+'\n'+$('nwBody').value,items,6);
    if(!hits.length){ alert('nwPushAlert','ok',`✓ Originality check passed${pass?` after ${pass} editor pass${pass>1?'es':''}`:''} — no verbatim phrasing (6+ words) shared with the source.`); return; }
    if(pass>=2){ const shown=hits.slice(0,3).map(h=>`“${esc(h)}”`).join(', '); alert('nwPushAlert','wr',`⚠ ${hits.length} phrase(s) still overlap the source after ${pass} rewrites: ${shown}. Edit those manually or Regenerate.`); return; }
    pass++;
    alert('nwPushAlert','inf',`Editor pass ${pass}: rewriting ${hits.length} flagged passage(s) for originality…`);
    const current=`# ${$('nwTitle').value}\n\n${$('nwBody').value}`;
    const rew=await aiStream({ system:NEWS_SYSTEM, messages:[{role:'user',content:buildRewritePrompt(current,hits)}], max_tokens:1800, onText:(t)=>{ $('nwBody').value=t; } });
    const {title,body}=splitHeadline(rew);
    if(title) $('nwTitle').value=title;
    $('nwBody').value=body; renderNwPreview();
  }
}

function splitHeadline(md){
  const m=(md||'').match(/^\s*#\s+(.+?)\s*$/m);
  if(!m) return { title:'', body:(md||'').trim() };
  return { title:m[1].trim(), body:(md.slice(0,m.index)+md.slice(m.index+m[0].length)).replace(/^\s+/,'').trim() };
}
function deriveExcerpt(body){
  const line=(body||'').split('\n').map(s=>s.trim()).find(s=>s && !/^[#>!|]/.test(s) && !/^[-*]\s/.test(s));
  return (line||'').replace(/\*\*?|`/g,'').replace(/\[([^\]]+)\]\([^)]*\)/g,'$1').slice(0,180);
}
function renderNwPreview(){
  const hero=$('nwHero').value.trim();
  $('nwPreview').innerHTML=`<div class="pv-content" style="padding:16px">${hero?`<img src="${esc(hero)}" style="width:100%;border-radius:8px;margin-bottom:12px" alt=""/>`:''}<h1 style="font-size:22px;color:#000036;margin:0 0 10px;line-height:1.2">${esc($('nwTitle').value||'Untitled')}</h1>${mdToHtml($('nwBody').value)}</div>`;
}
let nwPvT=null;
['nwBody','nwTitle'].forEach(id=>$(id).addEventListener('input',()=>{clearTimeout(nwPvT);nwPvT=setTimeout(renderNwPreview,250);}));
$('nwSlug').addEventListener('input',()=>{ $('nwSlug').value=slugify($('nwSlug').value); });

// --- Hero image: scrape from the source OR search a rights-free photo engine ---
let nwHeroImgs=[], nwHeroCredit='';
function heroUrl(u){ return (u&&u.url)||u||''; }
function heroThumb(u){ return (u&&u.thumb)||heroUrl(u); }
function nwHeroNote(msg){ const n=$('nwHeroNote'); n.innerHTML=msg||''; n.style.display=msg?'block':'none'; }

$('nwHeroFind').addEventListener('click',()=>{ const items=nwSel.map(i=>nwAllItems[i]).filter(Boolean); nwFindHero($('nwHero').value.trim()||(items[0]&&items[0].link),true); });
async function nwAutoHero(items){ const url=items[0]&&items[0].link; if(url) await nwFindHero(url,false); }
async function nwFindHero(url,manual){
  if(!/^https?:\/\//i.test(url||'')){ if(manual) alert('nwPushAlert','inf','No source URL to scrape — search free photos or paste an image URL instead.'); return; }
  const btn=$('nwHeroFind'); btn.disabled=true; btn.textContent='Finding…';
  try{
    const imgs=await scrapeImages(url);
    nwHeroImgs=(imgs||[]).slice(0,8);
    if(nwHeroImgs.length){ if(!$('nwHero').value.trim()){ nwHeroCredit=''; selectHero(0); } renderNwHeroGrid(); nwHeroNote('⚠ These are scraped from the source page — they may be rights-reserved. Prefer the <strong>Free photos</strong> search, or paste your own URL.'); }
    else if(manual) alert('nwPushAlert','wr','No images on that page — try the Free photos search or paste a direct image URL.');
  }catch(e){ if(manual) alert('nwPushAlert','er','Image search failed: '+e.message); }
  btn.disabled=false; btn.textContent='Find';
}
// Rights-free stock search (Openverse CC0/PD by default, or a keyed provider).
$('nwStockSearch').addEventListener('click',nwSearchStock);
$('nwStockQuery').addEventListener('keydown',e=>{ if(e.key==='Enter'){ e.preventDefault(); nwSearchStock(); } });
async function nwSearchStock(){
  const q=($('nwStockQuery').value||'').trim()||($('nwTopic').value||'').trim()||($('nwTitle').value||'').trim();
  if(!q){ alert('nwPushAlert','inf','Type what to search for (e.g. women running).'); return; }
  const btn=$('nwStockSearch'); btn.disabled=true; btn.textContent='Searching…';
  try{
    const r=await fetch('/api/stock-photo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:q})});
    const d=await r.json().catch(()=>({}));
    nwHeroImgs=(d.images||[]);
    if(nwHeroImgs.length){ renderNwHeroGrid(); nwHeroNote(`Rights-free results via <strong>${esc(d.provider||'stock')}</strong> — free for commercial use. Click one to set it as the hero.`); }
    else { renderNwHeroGrid(); nwHeroNote('No rights-free photos found for that search — try different keywords.'); }
  }catch(e){ alert('nwPushAlert','er','Photo search failed: '+e.message); }
  btn.disabled=false; btn.textContent='Free photos';
}
function selectHero(i){ if(i<0||i>=nwHeroImgs.length) return; const u=nwHeroImgs[i]; $('nwHero').value=heroUrl(u); nwHeroCredit=(u&&u.credit)||''; renderNwHeroGrid(); renderNwPreview(); }
function renderNwHeroGrid(){ const cur=$('nwHero').value.trim(); $('nwHeroGrid').innerHTML=nwHeroImgs.map((u,i)=>`<img src="${esc(heroThumb(u))}" data-i="${i}" class="${heroUrl(u)===cur?'sel':''}" title="${esc((u&&u.credit)||'')}" loading="lazy" alt=""/>`).join(''); }
$('nwHeroGrid').addEventListener('click',e=>{ const im=e.target.closest('[data-i]'); if(im) selectHero(parseInt(im.dataset.i)); });
$('nwHeroGrid').addEventListener('error',e=>{ if(e.target.tagName==='IMG') e.target.style.display='none'; },true);
$('nwHero').addEventListener('input',()=>{ nwHeroCredit=''; renderNwHeroGrid(); clearTimeout(nwPvT); nwPvT=setTimeout(renderNwPreview,250); });

function yamlStr(s){ return '"'+String(s||'').replace(/\\/g,'\\\\').replace(/"/g,'\\"')+'"'; }
// Download an external hero image (server-side) and commit it into the repo,
// returning the local /images/news/<slug>.<ext> path.
async function nwHostHeroImage(url,slug){
  const r=await fetch('/api/image-fetch',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({url})});
  const d=await r.json().catch(()=>({}));
  if(!d||!d.ok||!d.base64) throw new Error((d&&d.error)||'fetch failed');
  const ext=String(d.ext||'jpg').replace(/[^a-z0-9]/gi,'')||'jpg';
  const path=`public/images/news/${slug}.${ext}`;
  let sha; try{ const g=await ghApi('get',{path}); sha=g.sha; }catch(_){ }
  await ghApi('put',{path,content:d.base64,message:`Add news hero image: ${path}`,...(sha?{sha}:{})});
  return `/images/news/${slug}.${ext}`;
}
async function pushNews(){
  const title=$('nwTitle').value.trim(), slug=slugify($('nwSlug').value||title), body=$('nwBody').value.trim();
  if(!title||!slug||!body){ alert('nwPushAlert','er','Headline, slug and body are all required.'); return; }
  const editing=!!nwEditPath;
  const path=editing?nwEditPath:`src/pages/news/${slug}.md`;
  const btn=$('nwPush'); btn.disabled=true; btn.textContent=editing?'Saving…':'Pushing…'; alert('nwPushAlert','inf',(editing?'Saving ':'Pushing ')+path+'…');
  try{
    let sha, keepDraft=true;
    try{ const g=await ghApi('get',{path}); sha=g.sha; if(editing) keepDraft=isDraft(b64decode(g.content)); }catch(_){}
    const items=nwSel.map(i=>nwAllItems[i]).filter(Boolean);
    const srcItems=editing?(nwEditSources||[]):items.map(it=>({title:it.title,link:it.link}));
    const date=(editing&&nwEditDate)?nwEditDate:new Date().toISOString().slice(0,10);
    const excerpt=deriveExcerpt(body);
    const sourcesYaml=srcItems.length?('sources:\n'+srcItems.map(it=>`  - title: ${yamlStr(it.title)}\n    url: ${yamlStr(it.link)}`).join('\n')+'\n'):'';
    // Self-host an external hero image into the repo so we don't hotlink the CDN.
    let hero=$('nwHero').value.trim();
    if(/^https?:\/\//i.test(hero)){
      alert('nwPushAlert','inf','Saving hero image into the repo…');
      try{ const local=await nwHostHeroImage(hero,slug); if(local) hero=local; }
      catch(e){ alert('nwPushAlert','wr','Could not self-host the hero image ('+e.message+') — keeping the external URL.'); }
    }
    const fm=`---\nlayout: "../../layouts/NewsLayout.astro"\ntitle: ${yamlStr(title)}\ntopic: ${yamlStr($('nwTopic').value.trim()||"Women's Sport")}\ndate: ${yamlStr(date)}\nauthor: ${yamlStr($('nwAuthor').value||(team[0]&&team[0].name)||'')}\nexcerpt: ${yamlStr(excerpt)}\nmeta_description: ${yamlStr(excerpt)}\nhero_image: ${yamlStr(hero)}\nhero_credit: ${yamlStr(nwHeroCredit)}\ndraft: ${keepDraft?'true':'false'}\n${sourcesYaml}---\n\n${body}\n`;
    await ghApi('put',{path,content:b64(fm),message:`${editing?'Edit':'Add'} news article: ${path}`,...(sha?{sha}:{})});
    alert('nwPushAlert','ok',`${editing?'Saved':'Pushed'} ✓ ${keepDraft?'Draft':'Published'} — builds on the next deploy${keepDraft&&!editing?'. Publish it from the list above.':'.'}`);
    $('nwView').href=`/news/${slug}/`; $('nwView').style.display='inline-block';
    nwLibLoaded=true; loadNwLib();
  }catch(e){ alert('nwPushAlert','er','Push failed: '+e.message); }
  btn.disabled=false; btn.textContent=nwEditPath?'Save changes →':'Push as draft →';
}
$('nwPush').addEventListener('click',pushNews);
$('nwRecheck').addEventListener('click',async()=>{
  const btn=$('nwRecheck'); btn.disabled=true; btn.textContent='Checking…';
  alert('nwPushAlert','inf','Fetching source articles for the originality check…');
  try{ await nwAttachFullText(nwLastItems); }catch(_){}
  nwCheckOriginality($('nwTitle').value+'\n'+$('nwBody').value,nwLastItems);
  btn.disabled=false; btn.textContent='✓ Check originality';
});

loadAll();
nwLibLoaded=true; loadNwLib();  // also drives the dashboard "News articles" count
loadNwFeeds();                  // pull the managed feed list from the repo
</script>
</body>
</html>
