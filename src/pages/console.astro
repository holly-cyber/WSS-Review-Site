function productName(){ const {fm}=splitFrontmatter($('edBody').value); const b=fmField(fm,'brand'),t=fmField(fm,'title'); return (b&&t&&!t.toLowerCase().startsWith(b.toLowerCase()))?(b+' '+t):(t||b||'Product image'); }
function imgStatus(){ const n=sel.length; $('edImgStatus').textContent=n?`${n}/4 selected · first is the hero, the rest spread through the article`:'No images selected — click thumbnails, or paste a URL.'; $('edImgStatus').style.color=n?'#060':'#888'; $('edInsert').disabled=!n; }
function renderImgGrid(){ $('edImgGrid').innerHTML=imgs.map((im,i)=>`<div class="icard${sel.includes(i)?' sel':''}${sel[0]===i?' feat':''}" data-i="${i}"><img src="${esc(im.url||im)}" loading="lazy" alt=""/><div class="tick">✓</div></div>`).join(''); $('edImgGrid').querySelectorAll('img').forEach(im=>im.addEventListener('error',()=>{const c=im.closest('.icard');if(c)c.style.opacity='.25';})); imgStatus(); }
async function findImages(){
  const src=($('edImgUrl').value||'').trim();
  if(!/^https?:\/\//i.test(src)){ alert('edImgAlert','inf','Enter a product page URL above (or paste a direct image URL below).'); return; }
  alert('edImgAlert','inf','Fetching images…');
  try{ const found=await scrapeImages(src); if(found.length){ imgs=found.map(u=>({url:u})); sel=[0]; renderImgGrid(); alert('edImgAlert','ok',found.length+' image(s) found — first is the hero. Click to pick up to 4.'); } else alert('edImgAlert','wr','No images found automatically — paste the product image URLs below.'); }
  catch(e){ alert('edImgAlert','wr','Could not fetch — paste the product image URLs below. '+e.message); }
}
$('edFind').addEventListener('click',findImages);
$('edImgUrl').addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();findImages();}});
$('edImgGrid').addEventListener('click',e=>{const c=e.target.closest('[data-i]');if(!c)return;const i=parseInt(c.dataset.i);const k=sel.indexOf(i);if(k>=0)sel.splice(k,1);else{if(sel.length>=4){alert('edImgAlert','inf','Maximum 4 images — deselect one first.');return;}sel.push(i);}renderImgGrid();});
$('edImgPaste').addEventListener('keydown',e=>{if(e.key!=='Enter')return;e.preventDefault();const u=(e.target.value||'').trim();if(!/^https?:\/\//i.test(u)){alert('edImgAlert','er','Enter a full image URL.');return;}imgs.push({url:u});if(sel.length<4)sel.push(imgs.length-1);e.target.value='';alert('edImgAlert','','');renderImgGrid();});
$('edInsert').addEventListener('click',()=>{const chosen=sel.map(i=>imgs[i]).filter(Boolean);if(!chosen.length)return;$('edBody').value=insertImages($('edBody').value,chosen,productName());renderEdPreview();alert('edImgAlert','ok','Images written into the markdown (hero + inline). Review, then Save changes.');});

