// Review parsing helpers
function sectionText(md,name){
  const re=new RegExp('^##\\s*'+name.replace(/[-/\\^$*+?.()|[\]{}]/g,'\\$&')+'.*$','im');
  const m=md.match(re);if(!m)return'';
  const start=m.index+m[0].length;
  const rest=md.slice(start);
  const next=rest.search(/\n##\s/);
  return(next>=0?rest.slice(0,next):rest).trim();
}
function mdAlt(s){return(s||'Product image').replace(/[\[\]\r\n]/g,' ').replace(/\s+/g,' ').trim();}
// Keep markdown clean: collapse runs of blank lines to a single break, drop
// trailing spaces and any horizontal-rule separators (headings divide sections).
function tidyMd(md){return(md||'').replace(/\r/g,'').replace(/[ \t]+\n/g,'\n').replace(/^\s*[-*_]{3,}\s*$/gm,'').replace(/\n{3,}/g,'\n\n').replace(/[ \t]+$/gm,'').trim()+'\n';}
function reviewHeading(brand,name){brand=(brand||'').trim();name=(name||'').trim();let t=name;if(brand&&!name.toLowerCase().startsWith(brand.toLowerCase()))t=(brand+' '+name);t=t.replace(/\s+/g,' ').trim();return(t||'Product')+' Review';}
// Drop any AI-written "Buy"/CTA section and stray [AFFILIATE_LINK] tokens — the page adds its own buy button.
function stripBuy(md){return(md||'').replace(/\n#{2,3}[ \t]*(Buy|Where to Buy|Get It|Shop)\b[\s\S]*$/i,'\n').replace(/\[AFFILIATE_LINK\]/g,'').trim();}
// Minimal inline markdown -> HTML for items placed inside raw HTML blocks.
function inlineMd(t){return(t||'').replace(/!\[[^\]]*\]\([^)]*\)/g,'').replace(/\[([^\]]+)\]\(([^)\s]+)[^)]*\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>').replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>').replace(/(^|[^*])\*([^*]+)\*(?!\*)/g,'$1<em>$2</em>');}
// Turn the Pros & Cons section into a styled two-column box with ✓ / ✗.
function stylePros(md){
  const hm=md.match(/^##[ \t]*Pros[^\n]*$/im);
  if(!hm)return md;
  const afterHead=hm.index+hm[0].length;
  const rest=md.slice(afterHead);const nx=rest.search(/\n##\s/);
  const end=nx>=0?afterHead+nx:md.length;
  const content=md.slice(afterHead,end);
  const lines=content.split('\n');let pros=[],cons=[],side='pros',extra=[];
  for(const ln of lines){const t=ln.trim();if(!t)continue;
    if(/^[-*]\s/.test(t)){(side==='pros'?pros:cons).push(inlineMd(t.replace(/^[-*]\s+/,'')));continue;}
    if(/\]\(/.test(t)){extra.push(t);continue;} // a standalone link line (placement 3 buy link) — keep it
    if(/watch|cons|downside|drawback|against|negative/i.test(t)){side='cons';}else if(/loved|love|pros|liked|like|good|highlight|positive/i.test(t)){side='pros';}
  }
  if(!pros.length&&!cons.length)return md;
  const li=a=>a.map(x=>`<li>${x}</li>`).join('');
  const box=`<div class="pros-cons"><div class="pc-col pc-pros"><div class="pc-h">What I loved</div><ul>${li(pros)}</ul></div><div class="pc-col pc-cons"><div class="pc-h">Watch-outs</div><ul>${li(cons)}</ul></div></div>`;
  const buyLine=extra.length?'\n\n<p class="pc-buy">'+extra.map(inlineMd).join(' ')+'</p>':'';
  return md.slice(0,hm.index)+'## Pros & Cons\n\n'+box+buyLine+'\n'+md.slice(end);
}
// Replace the SHOPIFY_URL / AFFILIATE_URL placement tokens with real anchors (correct rel), or flag for Mel.
function replaceLinkTokens(md,aff,shop){
  const A=(aff||'').trim(),S=(shop||'').trim();
  const mkA=(t)=>A?`<a href="${A}" rel="nofollow sponsored" target="_blank">${t}</a>`:`${t} [AFFILIATE_LINK_NEEDED]`;
  const mkS=(t)=>S?`<a href="${S}" rel="nofollow" target="_blank">${t}</a>`:(A?`<a href="${A}" rel="nofollow sponsored" target="_blank">${t}</a>`:`${t} [SHOPIFY_LINK_NEEDED]`);
  return (md||'')
    .replace(/<a href="SHOPIFY_URL"[^>]*>([\s\S]*?)<\/a>/g,(m,t)=>mkS(t))
    .replace(/<a href="AFFILIATE_URL"[^>]*>([\s\S]*?)<\/a>/g,(m,t)=>mkA(t))
    .replace(/\[([^\]]+)\]\(\s*SHOPIFY_URL\s*\)/g,(m,t)=>mkS(t))
    .replace(/\[([^\]]+)\]\(\s*AFFILIATE_URL\s*\)/g,(m,t)=>mkA(t));
}
// Final clean-up of a built review body before publish/preview.
function polishBody(md){
  md=md||'';
  // 4) drop any leading title/byline before the first H2
  const fi=md.search(/^##\s/m);if(fi>0)md=md.slice(fi);
  md=md.replace(/^#[ \t]+[^\n]*$/gm,'');                 // stray single-# titles
  md=md.replace(/^[>\s]*\*{0,2}reviewed by\b[^\n]*$/gim,''); // 'Reviewed by …' lines
  // 3) remove the Scores tally section and any methodology working (sidebar shows scores)
  md=md.replace(/\n#{2,3}[ \t]*Scores\b[\s\S]*?(?=\n##\s|$)/i,'\n');
  md=md.replace(/^.*\b(calculated|weighted (?:average|sum)|rounded (?:to|up|down)|exact weighted)\b.*$/gim,'');
  md=md.replace(/^[>\s]*\*{0,2}overall:\s*[\d.]+\s*\/\s*5.*$/gim,'');
  // 5) style pros & cons
  md=stylePros(md);
  return md;
}
// Link the first product/brand mention out to the affiliate/product URL (SEO link-out).
function linkifyFirstBold(md,name,brand,url){
  if(!url)return md;
  name=(name||'').trim();brand=(brand||'').trim();
  const targets=[`**${name}**`,`**${brand} ${name}**`,`**${brand}**`,name,brand?`${brand} ${name}`:'',brand]
    .filter(t=>t&&t.replace(/\*/g,'').length>2);
  const lines=md.split('\n');
  for(let li=0;li<lines.length;li++){
    const line=lines[li];
    if(/^\s*#/.test(line)||/^\s*\|/.test(line)||/!\[/.test(line)||/<\w/.test(line)||/\]\(/.test(line))continue; // skip headings, tables, images, raw HTML, existing links
    for(const t of targets){
      const i=line.indexOf(t);
      if(i>=0){lines[li]=line.slice(0,i)+`[${t}](${url})`+line.slice(i+t.length);return lines.join('\n');}
    }
  }
  return md;
}
function insertReviewerBio(md,reviewer){
  reviewer=(reviewer||'').trim();
  if(!reviewer)return md;
  const bio=`\n\n> **Reviewed by ${reviewer.replace(/[*_`]/g,'')}**\n`;
  const m=md.match(/^##\s*Overview.*$/im);
  if(!m)return bio+'\n'+md;
  const start=m.index+m[0].length;const rest=md.slice(start);const nx=rest.search(/\n##\s/);
  const pos=nx>=0?start+nx:md.length;
  return md.slice(0,pos)+bio+md.slice(pos);
}
function insertImages(md,imgs,name){
  imgs=(imgs||[]).slice(0,4);
  if(!imgs.length)return md;
  const alt=mdAlt(name);
  const mk=(im,i)=>`\n\n![${alt}${i?' — image '+(i+1):''}](${im.url})\n`;
  // Collect all H2 headings and their positions.
  const heads=[];const re=/^##\s+(.*)$/gim;let m;
  while((m=re.exec(md))){heads.push({pos:m.index,title:m[1].trim()});}
  if(!heads.length)return imgs.map((im,i)=>mk(im,i)).join('')+'\n'+md;
  // Don't place images right before these structured/CTA sections.
  const skip=/^(overview|scores|faq|buy)/i;
  const ovIdx=heads.findIndex(h=>/^overview/i.test(h.title));
  const featuredPos=(ovIdx>=0&&heads[ovIdx+1])?heads[ovIdx+1].pos:heads[0].pos;
  const inserts=[{pos:featuredPos,text:mk(imgs[0],0)}];
  // Spread the remaining images across later, non-skipped section boundaries.
  const rest=imgs.slice(1);
  const candidates=heads.filter(h=>h.pos>featuredPos&&!skip.test(h.title));
  if(rest.length){
    if(candidates.length){
      const C=candidates.length,R=rest.length,used=new Set();
      rest.forEach((im,j)=>{
        let idx=R===1?Math.round((C-1)/2):Math.round(j*(C-1)/(R-1));
        idx=Math.max(0,Math.min(C-1,idx));
        let probe=idx;while(probe<C&&used.has(probe))probe++;
        if(probe>=C){probe=idx;while(probe>=0&&used.has(probe))probe--;}
        if(probe<0)probe=idx;
        used.add(probe);
        inserts.push({pos:candidates[probe].pos,text:mk(im,j+1)});
      });
    }else{
      rest.forEach((im,j)=>inserts.push({pos:md.length,text:mk(im,j+1)}));
    }
  }
  // Apply from the end so earlier positions stay valid.
  inserts.sort((a,b)=>b.pos-a.pos);
  let body=md;
  for(const ins of inserts)body=body.slice(0,ins.pos)+ins.text+body.slice(ins.pos);
  return body;
}
function scoreBadge(score){
  const n=Math.max(0,Math.min(5,Math.round(score)));
  return `<span class="wss-score"><span class="wss-score-num">${n}</span><span class="wss-score-stars">${'★'.repeat(n)}<span class="off">${'☆'.repeat(5-n)}</span></span></span>`;
}
// Assemble the final review body: reviewer bio after the Overview, then the
// featured image, then each assessment area (no "WSS Assessment" heading) led
// by a circular score badge, with one image between consecutive areas and
// none afterwards.
function buildReviewBody(review,reviewer,imgs,name){
  imgs=(imgs||[]).slice(0,4);
  const alt=mdAlt(name);
  const imgMd=(im,i)=>im?`\n\n![${alt}${i?' — image '+(i+1):''}](${im.url})\n`:'';
  let md=review;
  const am=md.match(/^##\s*WSS[^\n]*Assessment[^\n]*$/im);
  if(!am)return insertImages(md,imgs,name);
  const before=md.slice(0,am.index);
  const afterHead=am.index+am[0].length;
  const restAfter=md.slice(afterHead);
  const nextRel=restAfter.search(/\n##\s/);
  const asmBlock=nextRel>=0?restAfter.slice(0,nextRel):restAfter;
  const after=nextRel>=0?restAfter.slice(nextRel):'';
  const areaRe=/###[ \t]+(.+?)[ \t]*[—–-][ \t]*(\d)[ \t]*\/[ \t]*5[^\n]*\n([\s\S]*?)(?=\n###[ \t]|$)/g;
  const areas=[];let mm;
  while((mm=areaRe.exec(asmBlock)))areas.push({name:mm[1].trim(),score:parseInt(mm[2]),prose:mm[3].trim()});
  if(!areas.length)return insertImages(md,imgs,name);
  let out=before.replace(/\s+$/,'');
  out+=imgMd(imgs[0],0);
  let imgIdx=1;
  areas.forEach((a,i)=>{
    out+=`\n\n### ${a.name}\n\n${scoreBadge(a.score)}\n\n${a.prose}\n`;
    if(i<areas.length-1&&imgs[imgIdx]){out+=imgMd(imgs[imgIdx],imgIdx);imgIdx++;}
  });
  out+='\n\n'+after.replace(/^\s+/,'');
  return out;
}
function makeMeta(review){
  let v=sectionText(review,'The Verdict')||sectionText(review,'Verdict')||extractExcerpt(review);
  v=v.replace(/\s+/g,' ').trim();
  if(v.length>150)v=v.slice(0,147).replace(/[\s,;:.]+\S*$/,'')+'…';
  return v;
}
function parseFaq(review){
  const sec=sectionText(review,'FAQ');if(!sec)return[];
  const parts=sec.split(/\n?###\s+/).slice(1);
  return parts.map(p=>{const lines=p.split('\n');const q=lines[0].trim();const a=lines.slice(1).join(' ').replace(/\s+/g,' ').trim();return{q,a};}).filter(x=>x.q&&x.a).slice(0,5);
}
function extractExcerpt(review){
  const lines=review.split('\n').filter(l=>l.trim()&&!l.startsWith('#'));
  return(lines[0]||'').slice(0,155).replace(/"/g,"'");
}

