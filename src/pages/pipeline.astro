---
export const prerender = true;
import { taxonomy } from '../data/taxonomy.js';
import AuthGate from '../components/AuthGate.astro';
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WSS™ Review Pipeline</title>
<meta name="robots" content="noindex,nofollow"/>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style is:global>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Poppins',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f5;color:#111;padding:1.5rem}
.wrap{max-width:900px;margin:0 auto}
button{cursor:pointer;border:none;font-family:inherit;font-size:13px;transition:opacity .15s}
button:disabled{opacity:.4;cursor:not-allowed}
input,textarea,select{font-family:inherit;font-size:13px;border:1px solid #ddd;border-radius:6px;padding:8px 10px;width:100%;background:#fff;color:#111;outline:none}
input:focus,textarea:focus,select:focus{border-color:#FF5E84;box-shadow:0 0 0 3px rgba(255,94,132,.1)}
textarea{resize:vertical;line-height:1.65}
label{font-size:12px;color:#666;display:block;margin-bottom:3px}
.bp{background:#FF5E84;color:#fff;padding:8px 18px;border-radius:6px;font-size:13px;font-weight:600}
.bp:hover:not(:disabled){background:#e04470}
.bg{background:#fff;color:#555;border:1px solid #ddd;padding:8px 16px;border-radius:6px;font-size:13px}
.bg:hover:not(:disabled){background:#f5f5f5}
.bset{background:#fff;border:1px solid #ddd;color:#777;padding:7px 13px;border-radius:6px;font-size:12px}
.bset.on{border-color:#FF5E84;color:#FF5E84;background:#fff8f9}
.card{background:#fff;border:1px solid #eee;border-radius:10px;padding:1.25rem;margin-bottom:1rem}
.card.pk{border-color:#FF5E84}
.slbl{font-size:13px;font-weight:700;color:#000036;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.dot{width:22px;height:22px;background:#FF5E84;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0}
.dot.g{background:#4CAF50}
.dot.b{background:#000036}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;margin-top:8px}
.row{display:flex;gap:8px;align-items:flex-end}
.tabs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid #eee}
.tab{padding:7px 15px;border-radius:6px;font-size:12px;font-weight:600;border:1px solid #ddd;background:#f5f5f5;color:#777;cursor:pointer;transition:all .15s}
.tab.act{background:#FF5E84;color:#fff;border-color:#FF5E84}
.tab.dn{background:#fff0f4;color:#FF5E84;border-color:#ffc8d5}
.sbar{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;gap:10px;flex-wrap:wrap}
.sdesc{font-size:13px;color:#777;flex:1;line-height:1.5}
.out{background:#f9f9f9;border:1px solid #eee;border-radius:8px;padding:1rem 1.25rem;font-size:13px;line-height:1.75;color:#222;white-space:pre-wrap;min-height:80px;word-break:break-word}
.empty{color:#bbb}
.cursor{display:inline-block;width:7px;height:14px;background:#FF5E84;margin-left:2px;vertical-align:text-bottom;animation:bl 1s step-end infinite}
@keyframes bl{0%,100%{opacity:1}50%{opacity:0}}
.fb{margin-top:10px}
.fb textarea{min-height:50px;margin-bottom:8px}
.fbr{display:flex;gap:8px}
.al{padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:8px;line-height:1.5}
.al.er{background:#fff0f0;border:1px solid #fcc;color:#c00}
.al.ok{background:#f0fff4;border:1px solid #9f9;color:#060}
.al.inf{background:#f0f8ff;border:1px solid #bee;color:#336}
.igrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;margin-top:8px}
.icard{border:3px solid #e5e5e5;border-radius:8px;overflow:hidden;cursor:pointer;transition:all .15s;position:relative;opacity:.5;background:#f3f3f3}
.icard:hover{opacity:.85}
.icard.sel{border-color:#FF5E84;opacity:1;box-shadow:0 2px 10px rgba(255,94,132,.25)}
.icard img{width:100%;height:110px;object-fit:cover;display:block}
.icard .itick{display:none;position:absolute;top:5px;right:5px;background:#FF5E84;color:#fff;border-radius:50%;width:24px;height:24px;font-size:14px;align-items:center;justify-content:center;font-weight:700;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.icard.sel .itick{display:flex}
.icard .ifeat{display:none;position:absolute;top:5px;left:5px;background:#000036;color:#fff;border-radius:4px;padding:3px 7px;font-size:10px;font-weight:700;letter-spacing:.02em}
.icard.feat .ifeat{display:block}
.icard .itype{font-size:10px;color:#999;padding:3px 6px;background:#f9f9f9;text-align:center}
.rv{background:#f9f9f9;border:1px solid #eee;border-radius:6px;padding:8px 12px;margin-bottom:6px;font-size:12px}
.rv .rstar{color:#f5a623;margin-bottom:2px}
.rv .rauth{color:#999;font-size:11px;margin-top:3px}
.retlist{border:1px solid #eee;border-radius:6px;overflow:hidden;max-height:200px;overflow-y:auto;margin-top:6px}
.retitem{display:flex;align-items:center;gap:10px;padding:9px 14px;cursor:pointer;border-bottom:1px solid #f5f5f5;transition:background .1s}
.retitem:last-child{border-bottom:none}
.retitem:hover{background:#fff8fa}
.retitem.sel{background:#fff0f4}
.retn{font-size:13px;font-weight:600}
.retd{font-size:11px;color:#aaa;margin-top:1px}
.retck{width:16px;height:16px;border-radius:50%;border:2px solid #ddd;margin-left:auto;flex-shrink:0}
.retitem.sel .retck{background:#FF5E84;border-color:#FF5E84}
.retlist:has(select){max-height:none;overflow:visible}
.retlist select{width:100%;border:none;padding:11px 12px;font-size:14px;background:#fff;border-radius:6px;cursor:pointer}
.retlist select:focus{box-shadow:none}
.ec{border:1px solid #eee;border-radius:8px;overflow:hidden;margin-bottom:8px}
.eh{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#f9f9f9;cursor:pointer;user-select:none}
.eht{font-size:13px;font-weight:700;color:#FF5E84}
.eb{padding:12px 14px}
.efl{font-size:11px;color:#aaa;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
.ef{margin-bottom:10px}
.ci{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid #f0f0f0}
.ci:last-child{border-bottom:none}
.ck{width:20px;height:20px;border-radius:50%;border:2px solid #ddd;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700}
.ck.yes{background:#FF5E84;border-color:#FF5E84;color:#fff}
.cl{font-size:13px;color:#888}
.cl.yes{color:#111;font-weight:500}
.cr{margin-left:auto;font-size:12px;padding:4px 10px;background:#fff;border:1px solid #ddd;border-radius:5px;cursor:pointer;color:#666}
.mlb{background:#f9f9f9;border:1px solid #eee;border-radius:8px;padding:12px 14px;margin-top:12px}
.mlb p{font-size:12px;color:#777;margin-bottom:6px}
.mlb code{font-size:11px;line-height:1.6;color:#222;display:block;white-space:pre-wrap;word-break:break-word;background:#fff;padding:8px 10px;border-radius:6px;border:1px solid #eee;font-family:monospace}
.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:10px}
.hdr-l{display:flex;align-items:center;gap:12px}
.bar{width:6px;height:36px;background:#FF5E84;border-radius:3px;flex-shrink:0}
.ttl{font-size:20px;font-weight:700;color:#000036}
.sub{font-size:12px;color:#999;margin-top:2px}
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:flex-start;justify-content:center;padding-top:50px}
.ov.show{display:flex}
.mo{background:#fff;border-radius:12px;padding:1.5rem;width:100%;max-width:540px;margin:0 1rem;max-height:88vh;overflow-y:auto}
.moh{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
.mot{font-size:16px;font-weight:700;color:#000036}
.mox{background:none;border:none;font-size:22px;color:#aaa;cursor:pointer}
.mof{margin-bottom:12px}
.ht{background:#f9f9f9;border:1px solid #eee;border-radius:6px;padding:10px 14px;font-size:12px;line-height:1.75;color:#555;margin-bottom:14px}
.ht strong{color:#000036}
.mnote{font-size:11px;color:#bbb;margin-top:10px;line-height:1.5}
.div{border:none;border-top:1px solid #eee;margin:14px 0}
.gh-status{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px}
.gh-status.ok{background:#f0fff4;border:1px solid #9f9;color:#060}
.gh-status.er{background:#fff0f0;border:1px solid #fcc;color:#c00}
.deploy-link{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#000036;color:white;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;margin-top:8px;margin-right:8px}
.deploy-link:hover{background:#000060}
.deploy-link.pink{background:#FF5E84}
.deploy-link.pink:hover{background:#e04470}
.kw{font-size:11px;color:#FF5E84;background:#fff0f4;border:1px solid #ffc8d5;border-radius:6px;padding:6px 10px;margin-bottom:8px;line-height:1.5}
@media(max-width:600px){.g4{grid-template-columns:1fr 1fr}}
/* Review preview modal */
.pv-bar{display:flex;justify-content:space-between;align-items:center;background:#000036;padding:12px 18px}
.pv-scroll{max-height:84vh;overflow-y:auto;background:#fff}
.pv-hero{background:#000036;color:#fff;padding:22px}
.pv-pill{display:inline-block;background:rgba(255,255,255,.15);color:#fff;font-size:11px;font-weight:600;text-transform:capitalize;padding:3px 10px;border-radius:999px;margin-bottom:8px}
.pv-title{font-size:24px;font-weight:700;margin:0 0 6px}
.pv-brand{font-size:13px;opacity:.75;margin-bottom:10px}
.pv-score{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.pv-score .overall-num{font-size:18px;font-weight:700}
.pv-badge{background:#FF5E84;color:#fff;font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px}
.pv-byline{display:flex;align-items:center;gap:9px;margin-top:12px;font-size:13px;opacity:.9}
.pv-byline img{width:38px;height:38px;border-radius:50%;object-fit:cover;border:2px solid #FF5E84}
.pv-content{padding:22px;font-size:15px;line-height:1.7;color:#374151}
.pv-content h2{font-size:21px;color:#000036;margin:1.5rem 0 .5rem}
.pv-content h3{font-size:16px;color:#000036;margin:1.1rem 0 .35rem}
.pv-content h2:first-child,.pv-content h3:first-child{margin-top:0}
.pv-content p{margin:0 0 .8rem}
.pv-content strong{color:#111827}
.pv-content a{color:#FF5E84;text-decoration:underline}
.pv-content ul,.pv-content ol{margin:0 0 1rem 1.25rem}
.pv-content li{margin-bottom:.35rem}
.pv-content img{width:100%;border-radius:10px;margin:1.2rem 0}
.pv-content blockquote{border-left:3px solid #FF5E84;background:#fff0f4;border-radius:0 6px 6px 0;padding:.7rem 1.1rem;margin:1.1rem 0;font-style:italic}
.pv-content table{width:100%;border-collapse:collapse;font-size:13.5px;border:1px solid #eee;border-radius:8px;overflow:hidden;margin:1.2rem 0}
.pv-content thead{background:#000036}
.pv-content th{color:#fff;text-align:left;padding:.6rem .8rem;font-size:12px;text-transform:uppercase}
.pv-content td{padding:.6rem .8rem;border-top:1px solid #eee}
.pv-content tbody tr:nth-child(odd){background:#fafafa}
.pv-content tbody tr:first-child{background:#fff0f4}
.pv-content tbody tr:first-child td{font-weight:600;color:#111827}
.pv-content .wss-score{display:inline-flex;align-items:center;gap:.5rem;margin:.1rem 0 .8rem}
.pv-content .wss-score-num{display:inline-flex;align-items:center;justify-content:center;width:2.2rem;height:2.2rem;border-radius:50%;background:#FF5E84;color:#fff;font-weight:700;font-size:1.05rem}
.pv-content .wss-score-stars{color:#FF5E84;font-size:1.1rem;letter-spacing:.08em}
.pv-content .wss-score-stars .off{color:#dcdcdc}
.pv-cta{display:flex;gap:.6rem;flex-wrap:wrap;margin:1.6rem 0 1rem}
.pv-content .pv-buy,.pv-content .pv-buy:hover{display:inline-flex;align-items:center;background:#FF5E84;color:#fff;font-weight:700;padding:.75rem 1.4rem;border-radius:8px;text-decoration:none}
.pv-content .pv-buy.alt{background:#000036;color:#fff}
.pv-buy.alt{background:#000036}
.pv-reviewer{display:flex;gap:1rem;align-items:center;background:#f7f7f7;border:1px solid #eee;border-radius:10px;padding:1.1rem;margin:1.3rem 0 .3rem}
.pv-reviewer img{width:58px;height:58px;border-radius:50%;object-fit:cover;border:2px solid #FF5E84;flex-shrink:0}
.pv-reviewer .lbl{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:#9ca3af}
.pv-reviewer .nm{font-weight:700;color:#000036}
.pv-reviewer .bio{font-size:.85rem;color:#555;margin:.3rem 0 0;line-height:1.5}
.pv-content .pros-cons{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.25rem 0}
.pv-content .pc-col{border:1px solid #eee;border-radius:10px;padding:1rem 1.1rem;background:#f7f7f7}
.pv-content .pc-pros{border-top:4px solid #bde1c9}
.pv-content .pc-cons{border-top:4px solid #FF5E84}
.pv-content .pc-h{font-weight:700;color:#000036;margin-bottom:.6rem;font-size:.95rem}
.pv-content .pros-cons ul{list-style:none;margin:0;padding:0}
.pv-content .pros-cons li{position:relative;padding-left:1.7rem;margin-bottom:.5rem;font-size:.9rem;line-height:1.5;color:#374151}
.pv-content .pc-pros li::before{content:'✓';position:absolute;left:0;color:#2e9e5b;font-weight:800}
.pv-content .pc-cons li::before{content:'✗';position:absolute;left:0;color:#FF5E84;font-weight:800}
.pv-content .pc-buy{margin:1rem 0 .25rem;font-weight:600}
.pv-content .pc-buy a{color:#FF5E84;text-decoration:underline}
@media(max-width:600px){.pv-content .pros-cons{grid-template-columns:1fr}}
.pv-stars-wrap{position:relative;display:inline-block;white-space:nowrap;line-height:1;letter-spacing:.05em;font-size:18px}
.pv-stars-bg{color:rgba(255,255,255,.35)}
.pv-stars-fg{position:absolute;top:0;left:0;overflow:hidden;color:#FF5E84;width:0}
</style>
<script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
<AuthGate>
<div class="wrap">

<div class="hdr">
  <div class="hdr-l">
    <div class="bar"></div>
    <div>
      <div class="ttl">WSS™ Review Pipeline</div>
      <div class="sub">Scrape → Research → Affiliate → Write → Push → Reel → Emails → Social</div>
    </div>
  </div>
  <div style="display:flex;gap:8px">
    <button class="bset" id="manageBtn">📄 Manage</button>
    <button class="bset" id="settingsBtn">⚙ Settings</button>
  </div>
</div>

<div class="card pk">
  <div class="slbl"><div class="dot">1</div>Product URL</div>
  <div class="row">
    <div style="flex:2"><label>Product URL *</label><input id="pUrl" type="url" placeholder="https://brand.com/products/product-name"/></div>
    <div style="flex:1"><label>Product type *</label><select id="pType"><option value="apparel">Apparel</option><option value="equipment">Equipment</option><option value="footwear">Footwear</option><option value="nutrition">Nutrition</option><option value="technology">Technology</option></select></div>
    <div><button class="bp" id="scrapeBtn" style="white-space:nowrap">Scrape →</button></div>
  </div>
  <div id="scrapeAlert" style="margin-top:8px"></div>
  <div id="findings" style="display:none;margin-top:12px">
    <div class="al inf">Auto-scraped from the product page — edit if anything looks wrong.</div>
    <div class="g4">
      <div><label>Product name</label><input id="pName" placeholder="—"/></div>
      <div><label>Brand</label><input id="pBrand" placeholder="—"/></div>
      <div><label>Price (£)</label><input id="pPrice" placeholder="—"/></div>
      <div><label>Size range</label><input id="pSizes" placeholder="—"/></div>
    </div>
    <div class="g4" style="margin-top:8px">
      <div><label>Category</label><select id="pCategory">{taxonomy.map((c)=>(<option value={c.slug}>{c.name}</option>))}</select></div>
      <div><label>Subcategory</label><select id="pSubcategory"><option value="">— optional —</option></select></div>
      <div><label>Sub-subcategory</label><select id="pSubsubcategory"><option value="">— optional —</option></select></div>
      <div><label>&nbsp;</label><div style="font-size:11px;color:#aaa;line-height:1.3;padding-top:8px">Files the review into the menu taxonomy.</div></div>
    </div>
    <div style="margin-top:8px"><label>Key specs</label><textarea id="pSpecs" rows="2" placeholder="Key specifications found on the page…"></textarea></div>
    <div style="margin-top:8px"><label>WSS store (Shopify) link — optional; primary buy link when set</label><input id="pShopify" placeholder="https://shop.womenssportsstore.com/products/…"/></div>
  </div>
</div>

<div id="researchSection" style="display:none">
  <div class="card">
    <div class="slbl"><div class="dot">2</div>Research &amp; pre-assessment</div>
    <div id="researchOut" class="out empty">Analysing product…</div>
  </div>
  <div class="card">
    <div class="slbl"><div class="dot">3</div>Select images for the article</div>
    <div id="imageAlert"></div><div id="imageGrid" class="igrid"></div>
    <div id="imgStatus" style="font-size:12px;color:#888;margin-top:10px;font-weight:600"></div>
    <div style="display:flex;gap:8px;margin-top:8px">
      <input id="manualImgUrl" placeholder="Or paste an image URL to add it…"/>
      <button class="bg" id="addImgBtn" style="white-space:nowrap;padding:8px 14px">+ Add image</button>
    </div>
    <p style="font-size:11px;color:#aaa;margin-top:6px">Pick up to 4 images. The first one (★ Featured) becomes the hero; the rest are spread through the article.</p>
  </div>
  <div class="card">
    <div class="slbl"><div class="dot">4</div>Generate affiliate link (Avelon)</div>
    <p style="font-size:13px;color:#777;margin-bottom:8px">Select retailer:</p>
    <div id="retailerList" class="retlist"><div class="out empty" style="margin:0;border:none;background:none">Connect Avelon in Settings to load retailers…</div></div>
    <div style="margin-top:10px;display:flex;gap:8px;align-items:flex-end">
      <div style="flex:2"><label>Destination URL</label><input id="destUrl" placeholder="https://brand.com/products/…"/></div>
      <button class="bp" id="affBtn" style="white-space:nowrap;padding:9px 14px">Generate link</button>
    </div>
    <div id="affAlert" style="margin-top:6px"></div>
    <div id="affResult" style="display:none;margin-top:8px">
      <label>Affiliate tracking link</label>
      <div style="display:flex;gap:8px;margin-top:4px">
        <input id="affLink" readonly style="background:#f9f9f9;font-size:12px"/>
        <button class="bg" id="affCopyBtn" style="white-space:nowrap;padding:8px 12px">Copy</button>
      </div>
    </div>
  </div>
</div>

<div class="tabs" id="tabs" style="display:none">
  <div class="tab" data-s="write">5. Write Review</div>
  <div class="tab" data-s="push">6. Push to GitHub</div>
  <div class="tab" data-s="reel">7. Reel Script</div>
  <div class="tab" data-s="emails">8. Emails</div>
  <div class="tab" data-s="social">9. Social Copy</div>
  <div class="tab" data-s="approve">10. Holly Approves</div>
</div>

<div id="s-write" style="display:none">
  <div class="card">
    <div class="sbar"><span class="sdesc">Writes the full WSS™ review — apparel (6 pillars + star scores, full SEO sections) or nutrition (4 weighted criteria).</span><button class="bp" id="writeBtn">Write review →</button></div>
    <div id="writeTypeInfo" style="margin-bottom:8px"></div>
    <div id="writeKw" class="kw" style="display:none"></div>
    <div class="al inf" style="margin-bottom:10px">Reviewer name, bio &amp; photo are set once in ⚙ Settings → Reviewer profile, then reused on every review.</div>
    <div style="margin-bottom:10px">
      <label>Pre-set scores (optional) — leave blank to let WSS™ decide; any you set are used exactly</label>
      <div id="scoreInputs" class="g4"></div>
    </div>
    <div style="margin-bottom:10px"><label>Tester notes (optional — never fabricated; gaps flagged "Not independently verified")</label><textarea id="testerNotes" rows="2" placeholder="e.g. Tested size 12. Run-tested 3 sessions including 16km trail."></textarea></div>
    <div id="writeOut" class="out empty">Output will appear here…</div>
    <div id="writeEditWrap" style="display:none;margin-top:8px"><label>Edit before publishing:</label><textarea id="writeEdit" rows="16" style="margin-top:4px"></textarea></div>
    <div id="writeFB" class="fb" style="display:none">
      <label>Holly's feedback:</label><textarea id="writeFBText" rows="2" placeholder="e.g. Verdict too soft…"></textarea>
      <div class="fbr"><button class="bp" id="writeApproveBtn">✓ Approve</button><button class="bg" id="writeRegenBtn">↺ Regenerate</button></div>
    </div>
  </div>
</div>

<div id="s-push" style="display:none">
  <div class="card">
