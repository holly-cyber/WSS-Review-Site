---
import { withBase } from '../data/taxonomy.js';
import BaseLayout from './BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { findReviewer } from '../data/team.js';

const { frontmatter: fm } = Astro.props;
const author = fm.author || fm.tested_by || '';
const writer = findReviewer(author);
const avatar = fm.author_avatar || writer?.image;
const dateLabel = fm.date
  ? new Date(fm.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

// Other recent news (newest first), excluding this article.
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).pop();
const newsMods = import.meta.glob('../pages/news/*.md', { eager: true });
const moreNews = Object.entries(newsMods)
  .map(([p, m]: [string, any]) => ({ ...(m.frontmatter || {}), slug: p.split('/').pop().replace('.md', '') }))
  .filter((n) => n.slug !== currentSlug && (import.meta.env.PROD ? n.draft !== true : true))
  .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime())
  .slice(0, 3);

const sources = Array.isArray(fm.sources) ? fm.sources : [];
const sourceHost = (u: string) => { try { return new URL(u).hostname.replace(/^www\./, ''); } catch { return ''; } };
---
<BaseLayout title={fm.title} description={fm.meta_description || fm.excerpt} ogImage={fm.hero_image} noindex={import.meta.env.PROD && fm.draft === true}>
  <article class="news">
    <div class="container news-head">
      <div class="breadcrumb"><a href="/news/">News</a>{fm.topic ? <> / <span>{fm.topic}</span></> : null}</div>
      <h1>{fm.title}</h1>
      {fm.excerpt && <p class="news-standfirst">{fm.excerpt}</p>}
      <div class="news-meta">
        {avatar && <img class="news-avatar" src={withBase(avatar)} alt={author} loading="lazy" />}
        <span>
          {author && (<>By {writer ? <a href={`/reviewers/${writer.slug}/`}><strong>{author}</strong></a> : <strong>{author}</strong>}</>)}
          {author && dateLabel ? ' · ' : ''}{dateLabel}
        </span>
      </div>
    </div>

    {fm.hero_image && <div class="container"><img class="news-hero" src={withBase(fm.hero_image)} alt={fm.title} />{fm.hero_credit && <p class="news-hero-credit">{fm.hero_credit}</p>}</div>}

    <div class="container news-body">
      <div class="news-prose"><slot /></div>

      {sources.length > 0 && (
        <div class="news-sources">
          <h3>Sources</h3>
          <ul>
            {sources.map((s) => (
              <li><a href={s.url} target="_blank" rel="nofollow noopener">{s.title || sourceHost(s.url) || s.url}</a>{sourceHost(s.url) && <span class="news-source-host"> — {sourceHost(s.url)}</span>}</li>
            ))}
          </ul>
        </div>
      )}

      <p class="news-disclaimer">This article was produced by the WSS editorial team using the sources above. Spot something off? <a href="mailto:hello@womenssportsstore.com">Let us know</a>.</p>
    </div>

    {moreNews.length > 0 && (
      <div class="container news-more">
        <h2>More news</h2>
        <div class="news-more-grid">
          {moreNews.map((n) => (
            <a class="news-more-card" href={`/news/${n.slug}/`}>
              {n.hero_image && <img src={withBase(n.hero_image)} alt={n.title} loading="lazy" />}
              <div class="news-more-body">
                {n.topic && <span class="news-more-topic">{n.topic}</span>}
                <span class="news-more-title">{n.title}</span>
                {n.date && <span class="news-more-date">{new Date(n.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="container"><EmailSignup /></div>
  </article>

  <script define:vars={{ newsSlug: currentSlug, newsTitle: fm.title || '', newsTopic: fm.topic || '' }}>
    // Fire a custom "news-view" analytics event once Umami is ready (it loads
    // deferred, so poll briefly). No-ops when analytics isn't configured.
    (function () {
      function track() {
        if (window.umami && typeof window.umami.track === 'function') {
          try { window.umami.track('news-view', { slug: newsSlug, title: newsTitle, topic: newsTopic }); } catch (e) {}
          return true;
        }
        return false;
      }
      if (!track()) { var n = 0, id = setInterval(function () { if (track() || ++n > 25) clearInterval(id); }, 150); }
    })();
  </script>
</BaseLayout>

<style>
.news { padding-bottom: 3rem; }
.news-head { max-width: 760px; margin: 0 auto; padding-top: 2.5rem; }
.news .breadcrumb { font-size: .85rem; color: #888; margin-bottom: 1rem; text-transform: capitalize; }
.news .breadcrumb a { color: #FF5E84; text-decoration: none; }
.news-head h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.15; color: #000036; margin: 0 0 .8rem; }
.news-standfirst { font-size: 1.15rem; color: #444; line-height: 1.5; margin: 0 0 1.2rem; }
.news-meta { display: flex; align-items: center; gap: .6rem; font-size: .9rem; color: #666; }
.news-meta a { color: #000036; text-decoration: none; }
.news-avatar { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 2px solid #FF5E84; }
.news-hero { display: block; width: 100%; max-width: 920px; margin: 1.6rem auto 0; border-radius: 14px; object-fit: cover; }
.news-hero-credit { max-width: 920px; margin: .4rem auto 0; font-size: .75rem; color: #9ca3af; text-align: right; }
.news-body { max-width: 760px; margin: 0 auto; }
.news-prose { font-size: 1.06rem; line-height: 1.75; color: #1f2430; margin-top: 1.8rem; }
.news-prose :global(h2) { font-size: 1.5rem; color: #000036; margin: 2rem 0 .8rem; }
.news-prose :global(h3) { font-size: 1.2rem; color: #000036; margin: 1.6rem 0 .6rem; }
.news-prose :global(p) { margin: 0 0 1.1rem; }
.news-prose :global(ul), .news-prose :global(ol) { margin: 0 0 1.1rem 1.2rem; }
.news-prose :global(li) { margin: .3rem 0; }
.news-prose :global(a) { color: #FF5E84; }
.news-prose :global(img) { width: 100%; border-radius: 12px; margin: 1.4rem 0; }
.news-prose :global(blockquote) { border-left: 3px solid #FF5E84; margin: 1.4rem 0; padding: .2rem 0 .2rem 1.1rem; color: #555; font-style: italic; }
.news-sources { background: #f7f7fb; border: 1px solid #ececf3; border-radius: 12px; padding: 1rem 1.2rem; margin: 2rem 0 1.2rem; }
.news-sources h3 { margin: 0 0 .5rem; font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; color: #8a8aa3; }
.news-sources ul { margin: 0; padding-left: 1.1rem; }
.news-sources li { margin: .35rem 0; font-size: .95rem; }
.news-sources a { color: #000036; }
.news-source-host { color: #999; font-size: .85rem; }
.news-disclaimer { font-size: .85rem; color: #999; margin: 1.4rem 0 0; }
.news-more { max-width: 920px; margin: 2.5rem auto 0; }
.news-more h2 { font-size: 1.3rem; color: #000036; margin: 0 0 1rem; }
.news-more-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
.news-more-card { display: flex; flex-direction: column; border: 1px solid #ececf3; border-radius: 12px; overflow: hidden; text-decoration: none; background: #fff; transition: box-shadow .15s; }
.news-more-card:hover { box-shadow: 0 6px 20px rgba(0,0,54,.08); }
.news-more-card img { width: 100%; height: 130px; object-fit: cover; }
.news-more-body { padding: .8rem .9rem; display: flex; flex-direction: column; gap: .3rem; }
.news-more-topic { font-size: .7rem; text-transform: uppercase; letter-spacing: .05em; color: #FF5E84; font-weight: 600; }
.news-more-title { font-size: .98rem; color: #000036; font-weight: 600; line-height: 1.3; }
.news-more-date { font-size: .8rem; color: #999; }
</style>
